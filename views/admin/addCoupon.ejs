<%- include('../partials/admin/header') %>

<main class="ga-main">
  <style>
    /* ── Page Header ── */
    .ga-page-head { padding: 32px 32px 0; margin-bottom: 28px; }
    .ga-page-head__eyebrow { font-size: 10px; font-weight: 500; letter-spacing: 4px; text-transform: uppercase; color: #D4A96A; margin-bottom: 6px; }
    .ga-page-head__title { font-family: 'Cormorant Garant', serif; font-size: 36px; font-weight: 600; color: #1A1A1A; letter-spacing: -0.5px; line-height: 1; }

    /* ── Section wrapper ── */
    .ga-section { padding: 0 32px 40px; }

    /* ── Form card ── */
    .ga-form-card { background: #fff; border-radius: 3px; overflow: hidden; max-width: 860px; margin: 0 auto; }

    /* ── Card top bar (replaces the old gradient header) ── */
    .ga-form-card__bar { background: #1A1A1A; padding: 18px 28px; display: flex; align-items: center; gap: 10px; }
    .ga-form-card__bar-title { font-family: 'Cormorant Garant', serif; font-size: 22px; font-weight: 600; color: #fff; }
    .ga-form-card__bar-icon { color: #D4A96A; font-size: 16px; }

    /* ── Form body ── */
    .ga-form-body { padding: 32px 28px; }

    /* ── Two-column grid for the form fields ── */
    .ga-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 28px; }

    /* ── Each field group ── */
    .ga-field { margin-bottom: 24px; }

    /* ── Labels ── */
    .ga-label { display: block; font-size: 9px; font-weight: 600; letter-spacing: 2.5px; text-transform: uppercase; color: #aaa; margin-bottom: 8px; }

    /* ── Inputs, selects, textareas ── */
    .ga-input,
    .ga-select,
    .ga-textarea {
      width: 100%;
      padding: 10px 14px;
      border: 1.5px solid #E8E2DA;
      border-radius: 2px;
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      color: #1A1A1A;
      background: #fff;
      outline: none;
      transition: border-color 0.2s;
      box-sizing: border-box;  /* so padding doesn't cause overflow */
    }
    .ga-input:focus,
    .ga-select:focus,
    .ga-textarea:focus { border-color: #8B1A1A; }
    .ga-input::placeholder,
    .ga-textarea::placeholder { color: #ccc; }

    /* ── Textarea specific ── */
    .ga-textarea { resize: vertical; min-height: 90px; }

    /* ── Input with a prefix symbol (like ₹ or %) ── */
    .ga-input-wrap { display: flex; align-items: stretch; }
    .ga-input-prefix { display: flex; align-items: center; padding: 0 12px; background: #F4F1EC; border: 1.5px solid #E8E2DA; border-right: none; border-radius: 2px 0 0 2px; font-size: 13px; color: #888; white-space: nowrap; }
    .ga-input-wrap .ga-input { border-radius: 0 2px 2px 0; }

    /* ── Input with a suffix button (like the Generate button) ── */
    .ga-input-with-btn { display: flex; align-items: stretch; gap: 0; }
    .ga-input-with-btn .ga-input { border-radius: 2px 0 0 2px; flex: 1; }
    .ga-generate-btn { padding: 0 16px; background: #F4F1EC; border: 1.5px solid #E8E2DA; border-left: none; border-radius: 0 2px 2px 0; font-family: 'Poppins', sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: #888; cursor: pointer; transition: all 0.2s ease; white-space: nowrap; }
    .ga-generate-btn:hover { background: #1A1A1A; color: #D4A96A; border-color: #1A1A1A; }

    /* ── Two small fields side by side inside the grid ── */
    .ga-mini-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    /* ── Divider line ── */
    .ga-divider { border: none; border-top: 1px solid #F4F1EC; margin: 8px 0 28px; }

    /* ── Toggle switch for status ── */
    .ga-toggle-wrap { display: flex; align-items: center; gap: 12px; padding: 10px 0; }
    .ga-toggle { position: relative; width: 48px; height: 26px; flex-shrink: 0; }
    .ga-toggle input { opacity: 0; width: 0; height: 0; }
    .ga-toggle-slider { position: absolute; inset: 0; background: #E8E2DA; border-radius: 26px; cursor: pointer; transition: background 0.2s; }
    .ga-toggle-slider::before { content: ''; position: absolute; width: 20px; height: 20px; left: 3px; top: 3px; background: #fff; border-radius: 50%; transition: transform 0.2s; }
    .ga-toggle input:checked + .ga-toggle-slider { background: #2e6e4a; }
    .ga-toggle input:checked + .ga-toggle-slider::before { transform: translateX(22px); }
    /* statusLabel text colour is toggled by JS — keep these two classes */
    #statusLabel.text-success { color: #2e6e4a; font-weight: 600; }
    #statusLabel.text-danger  { color: #8B1A1A; font-weight: 600; }

    /* ── Form footer buttons ── */
    .ga-form-footer { display: flex; justify-content: flex-end; gap: 10px; }
    .ga-btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 22px; font-family: 'Poppins', sans-serif; font-size: 10px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; border: none; cursor: pointer; text-decoration: none; transition: all 0.2s ease; border-radius: 2px; }
    .ga-btn--dark   { background: #1A1A1A; color: #fff; }
    .ga-btn--dark:hover { background: #8B1A1A; color: #fff; }
    .ga-btn--ghost  { background: transparent; border: 1.5px solid #E8E2DA; color: #888; }
    .ga-btn--ghost:hover { border-color: #8B1A1A; color: #8B1A1A; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .ga-page-head { padding: 24px 16px 0; }
      .ga-section { padding: 0 16px 32px; }
      .ga-form-body { padding: 24px 16px; }
      .ga-form-grid { grid-template-columns: 1fr; }   /* stack columns on mobile */
      .ga-mini-row  { grid-template-columns: 1fr; }
    }
  </style>

  <!-- Page Header -->
  <div class="ga-page-head">
    <p class="ga-page-head__eyebrow">Manage</p>
    <h1 class="ga-page-head__title">Create Coupon</h1>
  </div>

  <div class="ga-section">
    <div class="ga-form-card">

      <!-- Card top bar -->
      <div class="ga-form-card__bar">
        <i class="bi bi-ticket-perforated ga-form-card__bar-icon"></i>
        <span class="ga-form-card__bar-title">New Coupon</span>
      </div>

      <div class="ga-form-body">
        <!--
          FORM ACTION & METHOD are exactly the same.
          Only the visual wrapping changed.
        -->
        <form action="/admin/coupons/add" method="POST" id="addCouponForm">

          <div class="ga-form-grid">

            <!-- ── LEFT COLUMN ── -->
            <div>

              <!-- Coupon Code -->
              <div class="ga-field">
                <label for="couponCode" class="ga-label">Coupon Code</label>
                <div class="ga-input-with-btn">
                  <!--
                    name="couponCode", id="couponCode", required,
                    style="text-transform:uppercase" — all unchanged
                  -->
                  <input
                    type="text"
                    name="couponCode"
                    id="couponCode"
                    class="ga-input"
                    placeholder="e.g., SUMMER25"
                    required
                    style="text-transform:uppercase"
                  >
                  <!-- id="generateCodeBtn" used by JS below — unchanged -->
                  <button type="button" class="ga-generate-btn" id="generateCodeBtn">Generate</button>
                </div>
              </div>

              <!-- Description -->
              <div class="ga-field">
                <label for="description" class="ga-label">Description</label>
                <!-- name="description", id="description", required — unchanged -->
                <textarea
                  name="description"
                  id="description"
                  class="ga-textarea"
                  placeholder="e.g., Special discount for summer season"
                  required
                ></textarea>
              </div>

              <!-- Discount Type -->
              <div class="ga-field">
                <label for="discountType" class="ga-label">Discount Type</label>
                <!-- name="discountType", id="discountType", required — unchanged -->
                <select name="discountType" id="discountType" class="ga-select" required>
                  <option value="Percentage">Percentage (%)</option>
                  <option value="Fixed Amount">Fixed Amount (₹)</option>
                </select>
              </div>

              <!-- Discount Value -->
              <div class="ga-field">
                <label for="discountValue" class="ga-label">Discount Value</label>
                <div class="ga-input-wrap">
                  <!-- id="discount-symbol" used by JS below — unchanged -->
                  <span class="ga-input-prefix" id="discount-symbol">%</span>
                  <!-- name="discountValue", id="discountValue", required — unchanged -->
                  <input
                    type="number"
                    name="discountValue"
                    id="discountValue"
                    class="ga-input"
                    placeholder="e.g., 15 or 500"
                    required
                    step="0.01"
                  >
                </div>
              </div>

            </div><!-- end left column -->

            <!-- ── RIGHT COLUMN ── -->
            <div>

              <!-- Minimum Purchase -->
              <div class="ga-field">
                <label for="minimumPurchaseAmount" class="ga-label">Minimum Purchase</label>
                <div class="ga-input-wrap">
                  <span class="ga-input-prefix">₹</span>
                  <!-- name="minimumPurchaseAmount", required — unchanged -->
                  <input
                    type="number"
                    name="minimumPurchaseAmount"
                    id="minimumPurchaseAmount"
                    class="ga-input"
                    placeholder="e.g., 1000"
                    required
                  >
                </div>
              </div>

              <!-- Expiry Date -->
              <div class="ga-field">
                <label for="expiryDate" class="ga-label">Expiry Date</label>
                <!-- name="expiryDate", id="expiryDate", required — unchanged -->
                <input type="date" name="expiryDate" id="expiryDate" class="ga-input" required>
              </div>

              <!-- Limit Per User + Total Uses (side by side) -->
              <div class="ga-field">
                <div class="ga-mini-row">
                  <div>
                    <label for="perUserLimit" class="ga-label">Per User Limit</label>
                    <!-- name="perUserLimit", required — unchanged -->
                    <input
                      type="number"
                      name="perUserLimit"
                      id="perUserLimit"
                      class="ga-input"
                      value="1"
                      required
                    >
                  </div>
                  <div>
                    <label for="maxUses" class="ga-label">Total Uses</label>
                    <!-- name="maxUses", required — unchanged -->
                    <input
                      type="number"
                      name="maxUses"
                      id="maxUses"
                      class="ga-input"
                      placeholder="e.g., 100"
                      required
                    >
                  </div>
                </div>
              </div>

              <!-- Status Toggle -->
              <div class="ga-field">
                <label class="ga-label">Status</label>
                <div class="ga-toggle-wrap">
                  <label class="ga-toggle">
                    <!--
                      id="isActive", name="isActive", checked — all unchanged.
                      JS reads this same id to update the label.
                    -->
                    <input type="checkbox" id="isActive" name="isActive" checked>
                    <span class="ga-toggle-slider"></span>
                  </label>
                  <!-- id="statusLabel" used by JS — unchanged -->
                  <span id="statusLabel" class="text-success">Active</span>
                </div>
              </div>

            </div><!-- end right column -->
          </div><!-- end ga-form-grid -->

          <hr class="ga-divider">

          <!-- Footer buttons -->
          <div class="ga-form-footer">
            <!-- Cancel href — unchanged -->
            <a href="/admin/coupons" class="ga-btn ga-btn--ghost">
              <i class="bi bi-x-lg"></i> Cancel
            </a>
            <button type="submit" class="ga-btn ga-btn--dark">
              <i class="bi bi-check-lg"></i> Save Coupon
            </button>
          </div>

        </form>
      </div><!-- end ga-form-body -->
    </div><!-- end ga-form-card -->
  </div><!-- end ga-section -->

</main>

<!--
  ═══════════════════════════════════════════════
  JAVASCRIPT — 100% UNCHANGED from your original.
  Only the toggle uses the new CSS classes above
  instead of Bootstrap's text-success/text-danger,
  but those class names are identical so it still works.
  ═══════════════════════════════════════════════
-->
<script>
  document.addEventListener('DOMContentLoaded', function() {

    // Generate Random Coupon Code
    const generateCodeBtn = document.getElementById('generateCodeBtn');
    const couponCodeInput = document.getElementById('couponCode');

    generateCodeBtn.addEventListener('click', () => {
      const randomCode = Math.random().toString(36).substring(2, 10).toUpperCase();
      couponCodeInput.value = randomCode;
    });

    // Update Discount Symbol when type changes
    const discountTypeSelect = document.getElementById('discountType');
    const discountSymbol = document.getElementById('discount-symbol');

    discountTypeSelect.addEventListener('change', (e) => {
      discountSymbol.textContent = e.target.value === 'Percentage' ? '%' : '₹';
    });

    // Set minimum date for expiry to today
    const expiryDateInput = document.getElementById('expiryDate');
    const today = new Date().toISOString().split('T')[0];
    expiryDateInput.setAttribute('min', today);

    // Toggle switch label (Active / Inactive)
    const isActiveSwitch = document.getElementById('isActive');
    const statusLabel = document.getElementById('statusLabel');

    const updateStatusLabel = () => {
      if (isActiveSwitch.checked) {
        statusLabel.textContent = 'Active';
        statusLabel.classList.remove('text-danger');
        statusLabel.classList.add('text-success');
      } else {
        statusLabel.textContent = 'Inactive';
        statusLabel.classList.remove('text-success');
        statusLabel.classList.add('text-danger');
      }
    };

    isActiveSwitch.addEventListener('change', updateStatusLabel);

    // Run once on page load to set correct colour
    updateStatusLabel();

  });
</script>

<%- include('../partials/admin/footer') %>
