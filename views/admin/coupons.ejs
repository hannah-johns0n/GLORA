<%- include('../partials/admin/header') %>

<style>
  .page-header {
    background: #fff;
    border-bottom: 1px solid #e9ecef;
    padding: 2rem 0;
    margin-bottom: 1rem;
  }
  
  .page-title {
    font-size: 1.75rem;
    font-weight: 600;
    color: #2c3e50;
    margin: 0;
  }
  
  .add-btn {
    background: #3c0707;
    border: none;
    border-radius: 6px;
    padding: 10px 20px;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  
  .add-btn:hover {
    background: #6f0606;
    transform: translateY(-1px);
  }
  
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1rem;
  }
  
  .stat-card {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
  }
  
  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: #2c3e50;
  }
  
  .stat-label {
    color: #6c757d;
    font-size: 0.9rem;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .table-container {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 8px;
    overflow: hidden;
  }
  
  .table {
    margin: 0;
  }
  
  .table thead th {
    background: #f8f9fa;
    color: #495057;
    border: none;
    padding: 1rem;
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .table tbody td {
    padding: 1rem;
    border-top: 1px solid #e9ecef;
    vertical-align: middle;
  }
  
  .table tbody tr:hover {
    background-color: #f8f9fa;
  }
  
  .coupon-code {
    font-family: 'Monaco', 'Consolas', monospace;
    background: #f1f3f4;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 600;
  }
  
  .discount-value {
    font-weight: 600;
    color: #28a745;
  }
  
  .type-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .type-percentage {
    background: #fff3cd;
    color: #856404;
  }
  
  .type-fixed {
    background: #d1ecf1;
    color: #0c5460;
  }
  
  .status-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .status-active {
    background: #d4edda;
    color: #155724;
  }
  
  .status-inactive {
    background: #f8d7da;
    color: #721c24;
  }
  
  .btn-group {
    display: flex;
    gap: 0.5rem;
  }
  
  .btn-sm {
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    border: none;
    transition: all 0.2s ease;
  }
  
  .btn-edit {
    background: #ffc107;
    color: #212529;
  }
  
  .btn-edit:hover {
    background: #e0a800;
    color: #212529;
  }
  
  .btn-delete {
    background: #dc3545;
    color: #fff;
  }
  
  .btn-delete:hover {
    background: #c82333;
  }
  
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 8px;
  }
  
  .empty-icon {
    font-size: 3rem;
    color: #dee2e6;
    margin-bottom: 1rem;
  }
  
  .empty-title {
    color: #6c757d;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  
  .empty-text {
    color: #6c757d;
    margin-bottom: 2rem;
  }
  
  @media (max-width: 768px) {
    .page-header .d-flex {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
    
    .btn-group {
      flex-direction: column;
    }
    
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<main class="col-md-10 ms-sm-auto col-lg-10 px-md-4">
<div class="container-fluid">
  <div class="page-header">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center">
        <h2 class="page-title">Coupons</h2>
        <a href="/admin/coupons/add" class="btn btn-primary add-btn">Add Coupon</a>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-number"><%= coupons ? coupons.length : 0 %></div>
        <div class="stat-label">Total</div>
      </div>
      <div class="stat-card">
        <div class="stat-number text-success"><%= coupons ? coupons.filter(c => c.isActive).length : 0 %></div>
        <div class="stat-label">Active</div>
      </div>
      <div class="stat-card">
        <div class="stat-number text-danger"><%= coupons ? coupons.filter(c => !c.isActive).length : 0 %></div>
        <div class="stat-label">Inactive</div>
      </div>
    </div>

    <% if (coupons && coupons.length > 0) { %>
      <div class="table-container">
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>#</th>
                <th>Code</th>
                <th>Discount</th>
                <th>Min. Purchase</th>
                <th>Expiry Date</th>
                <th>Usage Limit</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% coupons.forEach((coupon, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td>
                    <span class="coupon-code"><%= coupon.couponCode %></span>
                  </td>
                  <td>
                    <span class="discount-value">
                      <%= coupon.discountValue %><%= coupon.type === 'percentage' ? '%' : '₹' %>
                    </span>
                  </td>
                  <td>
                    <span class="min-purchase-amount">
                      ₹<%= coupon.minimumPurchaseAmount || 0 %>
                    </span>
                  </td>
                  <td><%= coupon.expiryDate.toDateString() %></td>
                  <td><%= coupon.maxUses %></td>
                  <td>
                    <% if(coupon.isActive) { %>
                      <span class="status-badge status-active">Active</span>
                    <% } else { %>
                      <span class="status-badge status-inactive">Inactive</span>
                    <% } %>
                  </td>
                  
                  <td>
                    <div class="btn-group">
                      <a href="/admin/coupons/edit/<%= coupon._id %>" class="btn btn-sm btn-edit">Edit</a>
                      <a href="javascript:void(0)" class="btn btn-sm btn-delete" onclick="confirmDelete('<%= coupon._id %>')">Delete</a>

                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">📄</div>
        <h4 class="empty-title">No coupons available</h4>
        <p class="empty-text">Create your first coupon to get started</p>
        <a href="/admin/coupons/add" class="btn btn-primary add-btn">Add Coupon</a>
      </div>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  function confirmDelete(couponId) {
    Swal.fire({
      title: 'Are you sure?',
      text: "This coupon will be permanently deleted.",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#3085d6',
      confirmButtonText: 'Yes, delete it!'
    }).then((result) => {
      if (result.isConfirmed) {
        window.location.href = `/admin/coupons/delete/${couponId}`;
      }
    });
  }

  const urlParams = new URLSearchParams(window.location.search);

  if (urlParams.get('success')) {
    Swal.fire({
      icon: 'success',
      title: 'Coupon Added',
      text: 'The coupon was added successfully!'
    });
  }

  if (urlParams.get('error')) {
    Swal.fire({
      icon: 'error',
      title: 'Oops...',
      text: 'Something went wrong while processing the coupon.'
    });
  }

  if (urlParams.get('deleted')) {
    Swal.fire({
      icon: 'success',
      title: 'Deleted!',
      text: 'The coupon was deleted successfully.'
    });
  }
</script>

</main>
<%- include('../partials/admin/footer') %>