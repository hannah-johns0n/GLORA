<%- include('../partials/admin/header') %>

<main class="ga-main">

  <style>
    .ga-page-head {
      padding: 32px 32px 0;
      margin-bottom: 28px;
    }
    .ga-page-head__eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #D4A96A;
      margin-bottom: 6px;
    }
    .ga-page-head__row {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .ga-page-head__title {
      font-family: 'Cormorant Garant', serif;
      font-size: 36px;
      font-weight: 600;
      color: #1A1A1A;
      letter-spacing: -0.5px;
      line-height: 1;
    }
    .ga-section { padding: 0 32px 40px; }

    .ga-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 20px;
      font-family: 'Poppins', sans-serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s ease;
      border-radius: 2px;
    }
    .ga-btn--dark { background: #1A1A1A; color: #fff; }
    .ga-btn--dark:hover { background: #8B1A1A; color: #fff; }

    .ga-card { background: #fff; border-radius: 3px; overflow: hidden; }
    .ga-table-wrap { overflow-x: auto; }
    .ga-table { width: 100%; border-collapse: collapse; }
    .ga-table thead { background: #1A1A1A; }
    .ga-table thead th {
      padding: 13px 16px;
      text-align: left;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55);
      white-space: nowrap;
    }
    .ga-table tbody td {
      padding: 14px 16px;
      font-size: 13px;
      color: #1A1A1A;
      border-bottom: 1px solid #F4F1EC;
      vertical-align: middle;
    }
    .ga-table tbody tr:last-child td { border-bottom: none; }
    .ga-table tbody tr:hover td { background: #FAF7F4; }

    .ga-product-name { font-weight: 500; }
    .ga-category-tag {
      display: inline-block;
      padding: 2px 8px;
      background: #F4F1EC;
      border-radius: 2px;
      font-size: 11px;
      color: #888;
      letter-spacing: 0.3px;
    }
    .ga-price {
      font-weight: 600;
      color: #1A1A1A;
    }
    .ga-price--sale { color: #8B1A1A; }
    .ga-price--original {
      font-size: 11px;
      color: #bbb;
      text-decoration: line-through;
      font-weight: 400;
      margin-left: 4px;
    }
    .ga-qty {
      font-size: 13px;
      font-weight: 500;
    }
    .ga-qty--low { color: #991b1b; }
    .ga-date { font-size: 12px; color: #aaa; }

    .ga-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 2px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .ga-badge--active  { background: #F0FDF4; color: #166534; }
    .ga-badge--blocked { background: #FEF2F2; color: #991b1b; }

    .ga-actions-cell { display: flex; gap: 8px; align-items: center; }

    .ga-action-btn {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 6px 14px;
      font-family: 'Poppins', sans-serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      border: 1.5px solid;
      border-radius: 2px;
      cursor: pointer;
      background: transparent;
      transition: all 0.2s ease;
      text-decoration: none;
    }
    .ga-action-btn--block   { border-color: #fca5a5; color: #991b1b; }
    .ga-action-btn--block:hover   { background: #991b1b; color: #fff; border-color: #991b1b; }
    .ga-action-btn--unblock { border-color: #86efac; color: #166534; }
    .ga-action-btn--unblock:hover { background: #166534; color: #fff; border-color: #166534; }
    .ga-action-btn--edit    { border-color: #E8E2DA; color: #555; }
    .ga-action-btn--edit:hover    { border-color: #1A1A1A; color: #1A1A1A; }

    .ga-empty {
      text-align: center;
      padding: 64px 20px;
      color: #bbb;
    }
    .ga-empty i { font-size: 2.5rem; display: block; margin-bottom: 14px; color: #E8E2DA; }
    .ga-empty p { font-size: 13px; }

    .ga-pagination {
      display: flex;
      justify-content: center;
      gap: 6px;
      margin-top: 28px;
      list-style: none;
      padding: 0;
    }
    .ga-pagination li a {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: 1.5px solid #E8E2DA;
      font-size: 12px;
      font-weight: 500;
      color: #555;
      text-decoration: none;
      border-radius: 2px;
      transition: all 0.2s ease;
    }
    .ga-pagination li a:hover { border-color: #8B1A1A; color: #8B1A1A; }
    .ga-pagination li.active a { background: #1A1A1A; border-color: #1A1A1A; color: #fff; }

    @media (max-width: 640px) {
      .ga-page-head { padding: 24px 16px 0; }
      .ga-section { padding: 0 16px 32px; }
      .ga-page-head__row { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <div class="ga-page-head">
    <p class="ga-page-head__eyebrow">Manage</p>
    <div class="ga-page-head__row">
      <h1 class="ga-page-head__title">Products</h1>
      <a href="/admin/products/add" class="ga-btn ga-btn--dark">
        <i class="bi bi-plus"></i> Add Product
      </a>
    </div>
  </div>

  <div class="ga-section">
    <div class="ga-card">
      <div class="ga-table-wrap">
        <table class="ga-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Category</th>
              <th>Regular Price</th>
              <th>Sale Price</th>
              <th>Qty</th>
              <th>Created</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!products || products.length === 0) { %>
            <tr>
              <td colspan="8">
                <div class="ga-empty">
                  <i class="bi bi-box"></i>
                  <p>No products found.</p>
                </div>
              </td>
            </tr>
            <% } else { %>
            <% products.forEach(product => { %>
            <tr>
              <td class="ga-product-name"><%= product.productName %></td>
              <td><span class="ga-category-tag"><%= product.category || 'N/A' %></span></td>
              <td>
                <span class="ga-price">
                  <% if (typeof product.regularPrice !== 'undefined') { %>
                    ₹<%= product.regularPrice.toLocaleString('en-IN') %>
                  <% } else { %>
                    —
                  <% } %>
                </span>
              </td>
              <td>
                <span class="ga-price ga-price--sale">
                  <% if (typeof product.salesPrice !== 'undefined') { %>
                    ₹<%= product.salesPrice.toLocaleString('en-IN') %>
                  <% } else { %>
                    —
                  <% } %>
                </span>
              </td>
              <td>
                <span class="ga-qty <%= (product.quantity !== 'undefined' && product.quantity <= 5) ? 'ga-qty--low' : '' %>">
                  <%= typeof product.quantity !== 'undefined' ? product.quantity : '—' %>
                </span>
              </td>
              <td class="ga-date"><%= new Date(product.createdAt).toLocaleDateString('en-IN') %></td>
              <td>
                <span class="ga-badge <%= product.isBlocked ? 'ga-badge--blocked' : 'ga-badge--active' %>">
                  <%= product.isBlocked ? 'Blocked' : 'Active' %>
                </span>
              </td>
              <td>
                <div class="ga-actions-cell">
                  <button
                    onclick="handleBlockAction(this, '<%= product._id %>', <%= !!product.isBlocked %>)"
                    class="ga-action-btn <%= product.isBlocked ? 'ga-action-btn--unblock' : 'ga-action-btn--block' %>">
                    <i class="bi bi-<%= product.isBlocked ? 'unlock' : 'slash-circle' %>"></i>
                    <%= product.isBlocked ? 'Unblock' : 'Block' %>
                  </button>
                  <a href="/admin/products/edit/<%= product._id %>" class="ga-action-btn ga-action-btn--edit">
                    <i class="bi bi-pencil"></i> Edit
                  </a>
                </div>
              </td>
            </tr>
            <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <% if (totalPages > 1) { %>
    <nav>
      <ul class="ga-pagination">
        <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="<%= i === currentPage ? 'active' : '' %>">
          <a href="?page=<%= i %>"><%= i %></a>
        </li>
        <% } %>
      </ul>
    </nav>
    <% } %>
  </div>
</main>

<%- include('../partials/admin/footer') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  async function handleBlockAction(button, productId, isBlocked) {
    const action = isBlocked ? 'unblock' : 'block';
    const buttonText = button.innerHTML;

    try {
      button.disabled = true;
      button.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

      const result = await Swal.fire({
        title: 'Are you sure?',
        text: `Do you want to ${action} this product?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: isBlocked ? '#166534' : '#991b1b',
        cancelButtonColor: '#6c757d',
        confirmButtonText: `Yes, ${action} it!`,
        cancelButtonText: 'Cancel',
        reverseButtons: true
      });

      if (result.isConfirmed) {
        const response = await fetch(`/admin/toggle-product-block`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ id: productId }),
          credentials: 'include'
        });

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          throw new Error(errorData.message || 'Failed to update product status');
        }

        const data = await response.json();

        await Swal.fire({
          icon: 'success',
          title: data.message || `Product ${action}ed successfully!`,
          showConfirmButton: false,
          timer: 1500
        });

        setTimeout(() => { window.location.reload(); }, 1500);
      } else {
        button.disabled = false;
        button.innerHTML = buttonText;
      }
    } catch (error) {
      button.disabled = false;
      button.innerHTML = buttonText;
      await Swal.fire({
        icon: 'error',
        title: 'Error',
        text: error.message || 'Failed to process your request. Please try again.',
        confirmButtonText: 'OK'
      });
    }
  }
</script>
