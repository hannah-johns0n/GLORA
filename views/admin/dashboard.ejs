<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — GLORA Admin</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    .ga-page-head {
      padding: 32px 32px 0;
      margin-bottom: 28px;
    }

    .ga-page-head__eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #D4A96A;
      margin-bottom: 6px;
    }

    .ga-page-head__title {
      font-family: 'Cormorant Garant', serif;
      font-size: 36px;
      font-weight: 600;
      color: #1A1A1A;
      letter-spacing: -0.5px;
      line-height: 1;
    }

    .ga-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      padding: 0 32px 32px;
    }

    .ga-stat {
      background: #fff;
      border-radius: 3px;
      padding: 24px 22px;
      border-bottom: 3px solid transparent;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
    }

    .ga-stat:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.08);
    }

    .ga-stat--customers { border-bottom-color: #D4A96A; }
    .ga-stat--orders    { border-bottom-color: #2e6e4a; }
    .ga-stat--products  { border-bottom-color: #2e4a6e; }
    .ga-stat--revenue   { border-bottom-color: #8B1A1A; }

    .ga-stat__label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #aaa;
      margin-bottom: 10px;
    }

    .ga-stat__value {
      font-family: 'Cormorant Garant', serif;
      font-size: 38px;
      font-weight: 600;
      color: #1A1A1A;
      line-height: 1;
    }

    .ga-stat__icon {
      font-size: 28px;
      opacity: 0.12;
      margin-top: 2px;
    }

    .ga-section {
      padding: 0 32px 32px;
    }

    .ga-section__title {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      color: #D4A96A;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid #E8E2DA;
    }

    .ga-card {
      background: #fff;
      border-radius: 3px;
      margin-bottom: 20px;
      overflow: hidden;
    }

    .ga-card__head {
      padding: 18px 22px 16px;
      border-bottom: 1px solid #F0EBE3;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .ga-card__head-title {
      font-family: 'Cormorant Garant', serif;
      font-size: 20px;
      font-weight: 600;
      color: #1A1A1A;
    }

    .ga-card__head-sub {
      font-size: 11px;
      color: #bbb;
      letter-spacing: 0.3px;
    }

    .ga-card__body {
      padding: 22px;
    }

    .ga-filter-group {
      display: flex;
      gap: 6px;
      align-items: center;
    }

    .ga-filter-label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #bbb;
      margin-right: 4px;
    }

    .ga-filter-btn {
      padding: 5px 13px;
      border: 1px solid #E8E2DA;
      background: #fff;
      color: #888;
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.5px;
      cursor: pointer;
      border-radius: 2px;
      transition: all 0.2s ease;
    }

    .ga-filter-btn.active {
      background: #1A1A1A;
      color: #fff;
      border-color: #1A1A1A;
    }

    .ga-filter-btn:hover:not(.active) {
      border-color: #8B1A1A;
      color: #8B1A1A;
    }

    .ga-chart-wrap {
      position: relative;
      height: 340px;
    }

    .ga-chart-note {
      text-align: center;
      font-size: 11px;
      color: #ccc;
      letter-spacing: 0.5px;
      margin-top: 12px;
      text-transform: uppercase;
    }

    .ga-table {
      width: 100%;
      border-collapse: collapse;
    }

    .ga-table thead {
      border-bottom: 1px solid #F0EBE3;
    }

    .ga-table th {
      padding: 12px 14px;
      text-align: left;
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #bbb;
    }

    .ga-table td {
      padding: 14px 14px;
      border-bottom: 1px solid #F9F6F3;
      font-size: 13px;
      color: #1A1A1A;
      vertical-align: middle;
    }

    .ga-table tbody tr:last-child td { border-bottom: none; }

    .ga-table tbody tr:hover td { background: #FAF7F4; }

    .ga-rank {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      background: #1A1A1A;
      color: #D4A96A;
      border-radius: 50%;
      font-size: 11px;
      font-weight: 600;
      font-family: 'Cormorant Garant', serif;
    }

    .ga-product-name {
      font-weight: 500;
      font-size: 13px;
      color: #1A1A1A;
    }

    .ga-product-meta {
      font-size: 11px;
      color: #bbb;
      margin-top: 2px;
    }

    .ga-metric {
      font-weight: 600;
      font-size: 14px;
      color: #1A1A1A;
    }

    .ga-revenue-tag {
      display: inline-block;
      background: #F0FDF4;
      color: #166534;
      padding: 3px 10px;
      border-radius: 2px;
      font-size: 12px;
      font-weight: 500;
    }

    .ga-status {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 2px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .ga-status--delivered   { background: #F0FDF4; color: #166534; }
    .ga-status--processing  { background: #EFF6FF; color: #1e40af; }
    .ga-status--pending     { background: #FFFBEB; color: #92400e; }
    .ga-status--shipped     { background: #EEF2FF; color: #3730a3; }
    .ga-status--cancelled   { background: #FEF2F2; color: #991b1b; }

    .ga-order-id {
      font-family: monospace;
      font-size: 12px;
      color: #888;
      letter-spacing: 0.5px;
    }

    .ga-amount {
      font-weight: 600;
      color: #8B1A1A;
    }

    .ga-empty {
      text-align: center;
      padding: 48px 20px;
      color: #bbb;
      font-size: 13px;
    }

    .ga-empty i {
      display: block;
      font-size: 2rem;
      color: #E8E2DA;
      margin-bottom: 12px;
    }

    .ga-two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    @media (max-width: 1100px) {
      .ga-stats { grid-template-columns: repeat(2, 1fr); }
      .ga-two-col { grid-template-columns: 1fr; }
    }

    @media (max-width: 640px) {
      .ga-stats { grid-template-columns: 1fr; padding: 0 16px 24px; }
      .ga-page-head { padding: 24px 16px 0; }
      .ga-section { padding: 0 16px 24px; }
    }
  </style>
</head>
<body>
  <%- include('../partials/admin/header') %>

  <main class="ga-main">

    <div class="ga-page-head">
      <p class="ga-page-head__eyebrow">Overview</p>
      <h1 class="ga-page-head__title">Dashboard</h1>
    </div>

    <div class="ga-stats">
      <div class="ga-stat ga-stat--customers">
        <div>
          <p class="ga-stat__label">Customers</p>
          <p class="ga-stat__value"><%= typeof totalCustomers !== 'undefined' ? totalCustomers : '0' %></p>
        </div>
        <div class="ga-stat__icon">👥</div>
      </div>
      <div class="ga-stat ga-stat--orders">
        <div>
          <p class="ga-stat__label">Orders</p>
          <p class="ga-stat__value"><%= typeof totalOrders !== 'undefined' ? totalOrders : '0' %></p>
        </div>
        <div class="ga-stat__icon">📦</div>
      </div>
      <div class="ga-stat ga-stat--products">
        <div>
          <p class="ga-stat__label">Products</p>
          <p class="ga-stat__value"><%= typeof totalProducts !== 'undefined' ? totalProducts : '0' %></p>
        </div>
        <div class="ga-stat__icon">🛍️</div>
      </div>
      <div class="ga-stat ga-stat--revenue">
        <div>
          <p class="ga-stat__label">Revenue</p>
          <p class="ga-stat__value">₹<%= typeof totalSales !== 'undefined' ? totalSales.toFixed(0) : '0' %></p>
        </div>
        <div class="ga-stat__icon">💰</div>
      </div>
    </div>

    <div class="ga-section">
      <p class="ga-section__title">Sales Analytics</p>

      <div class="ga-card">
        <div class="ga-card__head">
          <span class="ga-card__head-title">Revenue Trend</span>
          <div class="ga-filter-group">
            <span class="ga-filter-label">Period</span>
            <button class="ga-filter-btn <%= currentFilter === 'daily'   ? 'active' : '' %>" onclick="changeFilter('daily')">Daily</button>
            <button class="ga-filter-btn <%= currentFilter === 'weekly'  ? 'active' : '' %>" onclick="changeFilter('weekly')">Weekly</button>
            <button class="ga-filter-btn <%= currentFilter === 'monthly' ? 'active' : '' %>" onclick="changeFilter('monthly')">Monthly</button>
            <button class="ga-filter-btn <%= currentFilter === 'yearly'  ? 'active' : '' %>" onclick="changeFilter('yearly')">Yearly</button>
          </div>
        </div>
        <div class="ga-card__body">
          <div class="ga-chart-wrap">
            <canvas id="revenueTrendChart"></canvas>
          </div>
          <p class="ga-chart-note">Revenue over <%= currentFilter %> periods</p>
        </div>
      </div>

      <div class="ga-two-col">
        <div class="ga-card">
          <div class="ga-card__head">
            <span class="ga-card__head-title">Top 5 Products</span>
            <span class="ga-card__head-sub">By completed orders</span>
          </div>
          <div class="ga-card__body" style="padding: 0;">
            <% if (bestSellingProducts && bestSellingProducts.length > 0) { %>
            <table class="ga-table">
              <thead>
                <tr>
                  <th style="width:8%;">#</th>
                  <th>Product</th>
                  <th>Units</th>
                  <th>Revenue</th>
                </tr>
              </thead>
              <tbody>
                <% bestSellingProducts.forEach((product, index) => { %>
                <tr>
                  <td><span class="ga-rank"><%= index + 1 %></span></td>
                  <td>
                    <div class="ga-product-name"><%= product.productName %></div>
                    <div class="ga-product-meta"><%= product.variant?.unit || 'N/A' %></div>
                  </td>
                  <td><span class="ga-metric"><%= product.totalQuantity %></span></td>
                  <td><span class="ga-revenue-tag">₹<%= product.totalRevenue.toLocaleString('en-IN', { maximumFractionDigits: 0 }) %></span></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } else { %>
            <div class="ga-empty"><i class="bi bi-box"></i>No sales data yet</div>
            <% } %>
          </div>
        </div>

        <div class="ga-card">
          <div class="ga-card__head">
            <span class="ga-card__head-title">Top 3 Categories</span>
            <span class="ga-card__head-sub">By completed orders</span>
          </div>
          <div class="ga-card__body" style="padding: 0;">
            <% if (bestSellingCategories && bestSellingCategories.length > 0) { %>
            <table class="ga-table">
              <thead>
                <tr>
                  <th style="width:8%;">#</th>
                  <th>Category</th>
                  <th>Units</th>
                  <th>Revenue</th>
                </tr>
              </thead>
              <tbody>
                <% bestSellingCategories.forEach(function(cat, index) { %>
                <tr>
                  <td><span class="ga-rank"><%= index + 1 %></span></td>
                  <td><span class="ga-product-name"><%= cat.category %></span></td>
                  <td><span class="ga-metric"><%= cat.totalQuantity %></span></td>
                  <td><span class="ga-revenue-tag">₹<%= cat.totalRevenue.toLocaleString('en-IN', { maximumFractionDigits: 0 }) %></span></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } else { %>
            <div class="ga-empty"><i class="bi bi-grid"></i>No category data yet</div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="ga-card">
        <div class="ga-card__head">
          <span class="ga-card__head-title">Recent Orders</span>
        </div>
        <div class="ga-card__body" style="padding: 0;">
          <% if (recentOrders && recentOrders.length > 0) { %>
          <table class="ga-table">
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Status</th>
                <th>Amount</th>
              </tr>
            </thead>
            <tbody>
              <% recentOrders.forEach(function(order) { %>
              <tr>
                <td><span class="ga-order-id"><%- order._id.toString().slice(0, 8).toUpperCase() %></span></td>
                <td><%= order.customerName %></td>
                <td><%= order.date %></td>
                <td>
                  <span class="ga-status ga-status--<%= order.status.toLowerCase().replace(/[-\s]/g, '-') %>">
                    <%= order.status %>
                  </span>
                </td>
                <td><span class="ga-amount">₹<%= order.total.toFixed(2) %></span></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } else { %>
          <div class="ga-empty"><i class="bi bi-cart"></i>No recent orders</div>
          <% } %>
        </div>
      </div>
    </div>

  </main>

  <script>
    const chartCtx = document.getElementById('revenueTrendChart');
    let revenueTrendChart = null;

    const revenueLabels = <%- JSON.stringify(chartLabels) %>;
    const revenueData   = <%- JSON.stringify(chartData) %>;

    function initRevenueTrendChart() {
      if (revenueTrendChart) revenueTrendChart.destroy();

      revenueTrendChart = new Chart(chartCtx, {
        type: 'line',
        data: {
          labels: revenueLabels,
          datasets: [{
            label: 'Revenue (₹)',
            data: revenueData,
            borderColor: '#8B1A1A',
            backgroundColor: 'rgba(139, 26, 26, 0.05)',
            borderWidth: 2,
            fill: true,
            tension: 0.4,
            pointRadius: 4,
            pointBackgroundColor: '#8B1A1A',
            pointBorderColor: '#ffffff',
            pointBorderWidth: 2,
            pointHoverRadius: 6
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: true,
              position: 'top',
              labels: {
                font: { size: 11, family: 'Poppins', weight: '500' },
                color: '#aaa',
                padding: 16,
                usePointStyle: true
              }
            },
            tooltip: {
              backgroundColor: '#1A1A1A',
              titleFont: { size: 11, family: 'Poppins', weight: '600' },
              bodyFont: { size: 12, family: 'Poppins' },
              padding: 12,
              borderRadius: 2,
              displayColors: false,
              callbacks: {
                label: function(context) {
                  return '₹' + context.parsed.y.toLocaleString('en-IN', { maximumFractionDigits: 0 });
                }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: { color: '#F0EBE3', drawBorder: false },
              ticks: {
                font: { size: 11, family: 'Poppins' },
                color: '#bbb',
                callback: function(value) {
                  return '₹' + value.toLocaleString('en-IN', { maximumFractionDigits: 0 });
                }
              }
            },
            x: {
              grid: { display: false },
              ticks: { font: { size: 11, family: 'Poppins' }, color: '#bbb' }
            }
          }
        }
      });
    }

    function changeFilter(filterType) {
      window.location.href = '/admin/dashboard?filter=' + filterType;
    }

    window.addEventListener('load', function() {
      initRevenueTrendChart();
    });
  </script>

  <%- include('../partials/admin/footer') %>
