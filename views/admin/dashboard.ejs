<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/admin.css" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/admin/header') %>
  <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
  <div class="container mt-5">
    <h1 class="mb-4">Welcome to the Admin Dashboard</h1>
    <div class="row g-4">
      <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
          <div class="card-body">
            <h5 class="card-title">Total Customers</h5>
            <p class="card-text display-6"><%= typeof totalCustomers !== 'undefined' ? totalCustomers : '...' %></p>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
          <div class="card-body">
            <h5 class="card-title">Total Orders</h5>
            <p class="card-text display-6"><%= typeof totalOrders !== 'undefined' ? totalOrders : '...' %></p>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
          <div class="card-body">
            <h5 class="card-title">Total Products</h5>
            <p class="card-text display-6"><%= typeof totalProducts !== 'undefined' ? totalProducts : '...' %></p>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
          <div class="card-body">
            <h5 class="card-title">Total Sales</h5>
            <p class="card-text display-6"><%= typeof totalSales !== 'undefined' ? totalSales : '...' %></p>
          </div>
        </div>
      </div>
    </div>
    <div class="row mt-5">
      <div class="col-12">
        <div class="card">
          <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">Recent Orders</h5>
          </div>
          <div class="card-body">
            <% if (recentOrders && recentOrders.length > 0) { %>
              <table class="table table-striped">
                <thead>
                  <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Total</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentOrders.forEach(function(order) { %>
                    <tr>
                      <td><%= order._id %></td>
                      <td><%= order.customerName %></td>
                      <td><%= order.date %></td>
                      <td><%= order.status %></td>
                      <td>₹<%= order.total %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } else { %>
              <p>No recent orders found.</p>
            <% } %>
            <div class="row mt-5">
  <div class="col-md-12">
    <div class="card">
      <div class="card-header bg-secondary text-white d-flex justify-content-between">
        <h5 class="mb-0">Sales Overview</h5>
        <select id="salesFilter" class="form-select w-auto">
          <option value="yearly">Yearly</option>
          <option value="monthly">Monthly</option>
        </select>
      </div>
      <div class="card-body">
        <canvas id="salesChart" height="100"></canvas>
      </div>
    </div>
  </div>
</div>

<div class="row mt-5">
  <div class="col-md-6">
  <div class="card">
    <div class="card-header bg-info text-white">Top 10 Best-Selling Products</div>
    <div class="card-body">
      <canvas id="productChart"></canvas>
    </div>
  </div>
</div>
<div class="col-md-6">
  <div class="card">
    <div class="card-header bg-warning text-white">Best-Selling Categories</div>
    <div class="card-body">
      <canvas id="categoryChart"></canvas>
    </div>
  </div>
</div>

</div>

<script>
  const ctx = document.getElementById('salesChart').getContext('2d');
  let salesChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: <%- JSON.stringify(chartData.labels) %>,
      datasets: [{
        label: 'Sales',
        data: <%- JSON.stringify(chartData.data) %>,
        backgroundColor: 'rgba(54, 162, 235, 0.7)'
      }]
    }
  });

  document.getElementById('salesFilter').addEventListener('change', function() {
    window.location.href = '/admin/dashboard?filter=' + this.value;
  });
</script>

          </div>
        </div>
      </div>
    </div>
  </div>
  </main>
</body>
</html>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Product Chart (Bar)
  new Chart(document.getElementById('productChart'), {
    type: 'bar',
    data: {
      labels: <%- JSON.stringify(bestProducts.map(p => p.productName)) %>,
      datasets: [{
        label: 'Units Sold',
        data: <%- JSON.stringify(bestProducts.map(p => p.totalSold)) %>,
        backgroundColor: 'rgba(75, 192, 192, 0.7)'
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true } }
    }
  });

  // Category Chart (Pie)
  new Chart(document.getElementById('categoryChart'), {
    type: 'pie',
    data: {
      labels: <%- JSON.stringify(bestCategories.map(c => c.categoryName)) %>,
      datasets: [{
        label: 'Units Sold',
        data: <%- JSON.stringify(bestCategories.map(c => c.totalSold)) %>,
        backgroundColor: [
          'rgba(255, 99, 132, 0.7)',
          'rgba(54, 162, 235, 0.7)',
          'rgba(255, 206, 86, 0.7)',
          'rgba(75, 192, 192, 0.7)',
          'rgba(153, 102, 255, 0.7)'
        ]
      }]
    },
    options: { responsive: true }
  });
</script>
