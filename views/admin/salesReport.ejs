<%- include('../partials/admin/header') %>

<style>
  /* Modern minimal styling */
  .sales-report-container {
    background: #f8fafc;
    min-height: 100vh;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  .report-header {
    padding: 2rem 0;
    margin-bottom: 2rem;
  }

  .report-title {
    font-family: 'Playfair Display', 'Georgia', serif;
    font-size: 2.8rem;
    font-weight: 400;
    margin: 0;
    text-align: center;
    letter-spacing: -0.5px;
    color: #1f2937;
    position: relative;
  }

  .report-title:after {
    content: '';
    display: block;
    width: 80px;
    height: 3px;
    background: linear-gradient(135deg, #a81414 0%, #510505 100%);
    margin: 1rem auto 0;
    border-radius: 2px;
  }

  .filters-section {
    background: white;
    padding: 2rem;
    border-radius: 16px;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
    margin-bottom: 2rem;
    border: 1px solid #e2e8f0;
  }

  .filter-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 0.5rem;
    display: block;
  }

  .form-control {
    border: 2px solid #e2e8f0;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    transition: all 0.3s ease;
    background: #fafbfc;
  }

  .form-control:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    background: white;
    outline: none;
  }

  .btn-group {
    gap: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    align-items: center;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    font-weight: 500;
    font-size: 0.875rem;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-primary {
    background: linear-gradient(135deg, #3b0505 0%, rgb(120, 22, 22) 100%);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(84, 5, 5, 0.341);
  }

  .btn-secondary {
    background: #6b7280;
    color: white;
  }

  .btn-secondary:hover {
    background: #4b5563;
    transform: translateY(-2px);
  }

  .btn-danger {
    background: #510505;
    color: white;
  }

  .btn-danger:hover {
    background: #870505;
    transform: translateY(-2px);
  }

  .btn-success {
    background: #0d5b1a;
    color: white;
  }

  .btn-success:hover {
    background: #07840c;
    transform: translateY(-2px);
  }

  .stats-grid {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .stat-card {
    background: white;
    padding: 1.5rem 1rem;
    border-radius: 12px;
    text-align: center;
    border: 1px solid #e2e8f0;
    box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
    flex: 1;
    min-width: 160px;
  }

  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
  }

  .stat-title {
    font-size: 0.8125rem;
    color: #6b7280;
    font-weight: 500;
    margin-bottom: 0.375rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0;
  }

  .stat-card:nth-child(1) .stat-value { color: #602929; }
  .stat-card:nth-child(2) .stat-value { color: #169818; }
  .stat-card:nth-child(3) .stat-value { color: #c7881c; }
  .stat-card:nth-child(4) .stat-value { color: #a12424; }

  .table-container {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
    border: 1px solid #e2e8f0;
  }

  .table {
    margin: 0;
    font-size: 0.875rem;
  }

  .table thead th {
    background: #31282848;
    border: none;
    font-weight: 600;
    color: #374151;
    padding: 1.25rem 1rem;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .table tbody td {
    padding: 1rem;
    border-top: 1px solid #f1f5f9;
    vertical-align: middle;
  }

  .table tbody tr:hover {
    background: #f8fafc;
  }

  .order-id {
    font-family: 'Courier New', monospace;
    font-size: 0.8125rem;
    background: #f1f5f9;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    color: #374151;
  }

  .item-list p {
    margin: 0.25rem 0;
    padding: 0.25rem 0.5rem;
    background: #f8fafc;
    border-radius: 6px;
    font-size: 0.8125rem;
    color: #4b5563;
  }

  .status-badge {
    padding: 0.375rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .status-delivered { background: #dcfce7; color: #166534; }
  .status-cancelled { background: #fee2e2; color: #991b1b; }
  .status-returned { background: #fef3c7; color: #92400e; }
  .status-processing { background: #dbeafe; color: #1e40af; }

  .amount {
    font-weight: 600;
    color: #059669;
    font-size: 0.9375rem;
  }

  .no-orders {
    text-align: center;
    padding: 3rem;
    color: #6b7280;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .report-title {
      font-size: 2.2rem;
    }
    
    .filters-section {
      padding: 1.5rem;
    }
    
    .btn-group {
      justify-content: center;
    }
    
    .stats-grid {
      flex-direction: column;
      gap: 1rem;
    }
    
    .stat-card {
      padding: 1.25rem;
      min-width: auto;
    }
    
    .table-container {
      overflow-x: auto;
    }
  }
</style>

<main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 sales-report-container">
  <div class="report-header">
    <div class="container">
      <h1 class="report-title">Sales Report</h1>
    </div>
  </div>

  <div class="container mt-4">
    <div class="filters-section">
      <form method="GET" action="/admin/sales-report" class="row g-3">
        <div class="col-md-3">
          <label class="filter-label">Start Date</label>
          <input type="date" class="form-control" name="startDate" value="<%= filters.startDate || '' %>">
        </div>
        <div class="col-md-3">
          <label class="filter-label">End Date</label>
          <input type="date" class="form-control" name="endDate" value="<%= filters.endDate || '' %>">
        </div>
        <div class="col-md-3">
          <label class="filter-label">Payment Method</label>
          <select class="form-control" name="paymentMethod">
            <option value="all">All Methods</option>
            <option value="COD" <%= filters.paymentMethod === 'COD' ? 'selected' : '' %>>Cash on Delivery</option>
            <option value="Online" <%= filters.paymentMethod === 'Online' ? 'selected' : '' %>>Online Payment</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="filter-label">Order Status</label>
          <select class="form-control" name="orderStatus">
            <option value="all">All Status</option>
            <option value="Delivered" <%= filters.orderStatus === 'Delivered' ? 'selected' : '' %>>Delivered</option>
            <option value="Cancelled" <%= filters.orderStatus === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
            <option value="Returned" <%= filters.orderStatus === 'Returned' ? 'selected' : '' %>>Returned</option>
          </select>
        </div>
        <div class="col-12 mt-4">
          <div class="btn-group">
            <button type="submit" class="btn btn-primary">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
              </svg>
              Apply Filters
            </button>
            <a href="/admin/sales-report" class="btn btn-secondary">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/>
                <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/>
              </svg>
              Reset
            </a>
            <a href="/admin/sales-report/pdf" class="btn btn-danger">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2zM9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5v2z"/>
              </svg>
              PDF Report
            </a>
            <a href="/admin/sales-report/excel" class="btn btn-success">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M5.884 6.68a.5.5 0 1 0-.768.64L7.349 10l-2.233 2.68a.5.5 0 0 0 .768.64L8 10.781l2.116 2.54a.5.5 0 0 0 .768-.641L8.651 10l2.233-2.68a.5.5 0 0 0-.768-.64L8 9.219l-2.116-2.54z"/>
                <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2zM9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5v2z"/>
              </svg>
              Excel Report
            </a>
          </div>
        </div>
      </form>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-title">Total Sales</div>
        <h2 class="stat-value">₹<%= totalSales.toFixed(2) %></h2>
      </div>
      <div class="stat-card">
        <div class="stat-title">Total Orders</div>
        <h2 class="stat-value"><%= totalOrders %></h2>
      </div>
      <div class="stat-card">
        <div class="stat-title">Average Order</div>
        <h2 class="stat-value">₹<%= avgOrder.toFixed(2) %></h2>
      </div>
      <div class="stat-card">
        <div class="stat-title">Return Rate</div>
        <h2 class="stat-value"><%= returnRate.toFixed(1) %>%</h2>
      </div>
    </div>

    <!-- Orders Table -->
    <div class="table-container">
      <table class="table">
        <thead>
          <tr>
            <th>Order ID</th>
            <th>Customer</th>
            <th>Date</th>
            <th>Items</th>
            <th>Payment</th>
            <th>Status</th>
            <th>Amount</th>
          </tr>
        </thead>
        <tbody>
          <% if (orders.length === 0) { %>
            <tr>
              <td colspan="7" class="no-orders">
                <div>
                  <svg width="48" height="48" fill="currentColor" viewBox="0 0 16 16" style="opacity: 0.3; margin-bottom: 1rem;">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                    <path d="M8 4a.905.905 0 0 0-.9.995l.35 3.507a.552.552 0 0 0 1.1 0l.35-3.507A.905.905 0 0 0 8 4zm.002 6a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
                  </svg>
                  <br>
                  No orders found matching your criteria
                </div>
              </td>
            </tr>
          <% } %>
          <% orders.forEach(o => { %>
            <tr>
              <td><span class="order-id">#<%= o._id.toString().slice(-8) %></span></td>
              <td><%= o.userId ? o.userId.name : 'N/A' %></td>
              <td><%= o.createdAt.toDateString() %></td>
              <td class="item-list">
                <% if (o.orderItems && o.orderItems.length > 0) { %>
                  <% o.orderItems.forEach(i => { %>
                    <p><%= i.productId.name %> × <%= i.quantity %></p>
                  <% }) %>
                <% } else { %>
                  <p style="color: #9ca3af;">No items</p>
                <% } %>
              </td>
              <td><%= o.paymentMethod %></td>
              <td>
                <span class="status-badge status-<%= o.status.toLowerCase() %>">
                  <%= o.status %>
                </span>
              </td>
              <td class="amount">₹<%= o.totalPrice.toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('../partials/admin/footer') %>