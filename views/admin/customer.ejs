<%- include('../partials/admin/header') %>

<main class="ga-main">

  <style>
    .ga-page-head {
      padding: 32px 32px 0;
      margin-bottom: 28px;
    }
    .ga-page-head__eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #D4A96A;
      margin-bottom: 6px;
    }
    .ga-page-head__title {
      font-family: 'Cormorant Garant', serif;
      font-size: 36px;
      font-weight: 600;
      color: #1A1A1A;
      letter-spacing: -0.5px;
      line-height: 1;
    }
    .ga-section {
      padding: 0 32px 40px;
    }
    .ga-toolbar {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .ga-search-wrap {
      position: relative;
      flex: 1;
      max-width: 420px;
    }
    .ga-search-wrap input {
      width: 100%;
      padding: 10px 40px 10px 14px;
      border: 1.5px solid #E8E2DA;
      border-radius: 2px;
      font-family: 'Poppins', sans-serif;
      font-size: 12px;
      color: #1A1A1A;
      background: #fff;
      outline: none;
      transition: border-color 0.2s ease;
    }
    .ga-search-wrap input:focus { border-color: #8B1A1A; }
    .ga-search-wrap input::placeholder { color: #bbb; }
    .ga-search-wrap i {
      position: absolute;
      right: 13px;
      top: 50%;
      transform: translateY(-50%);
      color: #ccc;
      font-size: 13px;
      pointer-events: none;
    }
    .ga-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 18px;
      font-family: 'Poppins', sans-serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s ease;
      border-radius: 2px;
    }
    .ga-btn--dark {
      background: #1A1A1A;
      color: #fff;
    }
    .ga-btn--dark:hover { background: #8B1A1A; color: #fff; }
    .ga-btn--ghost {
      background: transparent;
      border: 1.5px solid #E8E2DA;
      color: #888;
    }
    .ga-btn--ghost:hover { border-color: #8B1A1A; color: #8B1A1A; }
    .ga-results-note {
      font-size: 11px;
      color: #bbb;
      letter-spacing: 0.3px;
      margin-bottom: 14px;
    }
    .ga-results-note strong { color: #1A1A1A; font-weight: 600; }
    .ga-card {
      background: #fff;
      border-radius: 3px;
      overflow: hidden;
    }
    .ga-table-wrap {
      overflow-x: auto;
    }
    .ga-table {
      width: 100%;
      border-collapse: collapse;
    }
    .ga-table thead {
      background: #1A1A1A;
    }
    .ga-table thead th {
      padding: 13px 16px;
      text-align: left;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55);
      white-space: nowrap;
    }
    .ga-table thead th:first-child { color: var(--glora-gold, #D4A96A); }
    .ga-table tbody td {
      padding: 14px 16px;
      font-size: 13px;
      color: #1A1A1A;
      border-bottom: 1px solid #F4F1EC;
      vertical-align: middle;
    }
    .ga-table tbody tr:last-child td { border-bottom: none; }
    .ga-table tbody tr:hover td { background: #FAF7F4; }
    .ga-table .ga-row-num {
      font-size: 11px;
      color: #ccc;
      font-family: monospace;
    }
    .ga-table .ga-customer-name {
      font-weight: 500;
    }
    .ga-table .ga-customer-email {
      color: #888;
      font-size: 12px;
    }
    .ga-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 2px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .ga-badge--active   { background: #F0FDF4; color: #166534; }
    .ga-badge--blocked  { background: #FEF2F2; color: #991b1b; }
    .ga-action-btn {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 6px 14px;
      font-family: 'Poppins', sans-serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      border: 1.5px solid;
      border-radius: 2px;
      cursor: pointer;
      background: transparent;
      transition: all 0.2s ease;
    }
    .ga-action-btn--block   { border-color: #fca5a5; color: #991b1b; }
    .ga-action-btn--block:hover   { background: #991b1b; color: #fff; border-color: #991b1b; }
    .ga-action-btn--unblock { border-color: #86efac; color: #166534; }
    .ga-action-btn--unblock:hover { background: #166534; color: #fff; border-color: #166534; }
    .ga-empty {
      text-align: center;
      padding: 64px 20px;
      color: #bbb;
    }
    .ga-empty i { font-size: 2.5rem; display: block; margin-bottom: 14px; color: #E8E2DA; }
    .ga-empty p { font-size: 13px; }
    .ga-pagination {
      display: flex;
      justify-content: center;
      gap: 6px;
      margin-top: 28px;
      list-style: none;
      padding: 0;
    }
    .ga-pagination li a,
    .ga-pagination li span {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: 1.5px solid #E8E2DA;
      font-size: 12px;
      font-weight: 500;
      color: #555;
      text-decoration: none;
      border-radius: 2px;
      transition: all 0.2s ease;
    }
    .ga-pagination li a:hover { border-color: #8B1A1A; color: #8B1A1A; }
    .ga-pagination li.active a { background: #1A1A1A; border-color: #1A1A1A; color: #fff; }
    .ga-pagination li.disabled span { color: #ddd; cursor: not-allowed; }
    @media (max-width: 640px) {
      .ga-page-head { padding: 24px 16px 0; }
      .ga-section { padding: 0 16px 32px; }
      .ga-toolbar { flex-direction: column; align-items: stretch; }
      .ga-search-wrap { max-width: 100%; }
    }
  </style>

  <div class="ga-page-head">
    <p class="ga-page-head__eyebrow">Manage</p>
    <h1 class="ga-page-head__title">Customers</h1>
  </div>

  <div class="ga-section">

    <form method="GET" action="/admin/customer" class="ga-toolbar">
      <div class="ga-search-wrap">
        <input type="text" name="search" placeholder="Search by name or email…" value="<%= search %>">
        <i class="bi bi-search"></i>
      </div>
      <button type="submit" class="ga-btn ga-btn--dark">
        <i class="bi bi-search"></i> Search
      </button>
      <a href="/admin/customer" class="ga-btn ga-btn--ghost">
        <i class="bi bi-x"></i> Reset
      </a>
    </form>

    <p class="ga-results-note">
      Showing <strong><%= customers.length %></strong> of <strong><%= totalCustomers %></strong> customer<%= totalCustomers !== 1 ? 's' : '' %><% if (search) { %> for "<strong><%= search %></strong>"<% } %>
    </p>

    <div class="ga-card">
      <div class="ga-table-wrap">
        <table class="ga-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Joined</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (customers.length === 0) { %>
              <tr>
                <td colspan="7">
                  <div class="ga-empty">
                    <i class="bi bi-person-x"></i>
                    <p>No customers found<% if (search) { %> matching "<%= search %>"<% } %>.</p>
                  </div>
                </td>
              </tr>
            <% } else { %>
              <% customers.forEach((customer, index) => { %>
                <tr>
                  <td class="ga-row-num"><%= (currentPage - 1) * 10 + index + 1 %></td>
                  <td class="ga-customer-name"><%= customer.name %></td>
                  <td class="ga-customer-email"><%= customer.email %></td>
                  <td style="color:#888; font-size:12px;"><%= customer.phoneNumber || '—' %></td>
                  <td style="font-size:12px; color:#888;">
                    <%
                      let joinedDate = '—';
                      try {
                        if (customer.createdAt) {
                          joinedDate = new Date(customer.createdAt).toLocaleDateString('en-IN', {
                            year: 'numeric', month: '2-digit', day: '2-digit'
                          });
                        }
                      } catch(e) {}
                    %>
                    <%= joinedDate %>
                  </td>
                  <td>
                    <span class="ga-badge <%= !customer.isBlocked ? 'ga-badge--active' : 'ga-badge--blocked' %>">
                      <%= !customer.isBlocked ? 'Active' : 'Blocked' %>
                    </span>
                  </td>
                  <td>
                    <button
                      onclick="handleCustomerAction(this, '<%= customer._id %>', <%= !customer.isBlocked ? 'true' : 'false' %>)"
                      class="ga-action-btn <%= !customer.isBlocked ? 'ga-action-btn--block' : 'ga-action-btn--unblock' %>">
                      <i class="bi bi-<%= !customer.isBlocked ? 'slash-circle' : 'check-circle' %>"></i>
                      <%= !customer.isBlocked ? 'Block' : 'Unblock' %>
                    </button>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <% if (totalPages > 1) { %>
      <nav>
        <ul class="ga-pagination">
          <li class="<%= currentPage === 1 ? 'disabled' : '' %>">
            <% if (currentPage === 1) { %>
              <span><i class="bi bi-chevron-left"></i></span>
            <% } else { %>
              <a href="?page=<%= currentPage - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"><i class="bi bi-chevron-left"></i></a>
            <% } %>
          </li>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="<%= i === currentPage ? 'active' : '' %>">
              <a href="?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"><%= i %></a>
            </li>
          <% } %>
          <li class="<%= currentPage === totalPages ? 'disabled' : '' %>">
            <% if (currentPage === totalPages) { %>
              <span><i class="bi bi-chevron-right"></i></span>
            <% } else { %>
              <a href="?page=<%= currentPage + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"><i class="bi bi-chevron-right"></i></a>
            <% } %>
          </li>
        </ul>
      </nav>
    <% } %>

  </div>
</main>

<%- include('../partials/admin/footer') %>

<script>
  async function handleCustomerAction(button, customerId, isActive) {
    const action = isActive === 'true' ? 'block' : 'unblock';
    const buttonText = button.innerHTML;

    try {
      button.disabled = true;
      button.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

      const result = await Swal.fire({
        title: action === 'block' ? 'Block this user?' : 'Unblock this user?',
        text: action === 'block' ? 'They will not be able to log in.' : 'They will be able to log in again.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: action === 'block' ? 'Yes, Block' : 'Yes, Unblock',
        confirmButtonColor: action === 'block' ? '#991b1b' : '#166534',
        cancelButtonText: 'Cancel',
        reverseButtons: true,
        showLoaderOnConfirm: true,
        preConfirm: async () => {
          try {
            const response = await fetch(`/admin/user/${action}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
              body: JSON.stringify({ id: customerId }),
              credentials: 'same-origin'
            });
            const data = await response.json();
            if (!response.ok) throw new Error(data.message || `Failed to ${action}`);
            return data;
          } catch (err) {
            Swal.showValidationMessage(`Request failed: ${err.message}`);
            return false;
          }
        },
        allowOutsideClick: () => !Swal.isLoading()
      });

      if (result.isConfirmed) {
        const badge = button.closest('tr').querySelector('.ga-badge');
        if (action === 'block') {
          badge.className = 'ga-badge ga-badge--blocked';
          badge.textContent = 'Blocked';
          button.className = 'ga-action-btn ga-action-btn--unblock';
          button.setAttribute('onclick', `handleCustomerAction(this, '${customerId}', false)`);
          button.innerHTML = '<i class="bi bi-check-circle"></i> Unblock';
        } else {
          badge.className = 'ga-badge ga-badge--active';
          badge.textContent = 'Active';
          button.className = 'ga-action-btn ga-action-btn--block';
          button.setAttribute('onclick', `handleCustomerAction(this, '${customerId}', true)`);
          button.innerHTML = '<i class="bi bi-slash-circle"></i> Block';
        }
        await Swal.fire({ icon: 'success', title: 'Done!', text: `User ${action === 'block' ? 'blocked' : 'unblocked'} successfully.`, timer: 1500, showConfirmButton: false });
      }
    } catch (err) {
      await Swal.fire({ icon: 'error', title: 'Error!', text: err.message || 'Something went wrong.' });
    } finally {
      if (button) { button.disabled = false; button.innerHTML = buttonText; }
    }
  }

  async function exportCustomerData() {
    try {
      const response = await fetch('/admin/customers/export', {
        method: 'GET',
        headers: { 'Accept': 'application/csv', 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin'
      });
      if (!response.ok) throw new Error(await response.text() || 'Export failed');
      const contentDisposition = response.headers.get('content-disposition');
      const filenameMatch = contentDisposition?.match(/filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/);
      const filename = filenameMatch ? filenameMatch[1].replace(/['"]/g, '') : 'customers.csv';
      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = filename;
      document.body.appendChild(a); a.click();
      window.URL.revokeObjectURL(url); document.body.removeChild(a);
      await Swal.fire({ icon: 'success', title: 'Exported!', timer: 1500, showConfirmButton: false });
    } catch (err) {
      Swal.fire({ icon: 'error', title: 'Export Failed', text: err.message });
    }
  }
</script>
