<%- include('../partials/admin/header') %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Offer Management</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
  .custom-red {
    background-color: #420404; /* Dark Red */
    color: #fff;
    border: none;
  }
  .custom-red:hover {
    background-color: #601212; 
    color: #fff;
  }
</style>

</head>
<body>
  <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4">
  <div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>Offer Management</h2>
      <a href="/admin/offers/add" class="btn custom-red">+ Add New Offer</a>

    </div>

    <table class="table table-bordered table-hover">
      <thead class="table-dark">
        <tr>
          <th>Title</th>
          <th>Description</th>
          <th>Discount</th>
          <th>Valid Till</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (offers && offers.length > 0) { %>
          <% offers.forEach(offer => { %>
            <tr>
              <td><%= offer.title %></td>
              <td><%= offer.description %></td>
              <td>
                <%= offer.discountType === 'Percentage' ? offer.discountValue + '%' : '₹' + offer.discountValue %>
              </td>
              <td>
  <% if (offer.endDate) { %>
    <%= new Date(offer.endDate).toDateString() %>
  <% } else { %>
    No Expiry
  <% } %>
</td>


              <td>
                <% if (offer.isActive) { %>
                  <span class="badge bg-success">Active</span>
                <% } else { %>
                  <span class="badge bg-secondary">Inactive</span>
                <% } %>
              </td>
              <td>
                <a href="/admin/offers/edit/<%= offer._id %>" class="btn btn-sm btn-warning">Edit</a>
                <button class="btn btn-sm btn-danger" onclick="deleteOffer('<%= offer._id %>')">Delete</button>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" class="text-center">No offers found</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <script>
    function deleteOffer(offerId) {
      Swal.fire({
        title: "Are you sure?",
        text: "This action cannot be undone.",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#d33",
        cancelButtonColor: "#3085d6",
        confirmButtonText: "Yes, delete it!"
      }).then((result) => {
        if (result.isConfirmed) {
          fetch(`/admin/offers/delete/${offerId}`, {
            method: "POST"
          }).then(res => {
            if (res.ok) {
              Swal.fire("Deleted!", "Offer has been deleted.", "success")
                .then(() => location.reload());
            }
          })
        }
      });
    }
  </script>
  </main>
</body>
<%- include('../partials/admin/footer') %>
</html>