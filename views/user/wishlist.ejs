<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wishlist</title>
    <link rel="stylesheet" href="/styles/bootstrap4/bootstrap.min.css">
    <link rel="stylesheet" href="/styles/main_styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #fafafa;
        }

        .header {
            height: 60px;
        }

        .container {
            margin-top: 80px;
        }

        /* Wishlist Page Styles */
        .wishlist-page {
            min-height: calc(100vh - 200px);
            padding-top: 40px;
            padding-bottom: 40px;
        }

        .wishlist-page h2 {
            color: #4a1f18;
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .wishlist-count {
            color: #888;
            font-weight: 500;
            margin-bottom: 30px;
        }

        /* Table and Row Styling */
        .wishlist-table {
            background-color: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            width: 100%;
        }

        .wishlist-table thead {
            background-color: #f8f9fa;
            color: #6c757d;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 1px;
        }

        .wishlist-table th, .wishlist-table td {
            padding: 15px;
            /* Vertical Alignment */
            vertical-align: middle;
            border-bottom: 1px solid #e9ecef;
        }
        
        /* Hover Effect on each row */
        .wishlist-table tbody tr {
            transition: all 0.2s ease;
        }
        .wishlist-table tbody tr:hover {
            background-color: #fcfcfc;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .wishlist-table tbody tr:last-child td {
            border-bottom: none;
        }

        /* Product Image and Info Cell */
        .product-cell {
            display: flex;
            align-items: center;
        }

        .product-image-box {
            width: 80px;
            height: 80px;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #eee;
            margin-right: 15px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .product-image-box img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .product-info {
            flex-grow: 1;
        }

        .product-title {
            font-size: 1rem;
            font-weight: 600;
            color: #333;
            margin: 0;
            line-height: 1.2;
        }

        .product-category {
            font-size: 0.8rem;
            color: #999;
            margin-top: 2px;
        }

        /* Price and Status */
        .product-price {
          margin-top: 16px;
            font-size: 1rem;
            font-weight: 700;
            color: #4a1f18;
        }
        
        .badge-stock {
            background-color: #28a745;
            color: #fff;
            font-size: 0.8rem;
            padding: 5px 10px;
            border-radius: 50px;
            font-weight: 500;
            margin-top: 18px;
        }

        /* Action Buttons */
        .action-buttons .btn {
            font-size: 0.85rem;
            padding: 8px 12px;
            font-weight: 500;
            border-radius: 6px;
        }
        
        .btn-add-to-cart {
            background: #4a1f18;
            color: #fff;
            border: none;
            margin-top: 9px;
            margin-right: 20px;
        }

        .btn-add-to-cart:hover {
            background: #6a3429;
            color: #fff;
        }

        .btn-remove-wishlist {
            color: #dc3545;
            border: 1px solid #dc3545;
            background: transparent;
             margin-top: 7px;
        }

        .btn-remove-wishlist:hover {
            background-color: #dc3545;
            color: #fff;
        }

        /* Empty Wishlist */
        .empty-wishlist {
            text-align: center;
            padding: 80px 20px;
        }

        .empty-wishlist i {
            font-size: 5rem;
            color: #ccc;
            margin-bottom: 20px;
        }
        
        .empty-wishlist h3 {
            color: #7f8c8d;
            font-weight: 600;
        }

        .btn-shop {
            background: #4a1f18;
            color: #fff;
            padding: 10px 25px;
            border-radius: 6px;
            text-decoration: none;
            transition: background 0.3s;
            font-weight: 500;
        }

        .btn-shop:hover {
            background: #6a3429;
            color: #fff;
        }
    </style>
</head>
<body>

<%- include('../partials/user/header', {
    userName: userName,
    url: url
}) %>

<div class="wishlist-page">
    <div class="container">
        <h2>My Wishlist</h2>
        <div class="wishlist-count"><%= wishlist ? wishlist.length : 0 %> items</div>

        <% if (wishlist && wishlist.length > 0) { %>
            <div class="table-responsive">
                <table class="table wishlist-table">
                    <thead>
                        <tr>
                            <th style="width: 50%;">Product</th>
                            <th style="width: 15%;">Price</th>
                            <th style="width: 15%;">Status</th>
                            <th style="width: 20%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% wishlist.forEach(product => { %>
                            <tr>
                                <td>
                                    <div class="product-cell">
                                        <div class="product-image-box">
                                            <img src="<%= product.images && product.images.length > 0 ? '/uploads/products/' + product.images[0] : '/images/placeholder-product.jpg' %>"
                                                 alt="<%= product.productName %>"
                                                 class="img-fluid">
                                        </div>
                                        <div class="product-info">
                                            <div class="product-title"><%= product.productName %></div>
                                            <div class="product-category"><%= product.category || 'No category' %></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="product-price">
                                        Rs <%= product.salesPrice > 0 ? product.salesPrice : product.regularPrice %>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-stock">In Stock</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <button class="btn btn-add-to-cart me-2" data-product-id="<%= product._id %>">
                                            <i class="fas fa-shopping-cart me-1"></i> Add
                                        </button>
                                        <a href="/wishlist/remove/<%= product._id %>" class="btn btn-remove-wishlist" title="Remove">
                                            <i class="far fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-wishlist">
                <i class="far fa-heart"></i>
                <h3>Your wishlist is empty</h3>
                <p>You haven't added any products to your wishlist yet. Let's find something you'll love!</p>
                <a href="/shop" class="btn btn-shop">Continue Shopping</a>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/user/footer') %>
