<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Wishlist — GLORA</title>
  <link rel="stylesheet" href="/styles/bootstrap4/bootstrap.min.css">
  <link rel="stylesheet" href="/styles/main_styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,400;0,600;1,400;1,600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Poppins', sans-serif;
      background: #FAF7F4;
      color: #1A1A1A;
    }

    /* ── PAGE BANNER ─────────────────────────────────── */
    .wishlist-banner {
      background: #1A1A1A;
      padding: 30px 0 25px;
      text-align: center;
      margin-top: 65px;
    }

    .wishlist-banner__eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #D4A96A;
      margin-bottom: 10px;
    }

    .wishlist-banner__title {
      font-family: 'Cormorant Garant', serif;
      font-size: clamp(36px, 5vw, 56px);
      font-weight: 600;
      color: #FAF7F4;
      letter-spacing: -0.5px;
      line-height: 1.1;
    }

    .wishlist-banner__title em {
      font-style: italic;
      font-weight: 400;
    }

    /* ── MAIN WRAPPER ─────────────────────────────────── */
    .wishlist-page {
      min-height: calc(100vh - 200px);
      padding: 48px 0 80px;
    }

    .wishlist-page .container {
      max-width: 1100px;
      margin-top: 0;
    }

    .wishlist-meta {
      display: flex;
      align-items: baseline;
      gap: 14px;
      margin-bottom: 32px;
    }

    .wishlist-meta h2 {
      font-family: 'Cormorant Garant', serif;
      font-size: clamp(28px, 4vw, 38px);
      font-weight: 600;
      color: #1A1A1A;
      letter-spacing: -0.3px;
    }

    .wishlist-count {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #D4A96A;
    }

    /* ── TABLE ───────────────────────────────────────── */
    .wishlist-table {
      background: #fff;
      width: 100%;
      border-collapse: collapse;
      border-radius: 2px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    }

    .wishlist-table thead {
      background: #1A1A1A;
    }

    .wishlist-table thead th {
      padding: 14px 20px;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #D4A96A;
      border: none;
    }

    .wishlist-table tbody td {
      padding: 20px;
      border-bottom: 1px solid #F0EBE3;
      vertical-align: middle;
    }

    .wishlist-table tbody tr:last-child td {
      border-bottom: none;
    }

    .wishlist-table tbody tr {
      transition: background 0.2s ease;
    }

    .wishlist-table tbody tr:hover {
      background: #FAF7F4;
    }

    /* ── PRODUCT CELL ────────────────────────────────── */
    .product-cell {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .product-image-box {
      width: 82px;
      height: 82px;
      border-radius: 2px;
      overflow: hidden;
      background: #F0EBE3;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .product-image-box img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .wishlist-table tbody tr:hover .product-image-box img {
      transform: scale(1.05);
    }

    .product-title {
      font-size: 13px;
      font-weight: 600;
      color: #1A1A1A;
      margin-bottom: 4px;
      line-height: 1.3;
    }

    .product-category {
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #aaa;
    }

    /* ── PRICE ───────────────────────────────────────── */
    .product-price {
      font-size: 14px;
      font-weight: 600;
      color: #8B1A1A;
    }

    .original-price {
      font-size: 11px;
      font-weight: 400;
      color: #bbb;
      text-decoration: line-through;
      margin-left: 5px;
    }

    /* ── STOCK BADGE ─────────────────────────────────── */
    .badge-stock {
      display: inline-block;
      background: transparent;
      border: 1px solid #2e7d32;
      color: #2e7d32;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 5px 12px;
      border-radius: 0;
    }

    /* ── ACTION BUTTONS ──────────────────────────────── */
    .btn-add-to-cart {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 18px;
      background: #1A1A1A;
      color: #fff;
      border: none;
      font-family: 'Poppins', sans-serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s ease;
      border-radius: 0;
    }

    .btn-add-to-cart:hover {
      background: #8B1A1A;
      color: #fff;
    }

    .btn-remove-wishlist {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      background: transparent;
      border: 1.5px solid #E0D8D0;
      color: #bbb;
      cursor: pointer;
      transition: all 0.2s ease;
      border-radius: 0;
      font-size: 13px;
    }

    .btn-remove-wishlist:hover {
      border-color: #8B1A1A;
      color: #8B1A1A;
      background: #fff5f5;
    }

    /* ── EMPTY STATE ─────────────────────────────────── */
    .empty-wishlist {
      text-align: center;
      padding: 100px 20px;
    }

    .empty-wishlist i {
      font-size: 3.5rem;
      color: #D4A96A;
      margin-bottom: 24px;
      display: block;
    }

    .empty-wishlist h3 {
      font-family: 'Cormorant Garant', serif;
      font-size: 32px;
      font-weight: 600;
      color: #1A1A1A;
      margin-bottom: 10px;
    }

    .empty-wishlist p {
      font-size: 13px;
      color: #999;
      margin-bottom: 28px;
      max-width: 360px;
      margin-left: auto;
      margin-right: auto;
    }

    .btn-shop {
      display: inline-block;
      padding: 13px 36px;
      background: #1A1A1A;
      color: #fff;
      font-family: 'Poppins', sans-serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      text-decoration: none;
      transition: background 0.2s ease;
      border-radius: 0;
    }

    .btn-shop:hover {
      background: #8B1A1A;
      color: #fff;
      text-decoration: none;
    }

    /* ── RESPONSIVE ──────────────────────────────────── */
    @media (max-width: 768px) {
      .wishlist-table thead { display: none; }

      .wishlist-table tbody td {
        display: block;
        padding: 12px 16px;
        border-bottom: none;
      }

      .wishlist-table tbody tr {
        display: block;
        border-bottom: 1px solid #F0EBE3;
        padding: 12px 0;
      }

      .product-image-box { width: 64px; height: 64px; }
    }

    .swal2-container {
      z-index: 99999 !important;
      position: fixed !important;
    }
  </style>
</head>

<body>

  <%- include('../partials/user/header', { userName: userName, url: url }) %>

  <!-- ── BANNER ── -->
  <section class="wishlist-banner">
    <p class="wishlist-banner__eyebrow">Your saved items</p>
    <h1 class="wishlist-banner__title">My <em>Wishlist</em></h1>
  </section>

  <div class="wishlist-page">
    <div class="container">

      <div class="wishlist-meta">
        <h2>Saved Picks</h2>
        <span class="wishlist-count"><%= wishlist ? wishlist.length : 0 %> items</span>
      </div>

      <% if (wishlist && wishlist.length > 0) { %>
        <div class="table-responsive">
          <table class="table wishlist-table">
            <thead>
              <tr>
                <th style="width:48%;">Product</th>
                <th style="width:16%;">Price</th>
                <th style="width:16%;">Status</th>
                <th style="width:20%;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% wishlist.forEach(function(product) { %>
                <% var activeVariant = product.variants && product.variants.find(function(v) { return !v.isBlocked; });
                   var displaySale    = activeVariant ? activeVariant.salesPrice   : null;
                   var displayRegular = activeVariant ? activeVariant.regularPrice : null; %>
                <tr>
                  <td>
                    <div class="product-cell">
                      <div class="product-image-box">
                        <img
                          src="<%= product.images && product.images.length > 0 ? product.images[0] : '/images/placeholder-product.jpg' %>"
                          alt="<%= product.productName %>">
                      </div>
                      <div class="product-info">
                        <div class="product-title"><%= product.productName %></div>
                        <div class="product-category"><%= product.category || 'No category' %></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="product-price">
                      <% if (displaySale != null) { %>
                        ₹<%= displaySale %>
                        <% if (displayRegular && displayRegular > displaySale) { %>
                          <span class="original-price">₹<%= displayRegular %></span>
                        <% } %>
                      <% } else { %>
                        <span style="color:#bbb;font-size:12px;">N/A</span>
                      <% } %>
                    </div>
                  </td>
                  <td>
                    <span class="badge-stock">In Stock</span>
                  </td>
                  <td>
                    <div class="d-flex align-items-center" style="gap:10px;">
                      <button class="btn-add-to-cart" data-product-id="<%= product._id %>">
                        <i class="fas fa-shopping-bag"></i> Add to Cart
                      </button>
                      <button class="btn-remove-wishlist" data-product-id="<%= product._id %>" title="Remove">
                        <i class="far fa-trash-alt"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

      <% } else { %>
        <div class="empty-wishlist">
          <i class="far fa-heart"></i>
          <h3>Your wishlist is empty</h3>
          <p>You haven't saved any products yet. Let's find something you'll love!</p>
          <a href="/shop" class="btn-shop">Explore the Collection</a>
        </div>
      <% } %>

    </div>
  </div>

  <%- include('../partials/user/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    // ── ALL YOUR ORIGINAL JS BELOW — UNTOUCHED ──────────
    document.querySelectorAll('.btn-add-to-cart').forEach(function (button) {
      button.addEventListener('click', async function (event) {
        const productId = event.currentTarget.dataset.productId;
        const btn = event.currentTarget;
        const btnText = btn.innerHTML;

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        try {
          const response = await fetch('/cart/add/' + productId, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });

          const data = await response.json();

          if (response.ok && data.success) {
            await Swal.fire({
              toast: true,
              position: 'top-end',
              icon: 'success',
              title: 'Product added to cart!',
              showConfirmButton: false,
              timer: 2000,
              timerProgressBar: true
            });
            window.location.reload();
          } else {
            Swal.fire({
              toast: true,
              position: 'top-end',
              icon: 'error',
              title: data.message || 'Failed to add to cart',
              showConfirmButton: false,
              timer: 2500,
              timerProgressBar: true
            });
          }
        } catch (error) {
          console.error('Error adding to cart:', error);
          Swal.fire({
            toast: true,
            position: 'top-end',
            icon: 'error',
            title: 'Something went wrong. Please try again.',
            showConfirmButton: false,
            timer: 2500,
            timerProgressBar: true
          });
        } finally {
          btn.disabled = false;
          btn.innerHTML = btnText;
        }
      });
    });

    document.querySelectorAll('.btn-remove-wishlist').forEach(button => {
      button.addEventListener('click', async function () {
        const productId = this.dataset.productId;

        try {
          const response = await fetch(`/wishlist/remove/${productId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });

          const data = await response.json();

          if (response.ok && data.success) {
            this.closest('tr').remove();

            const countEl = document.querySelector('.wishlist-count');
            const newCount = countEl ? (parseInt(countEl.textContent) || 0) - 1 : 0;
            if (countEl) countEl.textContent = newCount + ' items';

            await Swal.fire({
              icon: 'success',
              title: 'Removed!',
              text: 'Product removed from your wishlist',
              timer: 1500,
              showConfirmButton: false
            });

            if (newCount === 0) location.reload();

          } else {
            throw new Error(data.message || 'Failed to remove');
          }
        } catch (err) {
          Swal.fire({ icon: 'error', title: 'Error', text: err.message });
        }
      });
    });
  </script>

</body>
</html>