<%- include('../partials/user/header', { userName: userName, url: '/my-orders' }) %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<style>
  /* ── BASE ───────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --glora-dark:   #1A1A1A;
    --glora-cream:  #FAF7F4;
    --glora-red:    #8B1A1A;
    --glora-gold:   #D4A96A;
    --glora-blush:  #F0EBE3;
    --glora-muted:  #6B6B6B;
    --glora-border: #E0D8D0;
  }

  body {
    background: var(--glora-cream);
    font-family: 'Poppins', sans-serif;
    color: var(--glora-dark);
  }

  /* ── PAGE WRAPPER ───────────────────────────────────── */
  .glora-account {
  min-height: calc(100vh - 72px);
  padding: 40px 0 80px;
  margin-top: 72px;
}

  .glora-account__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .glora-account__heading {
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--glora-border);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .glora-account__eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  .glora-account__title {
    font-family: 'Cormorant Garant', serif;
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .glora-account__layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 32px;
    align-items: start;
  }

  /* ════════════════════════════════════════════════════
     SHARED SIDEBAR
  ════════════════════════════════════════════════════ */
  .profile-sidebar {
    background: #fff;
    border: 1px solid var(--glora-border);
    position: sticky;
    top: 96px;
  }

  .profile-sidebar__user {
    padding: 28px 24px 24px;
    border-bottom: 1px solid var(--glora-border);
    text-align: center;
  }

  .profile-sidebar__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--glora-blush);
    border: 2px solid var(--glora-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 14px;
  }

  .profile-sidebar__avatar i {
    font-size: 26px;
    color: var(--glora-muted);
  }

  .profile-sidebar__name {
    font-family: 'Cormorant Garant', serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: 0.3px;
    margin-bottom: 4px;
  }

  .profile-sidebar__label {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  /* Nav links */
  .profile-sidebar__nav {
    padding: 12px 0;
  }

  .profile-sidebar__nav a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--glora-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .profile-sidebar__nav a i {
    font-size: 13px;
    width: 16px;
    text-align: center;
  }

  .profile-sidebar__nav a:hover {
    color: var(--glora-dark);
    background: var(--glora-blush);
    border-left-color: var(--glora-border);
  }

  .profile-sidebar__nav a.active {
    color: var(--glora-red);
    border-left-color: var(--glora-red);
    background: #fdf5f5;
  }

  /* Logout */
  .profile-sidebar__logout {
    padding: 16px 24px;
    border-top: 1px solid var(--glora-border);
  }

  .profile-sidebar__logout form { margin: 0; }

  .btn-glora-logout {
    display: block;
    width: 100%;
    padding: 11px;
    background: transparent;
    border: 1.5px solid var(--glora-dark);
    color: var(--glora-dark);
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
  }

  .btn-glora-logout:hover {
    background: var(--glora-dark);
    color: #fff;
  }

  /* ════════════════════════════════════════════════════
     ORDERS PANEL
  ════════════════════════════════════════════════════ */
  .orders-panel { display: flex; flex-direction: column; gap: 0; }

  /* Search bar */
  .orders-search {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 16px;
    flex-wrap: wrap;
  }

  .orders-search__label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-muted);
  }

  .orders-search__form {
    position: relative;
    flex-shrink: 0;
  }

  .orders-search__input {
    padding: 10px 40px 10px 16px;
    border: 1px solid var(--glora-border);
    background: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    color: var(--glora-dark);
    outline: none;
    width: 240px;
    transition: border-color 0.2s ease;
  }

  .orders-search__input::placeholder { color: #bbb; }
  .orders-search__input:focus { border-color: var(--glora-dark); }

  .orders-search__btn {
    position: absolute;
    right: 0; top: 0; bottom: 0;
    padding: 0 14px;
    background: var(--glora-dark);
    border: none;
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease;
    font-size: 12px;
  }

  .orders-search__btn:hover { background: var(--glora-red); }

  /* ── ORDER CARD ─────────────────────────────────────── */
  .order-card {
    background: #fff;
    border: 1px solid var(--glora-border);
    margin-bottom: 16px;
    transition: box-shadow 0.2s ease;
  }

  .order-card:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,0.07);
  }

  .order-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 1px solid var(--glora-border);
    background: var(--glora-cream);
  }

  .order-card__id {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--glora-dark);
  }

  .order-card__date {
    font-size: 11px;
    color: var(--glora-muted);
    letter-spacing: 0.3px;
  }

  .order-card__body {
    padding: 20px 24px;
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  /* Items */
  .order-items { flex: 1; min-width: 0; }

  .order-item {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 12px;
  }

  .order-item:last-child { margin-bottom: 0; }

  .order-item__img {
    width: 54px;
    height: 54px;
    background: var(--glora-blush);
    border: 1px solid var(--glora-border);
    overflow: hidden;
    flex-shrink: 0;
  }

  .order-item__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .order-item__name {
    font-size: 12px;
    font-weight: 500;
    color: var(--glora-dark);
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 260px;
  }

  .order-item__meta {
    font-size: 11px;
    color: var(--glora-muted);
    display: flex;
    gap: 12px;
  }

  .order-more {
    font-size: 11px;
    color: var(--glora-gold);
    font-weight: 500;
    letter-spacing: 0.5px;
    margin-top: 8px;
  }

  /* Right side: status + total */
  .order-card__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
    flex-shrink: 0;
    min-width: 160px;
  }

  /* Status badge */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .status-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-badge.pending    { background: #FFF8E6; color: #9A6F00; }
  .status-badge.pending::before { background: #D4A96A; }

  .status-badge.processing { background: #EAF2FF; color: #1A5FAD; }
  .status-badge.processing::before { background: #1A5FAD; }

  .status-badge.shipped    { background: #F0EBE3; color: #5A4A3A; }
  .status-badge.shipped::before { background: #9C7A5A; }

  .status-badge.delivered  { background: #EDFAF2; color: #1A6B40; }
  .status-badge.delivered::before { background: #27AE60; }

  .status-badge.cancelled,
  .status-badge.returned   { background: #FFF0F0; color: var(--glora-red); }
  .status-badge.cancelled::before,
  .status-badge.returned::before { background: var(--glora-red); }
  .status-badge.return-requested { background: #FFF4E5; color: #B25E00; }
  .status-badge.return-rejected { background: #FDEAEA; color: #B02A2A; }

  .order-card__updated {
    font-size: 10px;
    color: var(--glora-muted);
    letter-spacing: 0.3px;
  }

  .order-card__total-amount {
    font-family: 'Cormorant Garant', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--glora-dark);
  }

  .order-card__total-label {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--glora-muted);
    text-align: right;
  }

  .cancel-reason {
    font-size: 11px;
    color: var(--glora-muted);
    padding: 0 24px 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .cancel-reason i { color: var(--glora-gold); font-size: 11px; }

  /* ── ORDER ACTIONS ──────────────────────────────────── */
  .order-card__footer {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    border-top: 1px solid var(--glora-border);
    background: var(--glora-cream);
    flex-wrap: wrap;
  }

  .order-action-btn {
    padding: 8px 18px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    border: none;
  }

  .order-action-btn--view {
    background: var(--glora-dark);
    color: #fff;
  }

  .order-action-btn--view:hover {
    background: var(--glora-red);
    color: #fff;
    text-decoration: none;
  }

  .order-action-btn--cancel {
    background: transparent;
    color: var(--glora-red);
    border: 1px solid var(--glora-red);
  }

  .order-action-btn--cancel:hover {
    background: var(--glora-red);
    color: #fff;
  }

  .order-action-btn--return {
    background: transparent;
    color: var(--glora-muted);
    border: 1px solid var(--glora-border);
  }

  .order-action-btn--return:hover {
    border-color: var(--glora-dark);
    color: var(--glora-dark);
  }

  .order-action-btn--invoice {
    background: transparent;
    color: var(--glora-dark);
    border: 1px solid var(--glora-border);
  }

  .order-action-btn--invoice:hover {
    background: var(--glora-dark);
    color: #fff;
    border-color: var(--glora-dark);
  }

  /* ── EMPTY STATE ────────────────────────────────────── */
  .orders-empty {
    background: #fff;
    border: 1px solid var(--glora-border);
    padding: 80px 40px;
    text-align: center;
  }

  .orders-empty__icon {
    font-size: 2.5rem;
    color: var(--glora-gold);
    margin-bottom: 20px;
    display: block;
  }

  .orders-empty__title {
    font-family: 'Cormorant Garant', serif;
    font-size: 28px;
    font-weight: 600;
    color: var(--glora-dark);
    margin-bottom: 10px;
  }

  .orders-empty__text {
    font-size: 13px;
    color: var(--glora-muted);
    margin-bottom: 28px;
  }

  .orders-empty__cta {
    display: inline-block;
    padding: 13px 32px;
    background: var(--glora-dark);
    color: #fff;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .orders-empty__cta:hover {
    background: var(--glora-red);
    color: #fff;
    text-decoration: none;
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .glora-account__layout { grid-template-columns: 1fr; }
    .glora-sidebar { position: static; }
    .glora-sidebar__nav { display: grid; grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 640px) {
    .glora-account__container { padding: 0 16px; }
    .order-card__body { flex-direction: column; }
    .order-card__right { align-items: flex-start; flex-direction: row; flex-wrap: wrap; }
    .orders-search__input { width: 180px; }
    .glora-sidebar__nav { grid-template-columns: 1fr; }
  }
</style>

<div class="glora-account">
  <div class="glora-account__container">
    <div class="glora-account__layout">

      <!-- ══ SHARED SIDEBAR ══════════════════════════════ -->
      <aside class="profile-sidebar">

      <div class="profile-sidebar__user">
        <div class="profile-sidebar__avatar">
          <i class="fas fa-user"></i>
        </div>
        <p class="profile-sidebar__name"><%= userName || 'User' %></p>
        <span class="profile-sidebar__label">My Account</span>
      </div>

      <nav class="profile-sidebar__nav">
        <a href="/profile" class="<%= url === '/profile' ? 'active' : '' %>">
          <i class="fas fa-user"></i> Profile
        </a>
        <a href="/my-orders" class="<%= url === '/my-orders' ? 'active' : '' %>">
          <i class="fas fa-box"></i> Orders
        </a>
        <a href="/manage-address" class="<%= url === '/manage-address' ? 'active' : '' %>">
          <i class="fas fa-map-marker-alt"></i> Addresses
        </a>
        <a href="/wallet" class="<%= url === '/wallet' ? 'active' : '' %>">
          <i class="fas fa-wallet"></i> Wallet
        </a>
        <a href="/wishlist"  class="<%= url === '/wishlist' ? 'active' : '' %>">
          <i class="fas fa-heart"></i> Wishlist
        </a>
        <a href="/add-account" class="<%= url === '/login' ? 'active' : '' %>">
          <i class="fas fa-sign-in-alt"></i> Add Account
        </a>
      </nav>

      <div class="profile-sidebar__logout">
        <form action="/logout" method="POST">
          <button type="submit" class="btn-glora-logout">
            <i class="fas fa-sign-out-alt" style="margin-right:6px;"></i>Log Out
          </button>
        </form>
      </div>

    </aside>

      <!-- ══ ORDERS PANEL ════════════════════════════════ -->
      <div class="orders-panel">
        <div class="glora-account__heading">
        <span class="glora-account__eyebrow">Your account</span>
        <h1 class="glora-account__title">My Orders</h1>
      </div>

        <!-- Search -->
        <div class="orders-search">
          <span class="orders-search__label"><%= orders && orders.length ? orders.length + ' order' + (orders.length !== 1 ? 's' : '') : 'No orders' %></span>
          <form method="get" action="/my-orders" class="orders-search__form">
            <input
              type="text"
              name="search"
              value="<%= search %>"
              class="orders-search__input"
              placeholder="Search by Order ID…"
            >
            <button type="submit" class="orders-search__btn">
              <i class="fas fa-search"></i>
            </button>
          </form>
        </div>

        <!-- Orders list -->
        <% if (orders && orders.length > 0) { %>

          <% orders.forEach(function(order) {
            let statusClass = 'pending';
            let statusText  = 'Pending';

            switch(order.status) {
              case 'Processing':      statusClass = 'processing'; statusText = 'Processing'; break;
              case 'Shipped':         statusClass = 'shipped';    statusText = 'Shipped';    break;
              case 'Delivered':       statusClass = 'delivered';  statusText = 'Delivered';  break;
              case 'Cancelled':       statusClass = 'cancelled';  statusText = 'Cancelled';  break;
              case 'Returned':        statusClass = 'returned';   statusText = 'Returned';   break;
              case 'Return-Requested':
              case 'Return-Request':  statusClass = 'return-requested'; statusText = 'Return Requested'; break;
              case 'Return-Rejected':  statusClass = 'return-rejected';  statusText = 'Return Rejected';  break;
            }
          %>

          <div class="order-card">

            <!-- Header -->
            <div class="order-card__header">
              <span class="order-card__id">Order #<%= order.orderId %></span>
              <span class="order-card__date">
                Placed <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
              </span>
            </div>

            <!-- Body -->
            <div class="order-card__body">

              <!-- Items -->
              <div class="order-items">
                <% if (order.orderItems && order.orderItems.length > 0) { %>
                  <% order.orderItems.slice(0, 3).forEach(function(item) { %>
                  <div class="order-item">
                    <div class="order-item__img">
                      <img src="<%= item.image || '/images/placeholder.jpg' %>" alt="<%= item.name || 'Product' %>">
                    </div>
                    <div>
                      <p class="order-item__name"><%= item.name || 'Product' %></p>
                      <div class="order-item__meta">
                        <span>₹<%= item.price ? item.price.toFixed(2) : '0.00' %></span>
                        <span>Qty: <%= item.quantity %></span>
                      </div>
                    </div>
                  </div>
                  <% }); %>
                  <% if (order.orderItems.length > 3) { %>
                    <p class="order-more">+<%= order.orderItems.length - 3 %> more item<%= order.orderItems.length - 3 !== 1 ? 's' : '' %></p>
                  <% } %>
                <% } %>
              </div>

              <!-- Right: status + total -->
              <div class="order-card__right">
                <span class="status-badge <%= statusClass %>"><%= statusText %></span>
                <% if (order.updatedAt) { %>
                  <span class="order-card__updated">
                    Updated <%= new Date(order.updatedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                  </span>
                <% } %>
                <div>
                  <p class="order-card__total-amount">₹<%= order.totalPrice?.toFixed(2) || '0.00' %></p>
                  <p class="order-card__total-label">Total</p>
                </div>
              </div>

            </div>

            <!-- Cancellation reason -->
            <% if (order.status === 'Cancelled' && order.cancellationReason) { %>
              <div class="cancel-reason">
                <i class="fas fa-info-circle"></i>
                Reason: <%= order.cancellationReason %>
              </div>
            <% } %>

            <!-- Footer actions -->
            <div class="order-card__footer">

              <a href="/my-orders/<%= order.orderId %>" class="order-action-btn order-action-btn--view">
                <i class="fas fa-eye"></i> View Details
              </a>

              <% if (order.status === 'Delivered') { %>
                <button type="button" class="order-action-btn order-action-btn--return" onclick="returnOrder('<%= order.orderId %>')">
                  <i class="fas fa-undo"></i> Return
                </button>
              <% } else if (order.status === 'Pending' || order.status === 'Processing') { %>
                <button type="button" class="order-action-btn order-action-btn--cancel" onclick="cancelOrder('<%= order.orderId %>')">
                  <i class="fas fa-times-circle"></i> Cancel Order
                </button>
              <% } %>

              <% if (order.paymentStatus === 'Paid' || (order.paymentMethod === 'COD' && order.status === 'Delivered')) { %>
                <a href="/my-orders/<%= order.orderId %>/invoice" class="order-action-btn order-action-btn--invoice">
                  <i class="fas fa-download"></i> Invoice
                </a>
              <% } else if (order.paymentMethod === 'Online' && order.paymentStatus !== 'Paid') { %>
                <button onclick="retryPayment('<%= order.orderId %>', this)" class="order-action-btn order-action-btn--invoice">
                  <i class="fas fa-redo"></i> Retry Payment
                </button>
              <% } %>

            </div>
          </div>

          <% }); %>

        <% } else { %>
          <div class="orders-empty">
            <i class="fas fa-box-open orders-empty__icon"></i>
            <h3 class="orders-empty__title">No Orders Yet</h3>
            <p class="orders-empty__text">You haven't placed any orders yet. Start exploring our collection.</p>
            <a href="/shop" class="orders-empty__cta">Continue Shopping</a>
          </div>
        <% } %>

      </div>
    </div>
  </div>
</div>

<%- include('../partials/user/footer') %>

<script>
  async function retryPayment(orderId, buttonElement) {
    const button = buttonElement || event?.target?.closest('button');
    try {
      if (button) {
        button.disabled = true;
        button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing…';
      }

      const response = await fetch('/retry-razorpay-order', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId })
      });

      const data = await response.json();
      if (!data.success) throw new Error(data.message || 'Failed to initiate retry');

      const options = {
        key: data.key,
        amount: data.amount,
        currency: data.currency || 'INR',
        name: 'GLORA',
        description: 'Retry Order Payment',
        order_id: data.razorpayOrderId,
        handler: async function (response) {
          try {
            const verifyRes = await fetch('/verify-retry-payment', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                razorpay_payment_id: response.razorpay_payment_id,
                razorpay_order_id:   response.razorpay_order_id,
                razorpay_signature:  response.razorpay_signature,
                orderId
              })
            });
            const verifyData = await verifyRes.json();
            if (verifyData.success) {
              window.location.href = verifyData.redirectUrl;
            } else {
              Swal.fire({ icon: 'error', title: 'Verification Failed', text: 'Payment received but verification failed. Please contact support.' });
            }
          } catch (err) {
            Swal.fire({ icon: 'warning', title: 'Payment Successful', text: 'Payment was received but we could not update your order. Please contact support.' })
              .then(() => window.location.href = '/my-orders');
          }
        },
        prefill: { name: '<%= userName %>' },
        theme: { color: '#8B1A1A' },
        modal: {
          ondismiss: function () {
            if (button) { button.disabled = false; button.innerHTML = '<i class="fas fa-redo"></i> Retry Payment'; }
          }
        }
      };

      const rzp = new Razorpay(options);
      rzp.on('payment.failed', function (response) {
        Swal.fire({ icon: 'error', title: 'Payment Failed', text: response.error.description || 'Payment could not be processed.' });
        if (button) { button.disabled = false; button.innerHTML = '<i class="fas fa-redo"></i> Retry Payment'; }
      });
      rzp.open();

    } catch (error) {
      Swal.fire({ icon: 'error', title: 'Error', text: error.message || 'Something went wrong.' });
      if (button) { button.disabled = false; button.innerHTML = '<i class="fas fa-redo"></i> Retry Payment'; }
    }
  }

  async function cancelOrder(orderId) {
    const { value: reason } = await Swal.fire({
      title: 'Reason for cancellation',
      input: 'textarea',
      inputPlaceholder: 'Why are you cancelling this order? (optional)',
      showCancelButton: true,
      confirmButtonText: 'Continue',
      confirmButtonColor: '#8B1A1A'
    });

    if (reason === undefined) return;

    const confirm = await Swal.fire({
      title: 'Cancel this order?',
      text: 'This action cannot be undone.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Yes, cancel it',
      confirmButtonColor: '#8B1A1A'
    });

    if (!confirm.isConfirmed) return;

    try {
      const res  = await fetch(`/my-orders/${orderId}/cancel`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason })
      });
      const data = await res.json();
      if (res.ok) {
        Swal.fire({ icon: 'success', title: 'Order Cancelled', text: data.message, confirmButtonColor: '#8B1A1A' })
          .then(() => window.location.reload());
      } else {
        Swal.fire({ icon: 'error', title: 'Error', text: data.message, confirmButtonColor: '#8B1A1A' });
      }
    } catch (err) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong.', confirmButtonColor: '#8B1A1A' });
    }
  }

  async function returnOrder(orderId) {
    const { value: reason } = await Swal.fire({
      title: 'Return Order',
      input: 'text',
      inputPlaceholder: 'Enter reason for return',
      showCancelButton: true,
      confirmButtonText: 'Submit Return',
      confirmButtonColor: '#8B1A1A',
      inputValidator: function (value) {
        if (!value) return 'Please provide a reason for return.';
      }
    });

    if (!reason) return;

    try {
      const res  = await fetch('/my-orders/' + orderId + '/return', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason })
      });
      const data = await res.json();
      if (res.ok && data.success) {
        await Swal.fire({ icon: 'success', title: 'Return Requested', text: 'Your return request has been submitted. Our team will review it shortly.', confirmButtonColor: '#8B1A1A' });
        window.location.reload();
      } else {
        Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Failed to submit return request.', confirmButtonColor: '#8B1A1A' });
      }
    } catch (err) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong. Please try again.', confirmButtonColor: '#8B1A1A' });
    }
  }
</script>
