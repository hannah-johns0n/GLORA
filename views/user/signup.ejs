<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Account — GLORA</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,400;0,600;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --glora-dark:   #1A1A1A;
      --glora-cream:  #FAF7F4;
      --glora-red:    #8B1A1A;
      --glora-gold:   #D4A96A;
      --glora-blush:  #F0EBE3;
      --glora-muted:  #6B6B6B;
      --glora-border: #E0D8D0;
    }

    body {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      font-family: 'Poppins', sans-serif;
      background: var(--glora-cream);
    }

    /* ── LEFT PANEL ─────────────────────────────────────── */
    .signup-left {
      background: var(--glora-dark);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 56px;
      position: relative;
      overflow: hidden;
    }

    .signup-left::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 30% 70%, rgba(139,26,26,0.25) 0%, transparent 65%),
                  radial-gradient(ellipse at 80% 20%, rgba(212,169,106,0.10) 0%, transparent 55%);
      pointer-events: none;
    }

    .signup-left__content {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 340px;
    }

    .signup-left__logo {
      font-family: 'Cormorant Garant', serif;
      font-size: 48px;
      font-weight: 600;
      letter-spacing: 8px;
      text-transform: uppercase;
      color: #fff;
      text-decoration: none;
      display: block;
      margin-bottom: 16px;
    }

    .signup-left__divider {
      width: 40px;
      height: 1px;
      background: var(--glora-gold);
      margin: 0 auto 20px;
      opacity: 0.7;
    }

    .signup-left__tagline {
      font-family: 'Cormorant Garant', serif;
      font-size: 22px;
      font-style: italic;
      font-weight: 400;
      color: rgba(255,255,255,0.55);
      line-height: 1.5;
      margin-bottom: 48px;
    }

    .signup-left__steps {
      display: flex;
      flex-direction: column;
      gap: 20px;
      text-align: left;
    }

    .signup-left__step {
      display: flex;
      align-items: flex-start;
      gap: 16px;
    }

    .signup-left__step-num {
      font-family: 'Cormorant Garant', serif;
      font-size: 28px;
      font-weight: 600;
      color: var(--glora-gold);
      opacity: 0.4;
      line-height: 1;
      flex-shrink: 0;
      width: 28px;
    }

    .signup-left__step-text {
      font-size: 11px;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.5px;
      line-height: 1.6;
      padding-top: 4px;
    }

    .signup-left__step-text strong {
      display: block;
      font-size: 12px;
      color: rgba(255,255,255,0.75);
      font-weight: 500;
      margin-bottom: 2px;
      letter-spacing: 0.3px;
    }

    /* ── RIGHT PANEL ────────────────────────────────────── */
    .signup-right {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 48px 56px;
      background: var(--glora-cream);
      overflow-y: auto;
    }

    .signup-form-wrap {
      width: 100%;
      max-width: 400px;
    }

    /* Heading */
    .signup-heading { margin-bottom: 32px; }

    .signup-heading__eyebrow {
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--glora-gold);
      margin-bottom: 10px;
    }

    .signup-heading__title {
      font-family: 'Cormorant Garant', serif;
      font-size: 32px;
      font-weight: 600;
      color: var(--glora-dark);
      letter-spacing: -0.5px;
      line-height: 1.1;
      margin-bottom: 8px;
    }

    .signup-heading__sub {
      font-size: 12px;
      color: var(--glora-muted);
      letter-spacing: 0.3px;
    }

    /* Server error */
    .signup-error {
      padding: 12px 16px;
      background: #fff0f0;
      border-left: 3px solid var(--glora-red);
      color: var(--glora-red);
      font-size: 12px;
      margin-bottom: 20px;
      line-height: 1.5;
    }

    /* Form */
    .signup-form { display: flex; flex-direction: column; gap: 18px; }

    /* Two-col row */
    .signup-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .signup-field { display: flex; flex-direction: column; gap: 7px; }

    .signup-label {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--glora-dark);
    }

    .signup-input-wrap { position: relative; }

    .signup-input {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid var(--glora-border);
      background: #fff;
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      color: var(--glora-dark);
      outline: none;
      border-radius: 0;
      transition: border-color 0.2s ease;
      -webkit-appearance: none;
    }

    .signup-input::placeholder { color: #c0b8b0; }
    .signup-input:focus { border-color: var(--glora-dark); }

    .signup-input--pad { padding-right: 44px; }

    .signup-toggle {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: var(--glora-muted);
      font-size: 13px;
      padding: 0;
      transition: color 0.2s ease;
    }

    .signup-toggle:hover { color: var(--glora-dark); }

    /* Terms checkbox */
    .signup-terms {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 11px;
      color: var(--glora-muted);
      line-height: 1.5;
    }

    .signup-terms input[type="checkbox"] {
      width: 14px;
      height: 14px;
      margin-top: 2px;
      accent-color: var(--glora-dark);
      flex-shrink: 0;
      cursor: pointer;
    }

    /* Submit */
    .signup-submit {
      width: 100%;
      padding: 14px;
      background: var(--glora-dark);
      color: #fff;
      border: none;
      font-family: 'Poppins', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s ease;
    }

    .signup-submit:hover { background: var(--glora-red); }

    /* Divider */
    .signup-or {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .signup-or__line { flex: 1; height: 1px; background: var(--glora-border); }

    .signup-or__text {
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--glora-muted);
    }

    /* Google */
    .signup-google {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 13px;
      background: #fff;
      border: 1px solid var(--glora-border);
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 1px;
      color: var(--glora-dark);
      text-decoration: none;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .signup-google:hover {
      border-color: var(--glora-dark);
      background: var(--glora-cream);
      color: var(--glora-dark);
      text-decoration: none;
    }

    .signup-google img { width: 16px; height: 16px; }

    /* Footer */
    .signup-footer {
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid var(--glora-border);
      text-align: center;
      font-size: 11px;
      color: var(--glora-muted);
    }

    .signup-footer a {
      color: var(--glora-dark);
      font-weight: 600;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .signup-footer a:hover { color: var(--glora-red); }

    /* ── RESPONSIVE ─────────────────────────────────────── */
    @media (max-width: 900px) {
      body { grid-template-columns: 1fr; }
      .signup-left { display: none; }
      .signup-right { padding: 48px 32px; min-height: 100vh; }
    }

    @media (max-width: 480px) {
      .signup-right { padding: 40px 20px; }
      .signup-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- ── LEFT PANEL ──────────────────────────────────────── -->
  <div class="signup-left">
    <div class="signup-left__content">
      <a href="/" class="signup-left__logo">GLORA</a>
      <div class="signup-left__divider"></div>
      <p class="signup-left__tagline">Your beauty journey<br>starts here</p>

      <div class="signup-left__steps">
        <div class="signup-left__step">
          <span class="signup-left__step-num">01</span>
          <div class="signup-left__step-text">
            <strong>Create your account</strong>
            Fill in your details to get started in under a minute.
          </div>
        </div>
        <div class="signup-left__step">
          <span class="signup-left__step-num">02</span>
          <div class="signup-left__step-text">
            <strong>Verify your email</strong>
            We'll send a one-time code to confirm it's really you.
          </div>
        </div>
        <div class="signup-left__step">
          <span class="signup-left__step-num">03</span>
          <div class="signup-left__step-text">
            <strong>Start shopping</strong>
            Discover curated beauty and Enjoy you shopping. Love yaa!
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── RIGHT PANEL ─────────────────────────────────────── -->
  <div class="signup-right">
    <div class="signup-form-wrap">

      <div class="signup-heading">
        <p class="signup-heading__eyebrow">Join GLORA</p>
        <h1 class="signup-heading__title">Create Your Account</h1>
        <p class="signup-heading__sub">Fill in the details below to get started.</p>
      </div>

      <% if (error) { %>
        <div class="signup-error"><i class="fas fa-exclamation-circle" style="margin-right:6px;"></i><%= error %></div>
      <% } %>

      <form action="/signup" method="POST" autocomplete="off" class="signup-form">

        <!-- Name + Phone -->
        <div class="signup-row">
          <div class="signup-field">
            <label class="signup-label" for="name">Full Name</label>
            <div class="signup-input-wrap">
              <input type="text" id="name" name="name" class="signup-input" placeholder="Your name" required>
            </div>
          </div>

          <div class="signup-field">
            <label class="signup-label" for="phoneNumber">Phone</label>
            <div class="signup-input-wrap">
              <input type="tel" id="phoneNumber" name="phoneNumber" class="signup-input" placeholder="10-digit" pattern="[0-9]{10}" required>
            </div>
          </div>
        </div>

        <!-- Email -->
        <div class="signup-field">
          <label class="signup-label" for="email">Email Address</label>
          <div class="signup-input-wrap">
            <input type="email" id="email" name="email" class="signup-input" placeholder="you@example.com" required>
          </div>
        </div>

        <!-- Password -->
        <div class="signup-field">
          <label class="signup-label" for="password">Password</label>
          <div class="signup-input-wrap">
            <input type="password" id="password" name="password" class="signup-input signup-input--pad" placeholder="Min. 8 characters" pattern=".{8,}" required>
            <button type="button" class="signup-toggle" onclick="togglePassword('password', 'pwd-icon')">
              <i class="fas fa-eye" id="pwd-icon"></i>
            </button>
          </div>
        </div>

        <!-- Confirm Password -->
        <div class="signup-field">
          <label class="signup-label" for="confirmPassword">Confirm Password</label>
          <div class="signup-input-wrap">
            <input type="password" id="confirmPassword" name="confirmPassword" class="signup-input signup-input--pad" placeholder="Re-enter password" required>
            <button type="button" class="signup-toggle" onclick="togglePassword('confirmPassword', 'cpwd-icon')">
              <i class="fas fa-eye" id="cpwd-icon"></i>
            </button>
          </div>
        </div>

        <!-- Referral Code (Optional) -->
<div class="signup-field">
  <label class="signup-label" for="referralCode">
    Referral Code 
    <span style="font-size:12px; color:#999; font-weight:400;">(Optional)</span>
  </label>
  <div class="signup-input-wrap">
    <input 
      type="text" 
      id="referralCode" 
      name="referralCode" 
      class="signup-input" 
      placeholder="Enter referral code if you have one"
      maxlength="20"
      style="text-transform: uppercase;"
    >
  </div>
</div>

        <!-- Terms -->
        <label class="signup-terms">
          <input type="checkbox" name="terms" required>
          I agree to the <a href="#" style="color:var(--glora-dark);margin:0 3px;">Terms of Service</a> and <a href="#" style="color:var(--glora-dark);margin-left:3px;">Privacy Policy</a>
        </label>

        <button type="submit" class="signup-submit">
          Create Account
        </button>

      </form>

      <div class="signup-or" style="margin-top:20px;">
        <div class="signup-or__line"></div>
        <span class="signup-or__text">or</span>
        <div class="signup-or__line"></div>
      </div>

      <a href="/auth/google" class="signup-google">
        <img src="https://img.icons8.com/color/16/google-logo.png" alt="Google">
        Continue with Google
      </a>

      <div class="signup-footer">
        Already have an account? <a href="/login">Sign in</a>
      </div>

    </div>
  </div>

  <script>
    function togglePassword(fieldId, iconId) {
      const field = document.getElementById(fieldId);
      const icon  = document.getElementById(iconId);
      if (field.type === 'password') {
        field.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        field.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }

    document.querySelector('form').addEventListener('submit', function (e) {
      const name            = document.getElementById('name').value.trim();
      const email           = document.getElementById('email').value.trim();
      const phone           = document.getElementById('phoneNumber').value.trim();
      const password        = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      const nameRegex  = /^[A-Za-z ]+$/;

      if (!name || !email || !phone || !password || !confirmPassword) {
        e.preventDefault();
        Swal.fire({ icon: 'warning', title: 'All fields are required', confirmButtonColor: '#8B1A1A' });
        return;
      }

      if (!emailRegex.test(email)) {
        e.preventDefault();
        Swal.fire({ icon: 'error', title: 'Invalid email format', confirmButtonColor: '#8B1A1A' });
        return;
      }

      if (!nameRegex.test(name) || name.startsWith(' ')) {
        e.preventDefault();
        Swal.fire({ icon: 'error', title: 'Invalid name', text: 'Name cannot have special characters or start with a space.', confirmButtonColor: '#8B1A1A' });
        return;
      }

      if (!/^\d{10}$/.test(phone)) {
        e.preventDefault();
        Swal.fire({ icon: 'warning', title: 'Phone number must be 10 digits', confirmButtonColor: '#8B1A1A' });
        return;
      }

      if (password.length < 8) {
        e.preventDefault();
        Swal.fire({ icon: 'warning', title: 'Password too short', text: 'Password must be at least 8 characters.', confirmButtonColor: '#8B1A1A' });
        return;
      }

      if (password !== confirmPassword) {
        e.preventDefault();
        Swal.fire({ icon: 'error', title: 'Passwords do not match', confirmButtonColor: '#8B1A1A' });
        return;
      }
    });
  </script>

</body>
</html>
