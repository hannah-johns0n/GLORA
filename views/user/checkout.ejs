<%- include('../partials/user/header', { userName: userName, url: url }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,400;0,600;1,400;1,600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --dark:   #1A1A1A;
    --cream:  #FAF7F4;
    --red:    #8B1A1A;
    --gold:   #D4A96A;
    --blush:  #F0EBE3;
    --muted:  #6B6B6B;
    --border: #E0D8D0;
  }

  body {
    background: var(--cream);
    font-family: 'Poppins', sans-serif;
    color: var(--dark);
  }

  /* ── BANNER ───────────────────────────────────────── */
  .checkout-banner {
    background: var(--dark);
    padding: 30px 0 25px;
    text-align: center;
    margin-top: 65px;
    position: relative;
    overflow: hidden;
  }

  .checkout-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 60%, rgba(139,26,26,0.20) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(212,169,106,0.09) 0%, transparent 55%);
    pointer-events: none;
  }

  .checkout-banner__eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
    position: relative;
  }

  .checkout-banner__title {
    font-family: 'Cormorant Garant', serif;
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.5px;
    line-height: 1.1;
    position: relative;
  }

  .checkout-banner__title em {
    font-style: italic;
    font-weight: 400;
  }

  /* ── MAIN ─────────────────────────────────────────── */
  .checkout-container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 52px 24px 90px;
  }

  .checkout-grid {
    display: grid;
    grid-template-columns: 1.45fr 1fr;
    gap: 36px;
    align-items: start;
  }

  /* ── PANELS ───────────────────────────────────────── */
  .checkout-panel {
    background: #fff;
    border-top: 3px solid var(--gold);
    padding: 32px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.05);
  }

  .panel-title {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }

  /* ── ADDRESS CARDS ────────────────────────────────── */
  .address-card {
    border: 1.5px solid var(--border);
    padding: 16px 18px;
    margin-bottom: 10px;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    background: var(--cream);
    display: block;
  }

  .address-card:hover {
    border-color: var(--gold);
    background: #fff;
  }

  .address-card.selected {
    border-color: var(--dark);
    background: #fff;
    box-shadow: 0 4px 16px rgba(26,26,26,0.08);
  }

  .address-card input[type="radio"] {
    accent-color: var(--dark);
    width: 15px;
    height: 15px;
    cursor: pointer;
    margin-top: 3px;
  }

  .address-card strong {
    font-size: 13px;
    font-weight: 600;
    color: var(--dark);
  }

  .address-card .addr-type {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-left: 8px;
  }

  .address-card .addr-detail {
    font-size: 12px;
    color: var(--muted);
    margin-top: 4px;
    line-height: 1.5;
  }

  .badge-default {
    display: inline-block;
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 2px 8px;
    margin-left: 8px;
  }

  /* ── ADD ADDRESS ──────────────────────────────────── */
  .btn-add-address {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--muted);
    border: 1.5px dashed var(--border);
    padding: 11px 18px;
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 14px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-add-address:hover {
    border-color: var(--dark);
    color: var(--dark);
    text-decoration: none;
  }

  /* ── PAYMENT METHOD ───────────────────────────────── */
  .payment-method { margin-top: 36px; }

  .payment-card {
    border: 1.5px solid var(--border);
    padding: 16px 18px;
    margin-bottom: 10px;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
    background: var(--cream);
    display: block;
  }

  .payment-card:hover { border-color: var(--gold); background: #fff; }

  .payment-card.selected {
    border-color: var(--dark);
    background: #fff;
    box-shadow: 0 4px 16px rgba(26,26,26,0.07);
  }

  .payment-card input[type="radio"] {
    accent-color: var(--dark);
    width: 15px;
    height: 15px;
    cursor: pointer;
    margin-top: 3px;
  }

  .payment-card strong {
    font-size: 13px;
    font-weight: 600;
    color: var(--dark);
  }

  .payment-card .pay-detail {
    font-size: 11px;
    color: var(--muted);
    margin-top: 3px;
  }

  /* ── ORDER ITEMS ──────────────────────────────────── */
  .order-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--blush);
  }

  .order-item:last-child { border-bottom: none; }

  .order-item-img {
    width: 68px;
    height: 68px;
    object-fit: cover;
    background: var(--blush);
    flex-shrink: 0;
  }

  .order-item-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .order-item-qty {
    font-size: 11px;
    color: var(--muted);
  }

  .order-item-offer {
    font-size: 10px;
    color: var(--muted);
    margin-top: 4px;
  }

  .order-item-price {
    font-family: 'Cormorant Garant', serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--red);
    white-space: nowrap;
    margin-left: auto;
  }

  /* ── PRICE SUMMARY ────────────────────────────────── */
  .price-summary {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 0;
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
  }

  .price-row.discount { color: #2e7d32; }

  .price-row.total {
    font-family: 'Cormorant Garant', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--dark);
    padding-top: 14px;
    margin-top: 8px;
    border-top: 1px solid var(--border);
  }

  /* ── BUTTONS ──────────────────────────────────────── */
  .btn-place-order {
    width: 100%;
    padding: 15px 24px;
    background: var(--dark);
    color: #fff;
    border: none;
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    margin-top: 24px;
    transition: background 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .btn-place-order:hover:not(:disabled) { background: var(--red); }

  .btn-place-order:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .btn-apply-coupon {
    width: 100%;
    background: transparent;
    border: 1.5px dashed var(--border);
    color: var(--muted);
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 12px 16px;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .btn-apply-coupon:hover {
    border-color: var(--dark);
    color: var(--dark);
  }

  .secure-note {
    text-align: center;
    font-size: 10px;
    color: #bbb;
    margin-top: 16px;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .secure-note i { color: var(--gold); }

  /* ── NO ADDRESS ALERT ─────────────────────────────── */
  .no-address-alert {
    background: #fff8f0;
    border-left: 3px solid var(--gold);
    color: #7a5c2e;
    font-size: 12px;
    padding: 12px 16px;
    font-weight: 500;
  }

  /* ── APPLIED COUPON ───────────────────────────────── */
  #appliedCouponInfo {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f0f8f5;
    border: 1.5px solid #a8d5bb;
    padding: 11px 14px;
    margin-top: 14px;
    font-size: 12px;
    font-weight: 600;
    color: #2e7d32;
  }

  #appliedCouponInfo .btn-danger {
    font-size: 10px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 0;
    letter-spacing: 1px;
  }

  /* ── MODAL ────────────────────────────────────────── */
  .modal-content {
    border: none;
    border-radius: 0;
    border-top: 3px solid var(--gold);
  }

  .modal-header {
    border-bottom: 1px solid var(--border);
    padding: 24px 28px 20px;
  }

  .modal-title {
    font-family: 'Cormorant Garant', serif;
    font-size: 24px;
    font-weight: 600;
    color: var(--dark);
    letter-spacing: -0.3px;
  }

  .modal-body { padding: 24px 28px; }

  .coupon-item {
    border: 1.5px solid var(--border) !important;
    padding: 16px !important;
    margin-bottom: 10px !important;
    background: var(--cream);
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
    border-radius: 0 !important;
  }

  .coupon-item:hover {
    border-color: var(--dark) !important;
    background: #fff;
  }

  .coupon-item input[type="radio"] { accent-color: var(--dark); }

  .coupon-item strong {
    font-size: 13px;
    font-weight: 600;
    color: var(--dark);
  }

  .coupon-item .text-muted {
    font-size: 11px;
    color: var(--muted) !important;
    margin-top: 3px;
  }

  .coupon-item .text-success {
    font-size: 11px;
    color: #2e7d32 !important;
    font-weight: 600;
    margin-top: 3px;
  }

  .modal-footer {
    border-top: 1px solid var(--border);
    padding: 16px 28px;
  }

  .btn-apply-modal {
    background: var(--dark);
    color: #fff;
    border: none;
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 12px 28px;
    cursor: pointer;
    transition: background 0.2s ease;
    border-radius: 0;
  }

  .btn-apply-modal:hover { background: var(--red); color: #fff; }

  /* ── RESPONSIVE ───────────────────────────────────── */
  @media (max-width: 900px) {
    .checkout-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .checkout-panel { padding: 22px 16px; }
    .checkout-container { padding: 36px 14px 70px; }
  }
</style>

<body>

  <!-- BANNER -->
  <section class="checkout-banner">
    <p class="checkout-banner__eyebrow">Almost There</p>
    <h1 class="checkout-banner__title">Complete Your <em>Order</em></h1>
  </section>

  <div class="checkout-container">
    <form id="checkoutForm" class="checkout-grid">

      <!-- ── LEFT: SHIPPING + PAYMENT ───────────────── -->
      <div>

        <!-- Shipping -->
        <div class="checkout-panel">
          <p class="panel-title">Shipping Information</p>

          <% if (addresses && addresses.length > 0) { %>
            <% addresses.forEach(function(address) { %>
              <label class="address-card <%= address.isDefault ? 'selected' : '' %>">
                <div style="display:flex;align-items:flex-start;gap:12px;">
                  <input type="radio" name="addressId" value="<%= address._id %>"
                    <%= address.isDefault ? 'checked' : '' %> required>
                  <div>
                    <div style="display:flex;align-items:center;flex-wrap:wrap;gap:4px;">
                      <strong><%= address.name %></strong>
                      <span class="addr-type"><%= address.addressType %></span>
                      <% if (address.isDefault) { %>
                        <span class="badge-default">Default</span>
                      <% } %>
                    </div>
                    <p class="addr-detail">
                      <%= address.city %><% if (address.landmark) { %>, <%= address.landmark %><% } %>, <%= address.state %>
                    </p>
                  </div>
                </div>
              </label>
            <% }); %>
          <% } else { %>
            <div class="no-address-alert">
              No addresses found. Please add a shipping address to continue.
            </div>
          <% } %>

          <a href="/add-address?fromCheckout=true" class="btn-add-address">
            <i class="fas fa-plus"></i> Add New Address
          </a>
        </div>

        <!-- Payment -->
        <div class="checkout-panel payment-method" style="margin-top:24px;">
          <p class="panel-title">Payment Method</p>

          <label class="payment-card selected">
            <div style="display:flex;align-items:flex-start;gap:12px;">
              <input type="radio" name="paymentMethod" value="cod" checked>
              <div>
                <strong>Cash on Delivery</strong>
                <p class="pay-detail">Pay with cash upon delivery</p>
              </div>
            </div>
          </label>

          <label class="payment-card">
            <div style="display:flex;align-items:flex-start;gap:12px;">
              <input type="radio" name="paymentMethod" value="razorpay">
              <div>
                <strong>Pay with Razorpay</strong>
                <p class="pay-detail">Secure online payment</p>
              </div>
            </div>
          </label>

          <label class="payment-card">
            <div style="display:flex;align-items:flex-start;gap:12px;">
              <input type="radio" name="paymentMethod" value="wallet" id="walletPayment">
              <div>
                <strong>GLORA Wallet</strong>
                <p class="pay-detail" id="walletBalanceText">
                  Available: ₹<span id="walletBalance">0.00</span>
                  <span id="walletInsufficient" class="d-none" style="color:#c62828;"> — Insufficient balance</span>
                </p>
              </div>
            </div>
          </label>
        </div>

      </div>

      <!-- ── RIGHT: ORDER SUMMARY ────────────────────── -->
      <div class="checkout-panel" style="position:sticky;top:90px;">
        <p class="panel-title">Order Summary</p>

        <div class="order-items">
          <% cartItems.forEach(function(item) { %>
            <div class="order-item">
              <img src="<%= item.productId.images[0] %>" alt="<%= item.productId.productName %>" class="order-item-img">
              <div class="order-item-details" style="flex:1;min-width:0;">
                <div class="order-item-name"><%= item.productId.productName %></div>
                <div class="order-item-qty">Qty: <%= item.quantity %></div>
                <% if (item.appliedOffer) { %>
                  <p class="order-item-offer"><strong>Offer:</strong> <%= item.appliedOffer.title %></p>
                <% } %>
              </div>
              <div class="order-item-price">₹<%= item.itemTotal.toFixed(2) %></div>
            </div>
          <% }); %>
        </div>

        <div class="price-summary">
          <div class="price-row">
            <span>Subtotal (<%= cartItems.reduce((t, i) => t + i.quantity, 0) %> items)</span>
            <span>₹<%= subtotal.toFixed(2) %></span>
          </div>
          <% if (offerDiscount > 0) { %>
            <div class="price-row discount">
              <span>Offer Discount</span>
              <span>−₹<%= offerDiscount.toFixed(2) %></span>
            </div>
            <div class="price-row">
              <span>After Offers</span>
              <span>₹<%= priceAfterOffers.toFixed(2) %></span>
            </div>
          <% } %>
          <% if (couponDiscount > 0) { %>
            <div class="price-row discount">
              <span>Coupon Discount</span>
              <span>−₹<%= couponDiscount.toFixed(2) %></span>
            </div>
          <% } %>
          <% if (appliedCoupon) { %>
            <div class="price-row">
              <span>Applied Coupon</span>
              <span><%= appliedCoupon %></span>
            </div>
          <% } %>
          <div class="price-row">
            <span>Shipping</span>
            <span id="shippingDisplay">
              <% if (shipping === 0) { %>
                <span style="color:#2e7d32;font-weight:600;">FREE</span>
              <% } else { %>
                ₹<%= shipping %>
              <% } %>
            </span>
          </div>
          <div class="price-row total">
            <span>Total</span>
            <span>₹<%= finalTotal.toFixed(2) %></span>
          </div>
        </div>

        <button type="submit" class="btn-place-order"
          <%= addresses && addresses.length === 0 ? 'disabled' : '' %>>
          <i class="fas fa-lock"></i> Place Order
        </button>

        <button type="button" class="btn-apply-coupon"
          data-bs-toggle="modal" data-bs-target="#couponModal">
          <i class="fas fa-tag"></i> Apply Coupon
        </button>

        <p class="secure-note">
          <i class="fas fa-shield-alt"></i> Your payment information is secure
        </p>
      </div>

    </form>
  </div>

  <!-- ── COUPON MODAL ─────────────────────────────────── -->
  <div class="modal fade" id="couponModal" tabindex="-1" aria-labelledby="couponModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="couponModalLabel">Available Coupons</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <% if (coupons && coupons.length > 0) { %>
            <form id="couponForm">
              <ul style="list-style:none;padding:0;margin:0;">
                <% coupons.forEach(function(coupon, index) { %>
                  <li class="coupon-item">
                    <input type="radio" name="selectedCoupon" value="<%= coupon.couponCode %>"
                      data-discounttype="<%= coupon.discountType %>"
                      data-discountvalue="<%= coupon.discountValue %>"
                      data-minimum="<%= coupon.minimumPurchaseAmount %>"
                      data-maxdiscount="<%= coupon.maxDiscountAmount || 0 %>"
                      id="coupon_<%= index %>" class="form-check-input"
                      style="margin-top:0;cursor:pointer;">
                    <label for="coupon_<%= index %>"
                      style="cursor:pointer;margin-left:10px;display:inline-block;width:calc(100% - 30px);">
                      <strong><%= coupon.couponCode %></strong><br>
                      <span class="text-muted"><%= coupon.description %></span><br>
                      <span class="text-success">
                        Save <%= coupon.discountType === 'Percentage' ? coupon.discountValue + '%' : '₹' + coupon.discountValue %>
                        <% if (coupon.discountType === 'Percentage' && coupon.maxDiscountAmount) { %>
                          (up to ₹<%= coupon.maxDiscountAmount %>)
                        <% } %>
                      </span>
                    </label>
                  </li>
                <% }); %>
              </ul>
            </form>
          <% } else { %>
            <p style="text-align:center;color:var(--muted);font-size:13px;">No coupons available right now.</p>
          <% } %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-apply-modal" id="applySelectedCoupon">
            Apply Coupon
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

</body>

<script>
  var SUBTOTAL = <%= subtotal %>;
  var OFFER_DISCOUNT = <%= offerDiscount || 0 %>;
  var PRICE_AFTER_OFFERS = <%= priceAfterOffers %>;
  var COUPON_DISCOUNT = <%= couponDiscount || 0 %>;
  var SHIPPING = <%= shipping %>;
  var APPLIED_COUPON = '<%= appliedCoupon || '' %>';

  document.addEventListener('DOMContentLoaded', async function () {
    if (APPLIED_COUPON) {
      var hiddenInput = document.createElement('input');
      hiddenInput.type = 'hidden';
      hiddenInput.name = 'couponCode';
      hiddenInput.value = APPLIED_COUPON;
      document.getElementById('checkoutForm').appendChild(hiddenInput);
    }
    try {
      const res = await fetch('/wallet/balance');
      const data = await res.json();
      if (data.success) {
        document.getElementById('walletBalance').textContent = data.balance.toFixed(2);
        checkWalletBalance();
      }
    } catch (err) {
      console.error('Error fetching wallet balance:', err);
    }
  });

  function checkWalletBalance() {
    const walletBalance = parseFloat(document.getElementById('walletBalance').textContent);
    const totalText = document.querySelector('.price-row.total span:last-child').textContent.replace('₹', '');
    const totalAmount = parseFloat(totalText);
    const walletRadio = document.getElementById('walletPayment');
    const walletInsufficient = document.getElementById('walletInsufficient');

    if (walletBalance < totalAmount) {
      walletInsufficient.classList.remove('d-none');
      if (walletRadio.checked) {
        walletRadio.checked = false;
        document.querySelector('input[value="cod"]').checked = true;
      }
      walletRadio.disabled = true;
    } else {
      walletInsufficient.classList.add('d-none');
      walletRadio.disabled = false;
    }
  }

  document.querySelectorAll('.address-card').forEach(function (card) {
    card.addEventListener('click', function () {
      document.querySelectorAll('.address-card').forEach(function (c) { c.classList.remove('selected'); });
      this.classList.add('selected');
      var radio = this.querySelector('input[type="radio"]');
      if (radio) radio.checked = true;
    });
  });

  document.querySelectorAll('.payment-card').forEach(function (card) {
    card.addEventListener('click', function () {
      document.querySelectorAll('.payment-card').forEach(function (c) { c.classList.remove('selected'); });
      this.classList.add('selected');
      var radio = this.querySelector('input[type="radio"]');
      if (radio) radio.checked = true;
    });
  });

  document.getElementById('applySelectedCoupon').addEventListener('click', function () {
    var selected = document.querySelector("input[name='selectedCoupon']:checked");
    if (!selected) {
      Swal.fire({ icon: 'error', title: 'No Coupon Selected', text: 'Please choose a coupon before applying.' });
      return;
    }

    var discountType = selected.dataset.discounttype;
    var discountValue = parseFloat(selected.dataset.discountvalue);
    var minimumPurchase = parseFloat(selected.dataset.minimum);
    var maxDiscount = parseFloat(selected.dataset.maxdiscount) || 0;

    if (PRICE_AFTER_OFFERS < minimumPurchase) {
      Swal.fire({ icon: 'warning', title: 'Coupon Not Applicable', text: 'This coupon requires a minimum purchase of ₹' + minimumPurchase });
      return;
    }

    var discountAmount = discountType === 'Percentage'
      ? (PRICE_AFTER_OFFERS * discountValue) / 100
      : discountValue;
    
    if (discountType === 'Percentage' && maxDiscount > 0) {
      discountAmount = Math.min(discountAmount, maxDiscount);
    }

    var priceAfterCoupon = PRICE_AFTER_OFFERS - discountAmount;
    var newShipping = priceAfterCoupon >= 999 ? 0 : 100;
    var finalTotal = priceAfterCoupon + newShipping;

    document.querySelector('.price-summary').innerHTML = `
      <div class="price-row"><span>Subtotal</span><span>₹${SUBTOTAL.toFixed(2)}</span></div>
      <div class="price-row discount"><span>Offer Discount</span><span>−₹${OFFER_DISCOUNT.toFixed(2)}</span></div>
      <div class="price-row"><span>After Offers</span><span>₹${PRICE_AFTER_OFFERS.toFixed(2)}</span></div>
      <div class="price-row discount"><span>Coupon Discount</span><span>−₹${discountAmount.toFixed(2)}</span></div>
      <div class="price-row"><span>Shipping</span><span>${newShipping === 0 ? '<span style="color:#2e7d32;font-weight:600;">FREE</span>' : '₹' + newShipping.toFixed(2)}</span></div>
      <div class="price-row total"><span>Total</span><span>₹${finalTotal.toFixed(2)}</span></div>
      <div id="appliedCouponInfo">
        <span>Coupon Applied: ${selected.value}</span>
        <button type="button" id="removeCouponBtn" class="btn btn-sm btn-danger">Remove</button>
      </div>
    `;

    var hiddenInput = document.querySelector("input[name='couponCode']");
    if (!hiddenInput) {
      hiddenInput = document.createElement('input');
      hiddenInput.type = 'hidden';
      hiddenInput.name = 'couponCode';
      document.getElementById('checkoutForm').appendChild(hiddenInput);
    }
    hiddenInput.value = selected.value;

    checkWalletBalance();
    bootstrap.Modal.getInstance(document.getElementById('couponModal')).hide();
  });

  document.querySelector('.price-summary').addEventListener('click', function (e) {
    if (e.target && e.target.id === 'removeCouponBtn') {
      var newShipping = PRICE_AFTER_OFFERS >= 999 ? 0 : 100;
      var originalTotal = PRICE_AFTER_OFFERS + newShipping;

      document.querySelector('.price-summary').innerHTML = `
        <div class="price-row"><span>Subtotal</span><span>₹${SUBTOTAL.toFixed(2)}</span></div>
        <div class="price-row discount"><span>Offer Discount</span><span>−₹${OFFER_DISCOUNT.toFixed(2)}</span></div>
        <div class="price-row"><span>After Offers</span><span>₹${PRICE_AFTER_OFFERS.toFixed(2)}</span></div>
        <div class="price-row"><span>Shipping</span><span>${newShipping === 0 ? '<span style="color:#2e7d32;font-weight:600;">FREE</span>' : '₹' + newShipping.toFixed(2)}</span></div>
        <div class="price-row total"><span>Total</span><span>₹${originalTotal.toFixed(2)}</span></div>
      `;

      var hiddenInput = document.querySelector("input[name='couponCode']");
      if (hiddenInput) hiddenInput.remove();

      checkWalletBalance();
    }
  });

  document.querySelector('.btn-place-order').addEventListener('click', async function (e) {
    e.preventDefault();

    var submitBtn = this;
    var selectedPayment = document.querySelector('input[name="paymentMethod"]:checked');
    var selectedAddress = document.querySelector('input[name="addressId"]:checked');
    var couponCode = document.querySelector("input[name='couponCode']")?.value || null;

    if (!selectedAddress) {
      Swal.fire({ icon: 'error', title: 'No Address Selected', text: 'Please select a shipping address before placing your order.' });
      return;
    }

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Placing Order...';

    var paymentMethod = selectedPayment.value;

    try {
      if (paymentMethod === 'cod' || paymentMethod === 'wallet') {

        if (paymentMethod === 'wallet') {
          var walletBalance = parseFloat(document.getElementById('walletBalance').textContent);
          var totalAmount = parseFloat(document.querySelector('.price-row.total span:last-child').textContent.replace('₹', ''));
          if (walletBalance < totalAmount) {
            Swal.fire({ icon: 'error', title: 'Insufficient Balance', text: 'You do not have enough wallet balance for this order.' });
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="fas fa-lock"></i> Place Order';
            return;
          }
        }

        const response = await fetch('/place-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ addressId: selectedAddress.value, paymentMethod, couponCode })
        });

        const result = await response.json();
        if (result.success) {
          window.location.href = '/order-success/' + result.orderId;
        } else {
          throw new Error(result.message || 'Failed to place order');
        }

      }  else if (paymentMethod === 'razorpay') {
        const response = await fetch('/create-razorpay-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ addressId: selectedAddress.value, couponCode, paymentMethod: 'razorpay' })
        });
      
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Failed to create payment order');
      
        const options = {
          key: data.key,
          amount: data.amount,
          currency: data.currency,
          name: 'Glora',
          description: 'Order Payment',
          order_id: data.razorpayOrderId,
          handler: async function (response) {
            const verifyRes = await fetch('/verify-razorpay-payment', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                razorpay_payment_id: response.razorpay_payment_id,
                razorpay_order_id: response.razorpay_order_id,
                razorpay_signature: response.razorpay_signature,
                orderId: data.orderId
              })
            });
            const verifyData = await verifyRes.json();
            window.location.href = verifyData.redirectUrl;
          },
          prefill: { name: '<%= userName %>' },
          theme: { color: '#1A1A1A' },
          modal: {
            ondismiss: function () {
              submitBtn.disabled = false;
              submitBtn.innerHTML = '<i class="fas fa-lock"></i> Place Order';
            }
          }
        };
      
        const rzp = new Razorpay(options);
      
        rzp.on('payment.failed', function (response) {
          window.location.href = `/order-failed/${data.orderId}`;
        });
      
        rzp.open();
        return;
      }

    } catch (err) {
      console.error('Checkout error:', err);
      Swal.fire({ icon: 'error', title: 'Error', text: err.message || 'An error occurred. Please try again.' });
    } finally {
      if (paymentMethod !== 'razorpay') {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-lock"></i> Place Order';
      }
    }
  });
</script>

<%- include('../partials/user/footer') %>