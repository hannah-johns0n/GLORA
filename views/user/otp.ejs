<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify OTP — GLORA</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,400;0,600;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --glora-dark:   #1A1A1A;
      --glora-cream:  #FAF7F4;
      --glora-red:    #8B1A1A;
      --glora-gold:   #D4A96A;
      --glora-blush:  #F0EBE3;
      --glora-muted:  #6B6B6B;
      --glora-border: #E0D8D0;
    }

    body {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      font-family: 'Poppins', sans-serif;
      background: var(--glora-cream);
    }

    /* ── LEFT PANEL ─────────────────────────────────────── */
    .otp-left {
      background: var(--glora-dark);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 56px;
      position: relative;
      overflow: hidden;
    }

    .otp-left::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 30% 70%, rgba(139,26,26,0.25) 0%, transparent 65%),
                  radial-gradient(ellipse at 80% 20%, rgba(212,169,106,0.10) 0%, transparent 55%);
      pointer-events: none;
    }

    .otp-left__content {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 300px;
    }

    .otp-left__logo {
      font-family: 'Cormorant Garant', serif;
      font-size: 48px;
      font-weight: 600;
      letter-spacing: 8px;
      text-transform: uppercase;
      color: #fff;
      text-decoration: none;
      display: block;
      margin-bottom: 16px;
    }

    .otp-left__divider {
      width: 40px;
      height: 1px;
      background: var(--glora-gold);
      margin: 0 auto 28px;
      opacity: 0.7;
    }

    /* Big lock icon */
    .otp-left__icon {
      width: 80px;
      height: 80px;
      border: 1px solid rgba(212,169,106,0.25);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 28px;
    }

    .otp-left__icon i {
      font-size: 30px;
      color: var(--glora-gold);
      opacity: 0.7;
    }

    .otp-left__tagline {
      font-family: 'Cormorant Garant', serif;
      font-size: 20px;
      font-style: italic;
      color: rgba(255,255,255,0.50);
      line-height: 1.6;
    }

    .otp-left__note {
      margin-top: 20px;
      font-size: 10px;
      color: rgba(255,255,255,0.25);
      letter-spacing: 1px;
      line-height: 1.7;
    }

    /* ── RIGHT PANEL ────────────────────────────────────── */
    .otp-right {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 56px;
      background: var(--glora-cream);
    }

    .otp-form-wrap {
      width: 100%;
      max-width: 360px;
    }

    /* Heading */
    .otp-heading { margin-bottom: 32px; }

    .otp-heading__eyebrow {
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--glora-gold);
      margin-bottom: 10px;
    }

    .otp-heading__title {
      font-family: 'Cormorant Garant', serif;
      font-size: 30px;
      font-weight: 600;
      color: var(--glora-dark);
      letter-spacing: -0.5px;
      line-height: 1.1;
      margin-bottom: 12px;
    }

    .otp-heading__email {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      color: var(--glora-muted);
      background: var(--glora-blush);
      border: 1px solid var(--glora-border);
      padding: 8px 14px;
      letter-spacing: 0.3px;
    }

    .otp-heading__email i { font-size: 11px; color: var(--glora-gold); }

    /* Error */
    .otp-error {
      padding: 12px 16px;
      background: #fff0f0;
      border-left: 3px solid var(--glora-red);
      color: var(--glora-red);
      font-size: 12px;
      margin-bottom: 20px;
      line-height: 1.5;
    }

    /* OTP input */
    .otp-form { display: flex; flex-direction: column; gap: 20px; }

    .otp-field { display: flex; flex-direction: column; gap: 8px; }

    .otp-label {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--glora-dark);
    }

    .otp-input {
      width: 100%;
      padding: 16px 20px;
      border: 1px solid var(--glora-border);
      background: #fff;
      font-family: 'Poppins', sans-serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--glora-dark);
      letter-spacing: 10px;
      text-align: center;
      outline: none;
      border-radius: 0;
      transition: border-color 0.2s ease;
      -webkit-appearance: none;
    }

    .otp-input::placeholder {
      font-size: 14px;
      letter-spacing: 4px;
      color: #c0b8b0;
      font-weight: 400;
    }

    .otp-input:focus { border-color: var(--glora-dark); }

    /* Timer */
    .otp-timer-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 11px;
    }

    .otp-timer {
      display: flex;
      align-items: center;
      gap: 6px;
      color: var(--glora-muted);
    }

    .otp-timer i { font-size: 11px; color: var(--glora-gold); }

    #otpTimerDisplay {
      font-weight: 600;
      color: var(--glora-dark);
      font-variant-numeric: tabular-nums;
    }

    #otpTimerDisplay.expired { color: var(--glora-red); }

    /* Resend */
    .otp-resend {
      font-size: 11px;
      color: var(--glora-muted);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .otp-resend:not(.disabled):hover {
      color: var(--glora-red);
    }

    .otp-resend.disabled {
      color: var(--glora-border);
      pointer-events: none;
      cursor: not-allowed;
    }

    /* Submit */
    .otp-submit {
      width: 100%;
      padding: 14px;
      background: var(--glora-dark);
      color: #fff;
      border: none;
      font-family: 'Poppins', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s ease;
    }

    .otp-submit:hover { background: var(--glora-red); }

    /* Back link */
    .otp-back {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 10px;
      color: var(--glora-muted);
      text-decoration: none;
      letter-spacing: 1px;
      transition: color 0.2s ease;
      margin-top: 8px;
    }

    .otp-back:hover { color: var(--glora-dark); }

    /* ── RESPONSIVE ─────────────────────────────────────── */
    @media (max-width: 820px) {
      body { grid-template-columns: 1fr; }
      .otp-left { display: none; }
      .otp-right { padding: 60px 32px; min-height: 100vh; }
    }

    @media (max-width: 480px) {
      .otp-right { padding: 48px 24px; }
    }
  </style>
</head>
<body>

  <div class="otp-left">
    <div class="otp-left__content">
      <a href="/" class="otp-left__logo">GLORA</a>
      <div class="otp-left__divider"></div>

      <div class="otp-left__icon">
        <i class="fas fa-shield-alt"></i>
      </div>

      <p class="otp-left__tagline">Keeping your account<br>safe & secure</p>
      <p class="otp-left__note">
        We verify every account to protect<br>
        our community and your personal data.
      </p>
    </div>
  </div>

  <div class="otp-right">
    <div class="otp-form-wrap">

      <div class="otp-heading">
        <p class="otp-heading__eyebrow">
          <% if (purpose === 'reset') { %>Reset password
          <% } else if (purpose === 'changeEmail') { %>Change email
          <% } else { %>Email verification<% } %>
        </p>
        <h1 class="otp-heading__title">
          <% if (purpose === 'reset') { %>Reset Your Password
          <% } else if (purpose === 'changeEmail') { %>Verify New Email
          <% } else { %>Verify Your Email
          <% } %>
        </h1>
        <div class="otp-heading__email">
          <i class="fas fa-envelope"></i>
          <%= email %>
        </div>
      </div>

      <% if (error) { %>
        <div class="otp-error">
          <i class="fas fa-exclamation-circle" style="margin-right:6px;"></i><%= error %>
        </div>
      <% } %>

      <form
        action="<%
          if (purpose === 'reset') { %>/forgot-password/verify<%
          } else if (purpose === 'changeEmail') { %>/verify-change-email-otp<%
          } else { %>/verify-otp<% } %>"
        method="POST"
        class="otp-form"
      >
        <input type="hidden" name="email" value="<%= email %>">

        <div class="otp-field">
          <label class="otp-label" for="otp">One-Time Password</label>
          <input
            type="text"
            id="otp"
            name="otp"
            class="otp-input"
            placeholder="· · · · · ·"
            maxlength="6"
            minlength="4"
            pattern="[0-9]+"
            inputmode="numeric"
            autocomplete="one-time-code"
            required
          >
        </div>

        <div class="otp-timer-wrap">
          <div class="otp-timer">
            <i class="fas fa-clock"></i>
            <span>Expires in <span id="otpTimerDisplay">05:00</span></span>
          </div>
          <a
            id="resendLink"
            href="<%
              if (purpose === 'reset') { %>/resend-forgot-password-otp<%
              } else if (purpose === 'changeEmail') { %>/resend-change-email-otp<%
              } else { %>/resend-otp<% } %>"
            class="otp-resend disabled"
          >Resend OTP</a>
        </div>

        <button type="submit" class="otp-submit">
          <i class="fas fa-check" style="margin-right:8px;"></i>Verify & Continue
        </button>

      </form>

      <a href="/login" class="otp-back">
        <i class="fas fa-arrow-left"></i> Back to Sign In
      </a>

    </div>
  </div>

  <script>
    (function () {
      const display    = document.getElementById('otpTimerDisplay');
      const resendLink = document.getElementById('resendLink');
      let remaining    = <%= typeof expiresIn !== 'undefined' ? expiresIn : 300 %>;

      function update() {
        const m = String(Math.floor(remaining / 60)).padStart(2, '0');
        const s = String(remaining % 60).padStart(2, '0');

        if (remaining <= 0) {
          display.textContent = 'Expired';
          display.classList.add('expired');
          resendLink.classList.remove('disabled');
          return;
        }

        display.textContent = `${m}:${s}`;
        resendLink.classList.add('disabled');
        remaining--;
        setTimeout(update, 1000);
      }

      update();
    })();
  </script>

</body>

</html>
