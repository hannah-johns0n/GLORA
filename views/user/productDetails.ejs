<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.productName %> – GLORA</title>
  <link rel="stylesheet" href="/styles/bootstrap4/bootstrap.min.css">
  <link rel="stylesheet" href="/styles/main_styles.css">

  <style>
    body{background:#fafafa;font-family:'Poppins',sans-serif;}
    .product-wrapper{display:flex;flex-wrap:wrap;gap:40px;margin: 160px auto 0; max-width: 1400px; padding: 0 20px;}
    .img-column{flex:1 1 400px;max-width:500px;}
    .info-column{flex:1 1 300px;}
    .main-img-container{width:100%;padding-top:100%;position:relative;overflow:hidden;border-radius:8px;background:#fff;box-shadow:0 4px 12px rgba(0,0,0,.05);}
    .main-img-container img{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:contain;transition:transform .3s ease;}
    .main-img-container:hover img{transform:scale(1.6);cursor:zoom-in;}
    .thumbs{display:flex;gap:10px;margin-top:15px;}
    .thumbs img{width:70px;height:70px;object-fit:cover;border-radius:6px;border:2px solid transparent;cursor:pointer;}
    .thumbs img.active,.thumbs img:hover{border-color:#471710;}
    .rating-stars{color:#000000;font-size:1.2rem;}
    .price{font-weight:600;font-size:1.5rem;color:#a44b3e;}
    .price .original{font-size:1rem;text-decoration:line-through;color:#999;margin-left:8px;}
    .btn-add{background:#6b2c22;color:#fff;padding:.6rem 1.5rem;border:none;border-radius:6px;margin-top:20px;}
  </style>
</head>

<body>

<%- include('../partials/user/header',{ userName:userName, cartCount: cartCount }) %>

<div class="container">
  <div class="product-wrapper">

    <!-- IMAGES -->
    <div class="img-column">
      <div class="main-img-container">
        <img id="mainImage" src="<%= product.images && product.images.length ? '/uploads/products/' + product.images[0] : '/images/placeholder-product.jpg' %>">
      </div>

      <div class="thumbs">
        <% product.images.slice(0,4).forEach(function(img,idx){ %>
          <img class="thumbnail <%= idx===0 ? 'active' : '' %>" src="/uploads/products/<%= img %>">
        <% }); %>
      </div>
    </div>

    <!-- INFO -->
    <div class="info-column">

      <h2><%= product.productName %></h2>

      <!-- RATING -->
      <div class="rating-stars mb-2">
        <% const rating=(product.rating||4); for(let i=1;i<=5;i++){ %>
          <% if(i<=rating){ %>
            <i class="fa fa-star"></i>
          <% } else { %>
            <i class="fa fa-star-o"></i>
          <% } %>
        <% } %>
      </div>

      <!-- VARIANTS -->
      <% if (product.variants && product.variants.length > 0) { %>
        <div class="mt-3">
          <label><strong>Select Variant:</strong></label>

          <select id="variantSelect" class="form-control mt-2">
            <% product.variants.forEach((v, index) => { %>
              <option value="<%= index %>">
                <%= v.unit %> (₹<%= v.salesPrice > 0 ? v.salesPrice : v.regularPrice %>)
              </option>
            <% }) %>
          </select>
        </div>
      <% } %>

      <!-- PRICE -->
      <div class="price mt-3" id="priceBox"></div>

      <!-- DESCRIPTION -->
      <p class="mt-3"><%= product.description %></p>

      <!-- BUTTONS -->
      <button id="addToCartBtn" class="btn-add" data-id="<%= product._id %>">
        Add to Cart
      </button>

      <button id="addToWishlistBtn" class="btn-add" style="background:#471710;">
        Add to Wishlist
      </button>

    </div>
  </div>
</div>

<%- include('../partials/user/footer') %>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
/* ---------------- IMAGE SWITCH ---------------- */
document.querySelectorAll('.thumbnail').forEach(thumb => {
  thumb.addEventListener('click', function() {
    document.getElementById('mainImage').src = this.src;
    document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
  });
});

/* ---------------- VARIANT LOGIC ---------------- */
const variants = <%- JSON.stringify(product.variants || []) %>;

function updatePrice(index) {
  const v = variants[index];

  document.getElementById("priceBox").innerHTML = `
    ₹${v.salesPrice > 0 ? v.salesPrice : v.regularPrice}
    ${v.salesPrice > 0 ? `<span class="original">₹${v.regularPrice}</span>` : ''}
  `;
}

// default load
if (variants.length > 0) {
  updatePrice(0);
}

const variantSelect = document.getElementById("variantSelect");

if (variantSelect) {
  variantSelect.addEventListener("change", function() {
    updatePrice(this.value);
  });
}

/* ---------------- ADD TO CART ---------------- */
document.getElementById('addToCartBtn').addEventListener('click', async function() {

  const productId = this.getAttribute('data-id');
  const selectedVariantIndex = document.getElementById("variantSelect")?.value || 0;

  this.disabled = true;
  this.innerText = "Adding...";

  try {
    const res = await fetch(`/cart/add/${productId}`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        variantIndex: selectedVariantIndex
      })
    });

    const data = await res.json();

    if (res.ok) {
      Swal.fire("Added!", "Product added to cart", "success");
    } else {
      throw new Error(data.message);
    }

  } catch (err) {
    Swal.fire("Error", err.message, "error");
  }

  this.disabled = false;
  this.innerText = "Add to Cart";
});

/* ---------------- WISHLIST ---------------- */
document.getElementById('addToWishlistBtn').addEventListener('click', async function() {

  const productId = '<%= product._id %>';

  try {
    const res = await fetch(`/wishlist/add/${productId}`, { method: "POST" });
    const data = await res.json();

    if (res.ok) {
      Swal.fire("Added!", data.message, "success");
    } else {
      throw new Error(data.message);
    }

  } catch (err) {
    Swal.fire("Error", err.message, "error");
  }

});
</script>

</body>
</html>