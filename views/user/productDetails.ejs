<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.productName %> – GLORA</title>
  <link rel="stylesheet" href="/styles/bootstrap4/bootstrap.min.css">
  <link rel="stylesheet" href="/styles/main_styles.css">

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Lora:wght@400;500;600&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #ffffff;
      font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: #2c2c2c;
      line-height: 1.6;
    }

    .product-section {
      max-width: 1300px;
      margin: 80px auto 0;
      padding: 0 20px 60px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: start;
    }

    /* ── IMAGE GALLERY ─────────────────────────────────────────────── */
    .gallery-column { display: flex; flex-direction: column; gap: 12px; }
    .main-img-container {
      width: 100%;
      aspect-ratio: 1;
      background: #f9f9f9;
      border-radius: 12px;
      overflow: hidden;
      position: relative;
    }
    .main-img-container img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      transition: transform 0.4s cubic-bezier(0.33, 0.66, 0.66, 1);
    }
    .main-img-container:hover img { transform: scale(1.05); }

    .thumbnails {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }
    .thumbnail {
      width: 100%;
      aspect-ratio: 1;
      border-radius: 8px;
      background: #f5f5f5;
      border: 2px solid transparent;
      cursor: pointer;
      overflow: hidden;
      transition: all 0.3s ease;
    }
    .thumbnail img { width: 100%; height: 100%; object-fit: cover; }
    .thumbnail:hover, .thumbnail.active {
      border-color: #8b6a47;
      box-shadow: 0 4px 12px rgba(139, 106, 71, 0.12);
    }

    /* ── INGREDIENTS SECTION ──────────────────────────────────────── */
    .ingredients-section {
      margin-top: 24px;
      padding: 16px;
      background: #fafafa;
      border-radius: 10px;
      border-left: 3px solid #8b6a47;
    }
    .ingredients-section h4 {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #666;
      margin-bottom: 12px;
      font-family: 'Poppins', sans-serif;
    }
    .ingredients-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .ingredient-tag {
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 20px;
      padding: 6px 12px;
      font-size: 0.85rem;
      color: #555;
      font-weight: 400;
    }

    /* ── PRODUCT INFO ──────────────────────────────────────────────── */
    .info-column { display: flex; flex-direction: column; }

    .product-header { margin-bottom: 24px; }
    .product-header h1 {
      font-size: 2.2rem;
      font-weight: 600;
      letter-spacing: -0.7px;
      margin-bottom: 12px;
      font-family: 'Lora', serif;
      color: #1a1a1a;
    }

    .rating-bar {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.9rem;
      color: #666;
      font-weight: 500;
    }
    .stars {
      color: #ffc107;
      letter-spacing: 2px;
    }

    .price-section {
      margin: 24px 0;
      padding-bottom: 20px;
      border-bottom: 1px solid #f0f0f0;
    }
    .price-display {
      display: flex;
      align-items: baseline;
      gap: 12px;
    }
    .current-price {
      font-size: 2rem;
      font-weight: 700;
      color: #2c2c2c;
      font-family: 'Poppins', sans-serif;
      letter-spacing: -0.5px;
    }
    .original-price {
      font-size: 1.1rem;
      color: #999;
      text-decoration: line-through;
      font-weight: 500;
    }

    .description {
      font-size: 0.95rem;
      color: #555;
      line-height: 1.8;
      margin-bottom: 28px;
      font-weight: 400;
      letter-spacing: 0.3px;
    }

    /* ── VARIANT SELECTORS ────────────────────────────────────────── */
    .variant-selector {
      margin-bottom: 28px;
    }
    .variant-label {
      display: block;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #666;
      margin-bottom: 14px;
      font-family: 'Poppins', sans-serif;
    }

    .variant-options {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .variant-box {
      padding: 10px 18px;
      border: 2px solid #e0e0e0;
      background: #fff;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 0.9rem;
      font-weight: 500;
      color: #555;
      display: flex;
      align-items: center;
      justify-content: center;
      min-width: 100px;
      text-align: center;
    }

    .variant-box:hover {
      border-color: #8b6a47;
      background: #fafafa;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(139, 106, 71, 0.1);
    }

    .variant-box.active {
      border-color: #8b6a47;
      background: #8b6a47;
      color: #fff;
      box-shadow: 0 6px 16px rgba(139, 106, 71, 0.3);
    }

    /* ── QUANTITY & BUTTONS ────────────────────────────────────────── */
    .controls {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 12px;
      margin-bottom: 28px;
    }

    .quantity-selector {
      display: flex;
      border: 1px solid #e0e0e0;
      border-radius: 6px;
      width: fit-content;
    }
    .qty-btn {
      width: 40px;
      height: 40px;
      border: none;
      background: #fff;
      cursor: pointer;
      font-size: 1rem;
      transition: all 0.2s ease;
      color: #666;
      font-weight: 600;
    }
    .qty-btn:hover { background: #f5f5f5; }
    .qty-input {
      width: 50px;
      border: none;
      text-align: center;
      font-weight: 600;
      background: #fff;
      font-size: 0.95rem;
    }

    .btn-primary-action {
      background: #2c2c2c;
      color: #fff;
      padding: 14px 40px;
      border: none;
      border-radius: 6px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      min-height: 48px;
      letter-spacing: 0.3px;
      text-transform: uppercase;
      font-size: 0.85rem;
    }
    .btn-primary-action:hover {
      background: #1a1a1a;
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(44, 44, 44, 0.2);
    }
    .btn-primary-action:active {
      transform: translateY(0);
    }

    .action-buttons {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .btn-secondary {
      flex: 1;
      min-width: 120px;
      border: 2px solid #2c2c2c;
      background: #fff;
      color: #2c2c2c;
      padding: 12px 20px;
      border-radius: 6px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      letter-spacing: 0.2px;
    }
    .btn-secondary:hover {
      background: #f5f5f5;
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(44, 44, 44, 0.1);
    }

    .btn-wishlist {
      width: 48px;
      height: 48px;
      border-radius: 6px;
      border: 2px solid #e0e0e0;
      background: #fff;
      cursor: pointer;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
      color: #666;
    }
    .btn-wishlist:hover {
      border-color: #8b6a47;
      color: #8b6a47;
      transform: scale(1.05);
    }

    /* ── SIMILAR PRODUCTS ──────────────────────────────────────────── */
    .similar-section {
      max-width: 1300px;
      margin: 80px auto 0;
      padding: 0 20px 60px;
    }

    .section-title {
      font-size: 1.8rem;
      font-weight: 600;
      margin-bottom: 32px;
      letter-spacing: -0.5px;
      font-family: 'Lora', serif;
      color: #1a1a1a;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 24px;
    }

    .product-card {
      background: #fff;
      border-radius: 8px;
      overflow: hidden;
      transition: all 0.3s ease;
      border: 1px solid transparent;
    }
    .product-card:hover {
      border-color: #e0e0e0;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    }

    .card-image {
      width: 100%;
      aspect-ratio: 1;
      background: #f5f5f5;
      overflow: hidden;
      position: relative;
    }
    .card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .product-card:hover .card-image img {
      transform: scale(1.05);
    }

    .card-wishlist-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 36px;
      height: 36px;
      background: #fff;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      transition: all 0.2s ease;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      color: #666;
    }
    .card-wishlist-btn:hover {
      transform: scale(1.1);
      color: #8b6a47;
    }

    .card-content {
      padding: 16px;
    }

    .card-title {
      font-size: 0.95rem;
      font-weight: 500;
      margin-bottom: 8px;
      color: #2c2c2c;
      line-height: 1.4;
      min-height: 2.8em;
    }

    .card-price {
      font-size: 1.1rem;
      font-weight: 700;
      color: #2c2c2c;
    }

    /* ── RESPONSIVE ────────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .product-section {
        grid-template-columns: 1fr;
        gap: 40px;
        margin: 60px auto 0;
      }
      .product-header h1 {
        font-size: 1.8rem;
      }
      .current-price {
        font-size: 1.6rem;
      }
      .controls {
        grid-template-columns: 1fr;
      }
      .action-buttons {
        flex-direction: column;
      }
      .btn-secondary {
        min-width: unset;
      }
      .products-grid {
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 16px;
      }
      .variant-box {
        padding: 10px 14px;
        font-size: 0.85rem;
      }
    }
  </style>
</head>

<body>

<%- include('../partials/user/header', { userName: userName, cartCount: cartCount }) %>

<!-- PRODUCT DETAIL -->
<div class="product-section">
  <!-- IMAGE GALLERY -->
  <div class="gallery-column">
    <div class="main-img-container">
      <img id="mainImage" src="<%= product.images && product.images.length ? product.images[0] : '/images/placeholder-product.jpg' %>" alt="<%= product.productName %>">
    </div>

    <div class="thumbnails">
      <% product.images.slice(0, 4).forEach(function(img, idx) { %>
        <div class="thumbnail <%= idx === 0 ? 'active' : '' %>" data-src="<%= img %>">
          <img src="<%= img %>" alt="Product image <%= idx + 1 %>">
        </div>
      <% }); %>
    </div>

    <!-- INGREDIENTS -->
    <% if (product.ingredients && product.ingredients.length > 0) { %>
      <div class="ingredients-section">
        <h4>Ingredients</h4>
        <div class="ingredients-list">
          <% product.ingredients.forEach(function(ingredient) { %>
            <span class="ingredient-tag"><%= ingredient %></span>
          <% }); %>
        </div>
      </div>
    <% } %>
  </div>

  <!-- PRODUCT INFO -->
  <div class="info-column">
    <div class="product-header">
      <h1><%= product.productName %></h1>
      <div class="rating-bar">
        <div class="stars">
          <% var rating = (product.rating || 4); %>
          <% for (var i = 1; i <= 5; i++) { %>
            <% if (i <= rating) { %>
              <i class="fa fa-star"></i>
            <% } else { %>
              <i class="fa fa-star-o"></i>
            <% } %>
          <% } %>
        </div>
        <span>(<%= rating %>/5)</span>
      </div>
    </div>

    <div class="price-section">
      <div class="price-display">
        <div class="current-price" id="priceDisplay">₹0</div>
        <div class="original-price" id="originalPriceDisplay"></div>
      </div>
    </div>

    <p class="description"><%= product.description %></p>

    <!-- VARIANT SELECT -->
    <% if (product.variants && product.variants.length > 0) { %>
      <div class="variant-selector">
        <label class="variant-label">Select Variant</label>
        <div class="variant-options">
          <% product.variants.forEach(function(v, index) { %>
            <button class="variant-box <%= index === 0 ? 'active' : '' %>" data-variant-index="<%= index %>" onclick="selectVariant('<%= index %>')">
              <%= v.unit %><br><span style="font-size: 0.75rem; opacity: 0.8;">₹<%= v.salesPrice > 0 ? v.salesPrice : v.regularPrice %></span>
            </button>
          <% }); %>
        </div>
      </div>
      <input type="hidden" id="variantSelect" value="0">
    <% } %>

    <!-- QUANTITY & ACTIONS -->
    <div class="controls">
      <div class="quantity-selector">
        <button class="qty-btn" id="decreaseQty">−</button>
        <input type="number" id="quantityInput" class="qty-input" value="1" min="1" readonly>
        <button class="qty-btn" id="increaseQty">+</button>
      </div>
    </div>

    <div class="action-buttons">
      <button id="buyNowBtn" class="btn-primary-action" data-id="<%= product._id %>">
        Buy Now
      </button>
      <button id="addToCartBtn" class="btn-secondary" data-id="<%= product._id %>">
        <i class="fa fa-shopping-bag"></i> Add to Cart
      </button>
      <button id="addToWishlistBtn" class="btn-wishlist" title="Add to Wishlist">
        <i class="fa fa-heart-o"></i>
      </button>
    </div>
  </div>
</div>

<!-- SIMILAR PRODUCTS -->
<div class="similar-section">
  <h2 class="section-title">Similar Products</h2>
  <div class="products-grid" id="similarProductsGrid">
    <% if (similarProducts && similarProducts.length > 0) { %>
      <% similarProducts.forEach(function(p) { %>
        <div class="product-card">
          <div class="card-image">
            <img src="<%= p.images && p.images[0] ? p.images[0] : '/images/placeholder-product.jpg' %>" alt="<%= p.productName %>">
            <button class="card-wishlist-btn" data-product-id="<%= p._id %>" onclick="addToWishlist('<%= p._id %>')">
              <i class="fa fa-heart-o"></i>
            </button>
          </div>
          <div class="card-content">
            <h3 class="card-title"><a href="/product/<%= p._id %>" style="text-decoration: none; color: #2c2c2c;"><%= p.productName %></a></h3>
            <div class="card-price">₹<%= p.variants && p.variants[0] ? (p.variants[0].salesPrice > 0 ? p.variants[0].salesPrice : p.variants[0].regularPrice) : 0 %></div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <p style="color: #999; padding: 20px;">No similar products found</p>
    <% } %>
  </div>
</div>

<%- include('../partials/user/footer') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
const variants = <%- JSON.stringify(product.variants || []) %>;
const variantSelect = document.getElementById('variantSelect');
const quantityInput = document.getElementById('quantityInput');

function updatePrice(index) {
  const v = variants[index];
  if (!v) return;
  const current = v.salesPrice > 0 ? v.salesPrice : v.regularPrice;
  document.getElementById('priceDisplay').textContent = '₹' + current;

  if (v.salesPrice > 0) {
    document.getElementById('originalPriceDisplay').textContent = '₹' + v.regularPrice;
  } else {
    document.getElementById('originalPriceDisplay').textContent = '';
  }
}

function selectVariant(index) {
  variantSelect.value = index;
  document.querySelectorAll('.variant-box').forEach(box => box.classList.remove('active'));
  document.querySelector(`[data-variant-index="${index}"]`).classList.add('active');
  updatePrice(index);
}

if (variants.length > 0) updatePrice(0);

// ── THUMBNAILS ─────────────────────────────────────────────────────
document.querySelectorAll('.thumbnail').forEach(function(thumb) {
  thumb.addEventListener('click', function() {
    document.getElementById('mainImage').src = this.dataset.src;
    document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
  });
});

// ── QUANTITY CONTROLS ─────────────────────────────────────────────
document.getElementById('decreaseQty').addEventListener('click', function() {
  const val = parseInt(quantityInput.value) || 1;
  if (val > 1) quantityInput.value = val - 1;
});

document.getElementById('increaseQty').addEventListener('click', function() {
  const val = parseInt(quantityInput.value) || 1;
  quantityInput.value = val + 1;
});

// ── ADD TO CART ────────────────────────────────────────────────────
document.getElementById('addToCartBtn').addEventListener('click', async function() {
  const productId = this.getAttribute('data-id');
  const variantIdx = variantSelect ? Number(variantSelect.value) : 0;
  const qty = parseInt(quantityInput.value) || 1;
  const btnText = this.textContent;

  this.disabled = true;
  this.textContent = 'Adding...';

  try {
    const response = await fetch('/cart/add/' + productId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ variantIndex: variantIdx, quantity: qty })
    });

    const result = await response.json();

    if (response.ok) {
      Swal.fire({ icon: 'success', title: 'Added!', text: 'Product added to cart' });
      const cartCountEl = document.querySelector('.cart-count');
      if (cartCountEl) cartCountEl.textContent = result.cartCount || 0;
    } else {
      throw new Error(result.message || 'Failed to add to cart');
    }
  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Error', text: err.message });
  } finally {
    this.disabled = false;
    this.textContent = btnText;
  }
});

// ── BUY NOW ────────────────────────────────────────────────────────
document.getElementById('buyNowBtn').addEventListener('click', async function() {
  const productId = this.getAttribute('data-id');
  const variantIdx = variantSelect ? Number(variantSelect.value) : 0;
  const qty = parseInt(quantityInput.value) || 1;

  try {
    const response = await fetch('/cart/add/' + productId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ variantIndex: variantIdx, quantity: qty })
    });

    if (response.ok) {
      window.location.href = '/checkout';
    } else {
      const result = await response.json();
      throw new Error(result.message || 'Failed to add to cart');
    }
  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Error', text: err.message });
  }
});

// ── WISHLIST ───────────────────────────────────────────────────────
document.getElementById('addToWishlistBtn').addEventListener('click', async function() {
  const productId = '<%= product._id %>';
  const icon = this.querySelector('i');
  const wasActive = icon.classList.contains('fa-heart');

  try {
    const res = await fetch('/wishlist/add/' + productId, { method: 'POST' });
    const data = await res.json();

    if (res.ok) {
      icon.classList.toggle('fa-heart-o', wasActive);
      icon.classList.toggle('fa-heart', !wasActive);
      Swal.fire({ icon: 'success', title: 'Done!', text: data.message });
    } else {
      throw new Error(data.message);
    }
  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Error', text: err.message });
  }
});

function addToWishlist(productId) {
  event.stopPropagation();
  const btn = event.currentTarget;
  const icon = btn.querySelector('i');

  fetch('/wishlist/add/' + productId, { method: 'POST' })
    .then(res => res.json())
    .then(data => {
      if (data.success || data.message) {
        icon.classList.toggle('fa-heart-o');
        icon.classList.toggle('fa-heart');
      }
    })
    .catch(err => console.error(err));
}
</script>

</body>
</html>