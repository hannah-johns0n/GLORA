<%- include('../partials/user/header', { userName: user?.name || 'User', url: '/profile' }) %>

<style>
  /* ── BASE ───────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --glora-dark:   #1A1A1A;
    --glora-cream:  #FAF7F4;
    --glora-red:    #8B1A1A;
    --glora-gold:   #D4A96A;
    --glora-blush:  #F0EBE3;
    --glora-muted:  #6B6B6B;
    --glora-border: #E0D8D0;
  }

  body {
    background: var(--glora-cream);
    font-family: 'Poppins', sans-serif;
    color: var(--glora-dark);
  }

  /* ── PAGE WRAPPER ───────────────────────────────────── */
  .glora-account {
    min-height: calc(100vh - 72px);
    background: var(--glora-cream);
    padding: 60px 0 100px;
    margin-top: 72px;
  }

  .glora-account__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ── PAGE HEADING ───────────────────────────────────── */
  .glora-account__heading {
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--glora-border);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .glora-account__eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  .glora-account__title {
    font-family: 'Cormorant Garant', serif;
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: -0.5px;
    line-height: 1;
  }

  /* ── LAYOUT ─────────────────────────────────────────── */
  .glora-account__layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 32px;
    align-items: start;
  }

  /* ════════════════════════════════════════════════════
     SHARED SIDEBAR  (same across all profile pages)
  ════════════════════════════════════════════════════ */
  .glora-sidebar {
    background: #fff;
    border: 1px solid var(--glora-border);
    position: sticky;
    top: 92px;
  }

  .glora-sidebar__user {
    padding: 28px 24px 20px;
    border-bottom: 1px solid rgba(26,26,26,0.07);
    text-align: center;
  }

  .glora-sidebar__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--glora-blush);
    border: 2px solid var(--glora-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
  }

  .glora-sidebar__avatar i {
    font-size: 22px;
    color: var(--glora-muted);
  }

  .glora-sidebar__name {
    font-family: 'Cormorant Garant', serif;
    font-size: 17px;
    font-weight: 600;
    color: var(--glora-dark);
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .glora-sidebar__label {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  .glora-sidebar__nav {
    padding: 12px 0;
  }

  .glora-sidebar__nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 24px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    color: var(--glora-muted);
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
    position: relative;
  }

  .glora-sidebar__nav-item::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: var(--glora-red);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .glora-sidebar__nav-item:hover {
    background: var(--glora-cream);
    color: var(--glora-dark);
    text-decoration: none;
  }

  .glora-sidebar__nav-item.active {
    background: var(--glora-cream);
    color: var(--glora-dark);
    font-weight: 600;
  }

  .glora-sidebar__nav-item.active::before { opacity: 1; }

  .glora-sidebar__nav-item i {
    font-size: 13px;
    width: 16px;
    text-align: center;
    flex-shrink: 0;
    color: var(--glora-muted);
    transition: color 0.2s ease;
  }

  .glora-sidebar__nav-item:hover i,
  .glora-sidebar__nav-item.active i {
    color: var(--glora-red);
  }

  .glora-sidebar__footer {
    padding: 12px 16px 20px;
    border-top: 1px solid rgba(26,26,26,0.07);
  }

  .glora-sidebar__logout {
    display: block;
    width: 100%;
    padding: 10px;
    background: none;
    border: 1px solid rgba(26,26,26,0.15);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-muted);
    cursor: pointer;
    font-family: 'Poppins', sans-serif;
    transition: all 0.2s ease;
    text-align: center;
  }

  .glora-sidebar__logout:hover {
    background: var(--glora-dark);
    border-color: var(--glora-dark);
    color: #fff;
  }

  /* ════════════════════════════════════════════════════
     MAIN PANEL
  ════════════════════════════════════════════════════ */
  .glora-panel {
    background: #fff;
    border: 1px solid var(--glora-border);
    padding: 40px 44px;
  }

  .glora-panel__heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--glora-border);
  }

  .glora-panel__eyebrow {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--glora-gold);
    margin-bottom: 6px;
  }

  .glora-panel__title {
    font-family: 'Cormorant Garant', serif;
    font-size: 26px;
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: -0.3px;
  }

  /* ── FORM FIELDS ────────────────────────────────────── */
  .glora-form { max-width: 500px; }

  .glora-form__group { margin-bottom: 26px; }

  .glora-form__label {
    display: block;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-dark);
    margin-bottom: 10px;
  }

  .glora-form__input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--glora-border);
    background: var(--glora-cream);
    font-size: 13px;
    font-family: 'Poppins', sans-serif;
    color: var(--glora-dark);
    outline: none;
    border-radius: 0;
    transition: border-color 0.2s ease, background 0.2s ease;
    -webkit-appearance: none;
  }

  .glora-form__input:focus {
    border-color: var(--glora-dark);
    background: #fff;
  }

  .glora-form__input.is-invalid {
    border-color: #c0392b;
    background: #fff8f8;
  }

  .glora-form__input.is-valid {
    border-color: #27ae60;
    background: #f8fff9;
  }

  .glora-form__input[readonly] {
    background: rgba(26,26,26,0.04);
    color: var(--glora-muted);
    cursor: not-allowed;
  }

  .glora-form__input[readonly]:focus {
    border-color: var(--glora-border);
    background: rgba(26,26,26,0.04);
  }

  .glora-form__error {
    font-size: 10px;
    color: #c0392b;
    letter-spacing: 0.3px;
    margin-top: 6px;
    display: block;
    min-height: 14px;
  }

  .glora-form__hint {
    font-size: 10px;
    color: var(--glora-muted);
    letter-spacing: 0.3px;
    margin-top: 6px;
    display: block;
  }

  /* ── ALERT ──────────────────────────────────────────── */
  .glora-alert {
    padding: 14px 18px;
    margin-bottom: 28px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 12px;
    letter-spacing: 0.3px;
    line-height: 1.5;
  }

  .glora-alert i { font-size: 14px; flex-shrink: 0; margin-top: 1px; }

  .glora-alert--success {
    background: #f0faf3;
    border-left: 3px solid #27ae60;
    color: #1e6e40;
  }
  .glora-alert--success i { color: #27ae60; }

  .glora-alert--danger {
    background: #fff5f5;
    border-left: 3px solid #c0392b;
    color: var(--glora-red);
  }
  .glora-alert--danger i { color: #c0392b; }

  /* ── ACTIONS ────────────────────────────────────────── */
  .glora-form__actions {
    display: flex;
    gap: 12px;
    margin-top: 36px;
    padding-top: 28px;
    border-top: 1px solid var(--glora-border);
  }

  .glora-btn {
    padding: 13px 28px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    border: none;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-decoration: none;
  }

  .glora-btn--primary {
    background: var(--glora-dark);
    color: #fff;
    flex: 1;
  }

  .glora-btn--primary:hover {
    background: var(--glora-red);
    color: #fff;
    text-decoration: none;
  }

  .glora-btn--primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .glora-btn--ghost {
    background: none;
    border: 1px solid var(--glora-border);
    color: var(--glora-muted);
    text-decoration: none;
  }

  .glora-btn--ghost:hover {
    border-color: var(--glora-dark);
    color: var(--glora-dark);
    text-decoration: none;
  }

  /* Spinner */
  .glora-spinner {
    width: 12px;
    height: 12px;
    border: 2px solid rgba(255,255,255,0.4);
    border-top-color: #fff;
    border-radius: 50%;
    animation: glora-spin 0.6s linear infinite;
    display: none;
  }

  @keyframes glora-spin { to { transform: rotate(360deg); } }

  /* ── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .glora-account__layout { grid-template-columns: 1fr; }
    .glora-sidebar { position: static; }
    .glora-sidebar__nav { display: grid; grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 640px) {
    .glora-account__container { padding: 0 20px; }
    .glora-panel { padding: 28px 20px; }
    .glora-form__actions { flex-direction: column; }
    .glora-sidebar__nav { grid-template-columns: 1fr; }
  }
</style>

<div class="glora-account">
  <div class="glora-account__container">

    <div class="glora-account__heading">
      <span class="glora-account__eyebrow">Your account</span>
      <h1 class="glora-account__title">My Profile</h1>
    </div>

    <% if (!user) { %>
      <div class="glora-alert glora-alert--danger">
        <i class="fas fa-exclamation-circle"></i>
        <span>You need to be logged in to view this page. <a href="/login" style="color:var(--glora-red);">Sign in here</a></span>
      </div>
    <% } else { %>

    <div class="glora-account__layout">

      <!-- ══ SHARED SIDEBAR ══════════════════════════════ -->
      <aside class="glora-sidebar">
        <div class="glora-sidebar__user">
          <div class="glora-sidebar__avatar">
            <i class="fas fa-user"></i>
          </div>
          <p class="glora-sidebar__name"><%= user.name || 'User' %></p>
          <span class="glora-sidebar__label">Member</span>
        </div>

        <nav class="glora-sidebar__nav">
          <a href="/profile" class="glora-sidebar__nav-item active">
            <i class="fas fa-user"></i> My Account
          </a>
          <a href="/my-orders" class="glora-sidebar__nav-item">
            <i class="fas fa-box"></i> My Orders
          </a>
          <a href="/manage-address" class="glora-sidebar__nav-item">
            <i class="fas fa-map-marker-alt"></i> Addresses
          </a>
          <a href="/wallet" class="glora-sidebar__nav-item">
            <i class="fas fa-wallet"></i> Wallet
          </a>
          <a href="/wishlist" class="glora-sidebar__nav-item">
            <i class="fas fa-heart"></i> Wishlist
          </a>
          <a href="/add-account" class="glora-sidebar__nav-item">
            <i class="fas fa-link"></i> Linked Accounts
          </a>
        </nav>

        <div class="glora-sidebar__footer">
          <form action="/logout" method="POST">
            <button type="submit" class="glora-sidebar__logout">
              <i class="fas fa-sign-out-alt" style="margin-right:6px;"></i>Log Out
            </button>
          </form>
        </div>
      </aside>

      <!-- ══ EDIT PANEL ══════════════════════════════════ -->
      <div class="glora-panel">
        <div class="glora-panel__heading">
          <div>
            <p class="glora-panel__eyebrow">Personal details</p>
            <h2 class="glora-panel__title">Edit Information</h2>
          </div>
        </div>

        <div id="alertContainer" style="display:none;"></div>

        <form id="profileForm" class="glora-form" novalidate>

          <div class="glora-form__group">
            <label class="glora-form__label" for="name">Full Name</label>
            <input
              type="text"
              id="name"
              name="name"
              class="glora-form__input"
              value="<%= user.name || '' %>"
              placeholder="Your full name"
              autocomplete="name"
            >
            <span id="nameError" class="glora-form__error"></span>
          </div>

          <div class="glora-form__group">
            <label class="glora-form__label" for="phoneNumber">Mobile Number</label>
            <input
              type="text"
              id="phoneNumber"
              name="phoneNumber"
              class="glora-form__input"
              value="<%= user.phoneNumber || '' %>"
              placeholder="10-digit mobile number"
              autocomplete="tel"
            >
            <span id="phoneNumberError" class="glora-form__error"></span>
          </div>

          <div class="glora-form__group">
            <label class="glora-form__label" for="email">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              class="glora-form__input"
              value="<%= user.email || '' %>"
              readonly
              autocomplete="email"
            >
            <span class="glora-form__hint">Email cannot be changed here</span>
            <span id="emailError" class="glora-form__error"></span>
          </div>

          <div class="glora-form__actions">
            <a href="/profile" class="glora-btn glora-btn--ghost">Cancel</a>
            <button type="submit" id="saveBtn" class="glora-btn glora-btn--primary">
              <span id="saveText">Save Changes</span>
              <span id="saveSpinner" class="glora-spinner"></span>
            </button>
          </div>

        </form>
      </div>

    </div>
    <% } %>
  </div>
</div>

<%- include('../partials/user/footer') %>

<script>
  function validateName(v) {
    if (!v || !v.trim()) return 'Name is required';
    if (v.trim().length < 2) return 'Name must be at least 2 characters';
    if (!/^[a-zA-Z\s]+$/.test(v.trim())) return 'Name can only contain letters and spaces';
    return null;
  }

  function validatePhone(v) {
    if (!v || !v.trim()) return 'Mobile number is required';
    const clean = v.replace(/\D/g, '');
    if (clean.length < 10) return 'Must be at least 10 digits';
    if (clean.length > 15) return 'Cannot exceed 15 digits';
    return null;
  }

  function validateEmail(v) {
    if (!v || !v.trim()) return 'Email is required';
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) return 'Enter a valid email address';
    return null;
  }

  function setFieldState(id, errorMsg) {
    const input   = document.getElementById(id);
    const errorEl = document.getElementById(id + 'Error');
    if (!input) return;
    input.classList.toggle('is-invalid', !!errorMsg);
    input.classList.toggle('is-valid',   !errorMsg && input.value.trim() !== '');
    if (errorEl) errorEl.textContent = errorMsg || '';
  }

  function showAlert(message, type) {
    const el   = document.getElementById('alertContainer');
    const icon = type === 'success' ? 'fas fa-check-circle' : 'fas fa-exclamation-circle';
    el.innerHTML = `
      <div class="glora-alert glora-alert--${type}">
        <i class="${icon}"></i>
        <span>${message}</span>
      </div>`;
    el.style.display = 'block';
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    if (type === 'success') setTimeout(() => { el.style.display = 'none'; }, 5000);
  }

  document.getElementById('name').addEventListener('input', function () {
    setFieldState('name', validateName(this.value));
  });

  document.getElementById('phoneNumber').addEventListener('input', function () {
    setFieldState('phoneNumber', validatePhone(this.value));
  });

  document.getElementById('profileForm').addEventListener('submit', async function (e) {
    e.preventDefault();

    const name  = document.getElementById('name').value.trim();
    const phone = document.getElementById('phoneNumber').value.trim();
    const email = document.getElementById('email').value.trim();

    const nameErr  = validateName(name);
    const phoneErr = validatePhone(phone);
    const emailErr = validateEmail(email);

    setFieldState('name',        nameErr);
    setFieldState('phoneNumber', phoneErr);
    setFieldState('email',       emailErr);

    if (nameErr || phoneErr || emailErr) {
      showAlert('Please fix the errors above before saving.', 'danger');
      return;
    }

    const saveBtn     = document.getElementById('saveBtn');
    const saveText    = document.getElementById('saveText');
    const saveSpinner = document.getElementById('saveSpinner');

    saveBtn.disabled          = true;
    saveText.style.display    = 'none';
    saveSpinner.style.display = 'block';

    try {
      const res  = await fetch('/profile/edit', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ name, phoneNumber: phone, email })
      });

      const data = await res.json().catch(() => ({}));

      if (res.ok) {
        showAlert(data.message || 'Profile updated successfully!', 'success');
        setTimeout(() => { window.location.href = '/profile'; }, 2000);
      } else {
        if (data.errors?.length) {
          data.errors.forEach(err => { if (err.field) setFieldState(err.field, err.message); });
          showAlert(data.errors.map(e => e.message || e).join('<br>'), 'danger');
        } else {
          showAlert(data.message || 'Failed to update profile. Please try again.', 'danger');
        }
      }
    } catch (err) {
      showAlert('Network error — please check your connection and try again.', 'danger');
    } finally {
      saveBtn.disabled          = false;
      saveText.style.display    = 'inline';
      saveSpinner.style.display = 'none';
    }
  });
</script>
