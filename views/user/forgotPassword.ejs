<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password — GLORA</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,400;0,600;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --glora-dark:   #1A1A1A;
      --glora-cream:  #FAF7F4;
      --glora-red:    #8B1A1A;
      --glora-gold:   #D4A96A;
      --glora-blush:  #F0EBE3;
      --glora-muted:  #6B6B6B;
      --glora-border: #E0D8D0;
    }

    body {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      font-family: 'Poppins', sans-serif;
      background: var(--glora-cream);
    }

    /* ── LEFT PANEL ───────────────────────────────────── */
    .login-left {
      background: var(--glora-dark);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 56px;
      position: relative;
      overflow: hidden;
    }

    .login-left::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 30% 70%, rgba(139,26,26,0.25) 0%, transparent 65%),
        radial-gradient(ellipse at 80% 20%, rgba(212,169,106,0.10) 0%, transparent 55%);
      pointer-events: none;
    }

    .login-left__content {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 340px;
    }

    .login-left__logo {
      font-family: 'Cormorant Garant', serif;
      font-size: 48px;
      font-weight: 600;
      letter-spacing: 8px;
      text-transform: uppercase;
      color: #fff;
      text-decoration: none;
      display: block;
      margin-bottom: 16px;
    }

    .login-left__divider {
      width: 40px;
      height: 1px;
      background: var(--glora-gold);
      margin: 0 auto 20px;
      opacity: 0.7;
    }

    .login-left__tagline {
      font-family: 'Cormorant Garant', serif;
      font-size: 22px;
      font-style: italic;
      font-weight: 400;
      color: rgba(255,255,255,0.55);
      line-height: 1.5;
      margin-bottom: 48px;
    }

    .login-left__perks {
      display: flex;
      flex-direction: column;
      gap: 16px;
      text-align: left;
    }

    .login-left__perk {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .login-left__perk-icon {
      width: 32px;
      height: 32px;
      border: 1px solid rgba(212,169,106,0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .login-left__perk-icon i {
      font-size: 12px;
      color: var(--glora-gold);
    }

    .login-left__perk-text {
      font-size: 11px;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.5px;
      line-height: 1.5;
    }

    /* ── RIGHT PANEL ──────────────────────────────────── */
    .login-right {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 56px;
      background: var(--glora-cream);
    }

    .login-form-wrap {
      width: 100%;
      max-width: 380px;
    }

    .login-heading { margin-bottom: 36px; }

    .login-heading__eyebrow {
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--glora-gold);
      margin-bottom: 10px;
    }

    .login-heading__title {
      font-family: 'Cormorant Garant', serif;
      font-size: 32px;
      font-weight: 600;
      color: var(--glora-dark);
      letter-spacing: -0.5px;
      line-height: 1.1;
      margin-bottom: 8px;
    }

    .login-heading__sub {
      font-size: 12px;
      color: var(--glora-muted);
      letter-spacing: 0.3px;
      line-height: 1.6;
    }

    /* Error */
    .login-error {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      background: #fff0f0;
      border-left: 3px solid var(--glora-red);
      color: var(--glora-red);
      font-size: 12px;
      margin-bottom: 24px;
      line-height: 1.5;
    }

    /* Form */
    .login-form { display: flex; flex-direction: column; gap: 20px; }

    .login-field { display: flex; flex-direction: column; gap: 8px; }

    .login-label {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--glora-dark);
    }

    .login-input-wrap { position: relative; }

    .login-input {
      width: 100%;
      padding: 13px 16px;
      border: 1px solid var(--glora-border);
      background: #fff;
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      color: var(--glora-dark);
      outline: none;
      border-radius: 0;
      transition: border-color 0.2s ease;
    }

    .login-input::placeholder { color: #c0b8b0; }
    .login-input:focus { border-color: var(--glora-dark); }

    /* Submit */
    .login-submit {
      width: 100%;
      padding: 14px;
      background: var(--glora-dark);
      color: #fff;
      border: none;
      font-family: 'Poppins', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s ease;
      margin-top: 4px;
    }

    .login-submit:hover { background: var(--glora-red); }

    /* Footer */
    .login-footer {
      margin-top: 28px;
      padding-top: 24px;
      border-top: 1px solid var(--glora-border);
      text-align: center;
      font-size: 11px;
      color: var(--glora-muted);
    }

    .login-footer a {
      color: var(--glora-dark);
      font-weight: 600;
      text-decoration: none;
      letter-spacing: 0.3px;
      transition: color 0.2s ease;
    }

    .login-footer a:hover { color: var(--glora-red); }

    /* ── RESPONSIVE ───────────────────────────────────── */
    @media (max-width: 820px) {
      body { grid-template-columns: 1fr; }
      .login-left { display: none; }
      .login-right { padding: 60px 32px; min-height: 100vh; }
    }

    @media (max-width: 480px) {
      .login-right { padding: 48px 24px; }
    }
  </style>
</head>
<body>

  <!-- LEFT PANEL -->
  <div class="login-left">
    <div class="login-left__content">
      <a href="/" class="login-left__logo">GLORA</a>
      <div class="login-left__divider"></div>
      <p class="login-left__tagline">Glow Like<br>Never Before</p>

      <div class="login-left__perks">
        <div class="login-left__perk">
          <div class="login-left__perk-icon"><i class="fas fa-lock"></i></div>
          <span class="login-left__perk-text">Your account is safe with us</span>
        </div>
        <div class="login-left__perk">
          <div class="login-left__perk-icon"><i class="fas fa-envelope"></i></div>
          <span class="login-left__perk-text">OTP sent instantly to your inbox</span>
        </div>
        <div class="login-left__perk">
          <div class="login-left__perk-icon"><i class="fas fa-undo"></i></div>
          <span class="login-left__perk-text">Reset and get back to shopping fast</span>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="login-right">
    <div class="login-form-wrap">

      <div class="login-heading">
        <p class="login-heading__eyebrow">Account Recovery</p>
        <h1 class="login-heading__title">Want to Change Your Password?</h1>
        <p class="login-heading__sub">Enter your email and we'll send you a one-time password to reset it.</p>
      </div>

      <% if (error) { %>
        <div class="login-error">
          <i class="fas fa-exclamation-circle"></i>
          <%= error %>
        </div>
      <% } %>

      <form action="/forgot-password" method="POST" class="login-form">
        <div class="login-field">
          <label class="login-label" for="email">Email Address</label>
          <div class="login-input-wrap">
            <input
              type="email"
              id="email"
              name="email"
              class="login-input"
              placeholder="you@example.com"
              required>
          </div>
        </div>

        <button type="submit" class="login-submit">Send OTP</button>
      </form>

      <div class="login-footer">
        Remembered it? <a href="/login">Back to Sign In</a>
      </div>

    </div>
  </div>

</body>
</html>