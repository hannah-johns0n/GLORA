<%- include('../partials/user/header', { userName: userName, url: '/wallet' }) %>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<style>
  /* ── BASE ───────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --glora-dark:   #1A1A1A;
    --glora-cream:  #FAF7F4;
    --glora-red:    #8B1A1A;
    --glora-gold:   #D4A96A;
    --glora-blush:  #F0EBE3;
    --glora-muted:  #6B6B6B;
    --glora-border: #E0D8D0;
  }

  body {
    background: var(--glora-cream);
    font-family: 'Poppins', sans-serif;
    color: var(--glora-dark);
  }

  .glora-account {
    min-height: calc(100vh - 72px);
    padding: 40px 0 100px;
    margin-top: 72px;
  }

  .glora-account__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .glora-account__heading {
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--glora-border);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .glora-account__eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  .glora-account__title {
    font-family: 'Cormorant Garant', serif;
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .glora-account__layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 32px;
    align-items: start;
  }

  /* ════════════════════════════════════════════════════
     SHARED SIDEBAR
  ════════════════════════════════════════════════════ */
  .profile-sidebar {
    background: #fff;
    border: 1px solid var(--glora-border);
    position: sticky;
    top: 96px;
  }

  .profile-sidebar__user {
    padding: 28px 24px 24px;
    border-bottom: 1px solid var(--glora-border);
    text-align: center;
  }

  .profile-sidebar__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--glora-blush);
    border: 2px solid var(--glora-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 14px;
  }

  .profile-sidebar__avatar i {
    font-size: 26px;
    color: var(--glora-muted);
  }

  .profile-sidebar__name {
    font-family: 'Cormorant Garant', serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: 0.3px;
    margin-bottom: 4px;
  }

  .profile-sidebar__label {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  /* Nav links */
  .profile-sidebar__nav {
    padding: 12px 0;
  }

  .profile-sidebar__nav a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--glora-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .profile-sidebar__nav a i {
    font-size: 13px;
    width: 16px;
    text-align: center;
  }

  .profile-sidebar__nav a:hover {
    color: var(--glora-dark);
    background: var(--glora-blush);
    border-left-color: var(--glora-border);
  }

  .profile-sidebar__nav a.active {
    color: var(--glora-red);
    border-left-color: var(--glora-red);
    background: #fdf5f5;
  }

  /* Logout */
  .profile-sidebar__logout {
    padding: 16px 24px;
    border-top: 1px solid var(--glora-border);
  }

  .profile-sidebar__logout form { margin: 0; }

  .btn-glora-logout {
    display: block;
    width: 100%;
    padding: 11px;
    background: transparent;
    border: 1.5px solid var(--glora-dark);
    color: var(--glora-dark);
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
  }

  .btn-glora-logout:hover {
    background: var(--glora-dark);
    color: #fff;
  }

  /* ════════════════════════════════════════════════════
     WALLET PANEL
  ════════════════════════════════════════════════════ */
  .wallet-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── BALANCE CARD ───────────────────────────────────── */
  .wallet-balance {
    background: var(--glora-dark);
    padding: 36px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .wallet-balance__left {}

  .wallet-balance__eyebrow {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--glora-gold);
    margin-bottom: 10px;
  }

  .wallet-balance__amount {
    font-family: 'Cormorant Garant', serif;
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 600;
    color: #fff;
    letter-spacing: -1px;
    line-height: 1;
  }

  .wallet-balance__sub {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    margin-top: 8px;
    letter-spacing: 0.5px;
  }

  /* Add money form inside balance card */
  .wallet-balance__add {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  .wallet-balance__input {
    padding: 13px 18px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-right: none;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    color: #fff;
    outline: none;
    width: 160px;
    transition: background 0.2s ease;
  }

  .wallet-balance__input::placeholder { color: rgba(255,255,255,0.35); }
  .wallet-balance__input:focus { background: rgba(255,255,255,0.12); }

  /* Remove number input arrows */
  .wallet-balance__input::-webkit-outer-spin-button,
  .wallet-balance__input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .wallet-balance__input[type=number] { -moz-appearance: textfield; }

  .wallet-balance__btn {
    padding: 13px 20px;
    background: var(--glora-gold);
    border: none;
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--glora-dark);
    cursor: pointer;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .wallet-balance__btn:hover { opacity: 0.85; }

  /* ── TRANSACTION TABLE ──────────────────────────────── */
  .wallet-transactions {
    background: #fff;
    border: 1px solid var(--glora-border);
  }

  .wallet-transactions__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 28px;
    border-bottom: 1px solid var(--glora-border);
    background: var(--glora-cream);
  }

  .wallet-transactions__title {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--glora-muted);
  }

  .wallet-transactions__count {
    font-size: 11px;
    color: var(--glora-muted);
  }

  .wallet-table {
    width: 100%;
    border-collapse: collapse;
  }

  .wallet-table thead {
    background: var(--glora-cream);
  }

  .wallet-table th {
    padding: 12px 28px;
    text-align: left;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--glora-muted);
    border-bottom: 1px solid var(--glora-border);
  }

  .wallet-table td {
    padding: 16px 28px;
    font-size: 12px;
    color: var(--glora-dark);
    border-bottom: 1px solid var(--glora-border);
    vertical-align: middle;
  }

  .wallet-table tbody tr:last-child td { border-bottom: none; }

  .wallet-table tbody tr:hover { background: var(--glora-cream); }

  /* Type badge */
  .tx-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .tx-badge--credit {
    background: #EDFAF2;
    color: #1A6B40;
  }

  .tx-badge--debit {
    background: #FFF0F0;
    color: var(--glora-red);
  }

  /* Amount */
  .tx-amount--credit {
    font-size: 13px;
    font-weight: 600;
    color: #1A6B40;
  }

  .tx-amount--debit {
    font-size: 13px;
    font-weight: 600;
    color: var(--glora-red);
  }

  /* Date */
  .tx-date {
    font-size: 11px;
    color: var(--glora-muted);
    white-space: nowrap;
  }

  /* Description */
  .tx-desc {
    font-size: 12px;
    color: var(--glora-muted);
    max-width: 220px;
  }

  /* Empty */
  .wallet-empty {
    padding: 64px 28px;
    text-align: center;
  }

  .wallet-empty i {
    font-size: 2rem;
    color: var(--glora-gold);
    margin-bottom: 16px;
    display: block;
  }

  .wallet-empty__title {
    font-family: 'Cormorant Garant', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--glora-dark);
    margin-bottom: 8px;
  }

  .wallet-empty__text {
    font-size: 12px;
    color: var(--glora-muted);
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .glora-account__layout { grid-template-columns: 1fr; }
    .glora-sidebar { position: static; }
    .glora-sidebar__nav { display: grid; grid-template-columns: 1fr 1fr; }
    .wallet-balance { flex-direction: column; align-items: flex-start; }
    .wallet-balance__add { width: 100%; }
    .wallet-balance__input { flex: 1; }
  }

  @media (max-width: 640px) {
    .glora-account__container { padding: 0 16px; }
    .glora-sidebar__nav { grid-template-columns: 1fr; }
    .wallet-table th,
    .wallet-table td { padding: 12px 16px; }
    .wallet-balance { padding: 28px 24px; }
    .tx-desc { display: none; }
  }
</style>

<div class="glora-account">
  <div class="glora-account__container">

    <div class="glora-account__layout">

      <!-- ══ SHARED SIDEBAR ══════════════════════════════ -->
      <aside class="profile-sidebar">

      <div class="profile-sidebar__user">
        <div class="profile-sidebar__avatar">
          <i class="fas fa-user"></i>
        </div>
        <p class="profile-sidebar__name"><%= userName || 'User' %></p>
        <span class="profile-sidebar__label">My Account</span>
      </div>

      <nav class="profile-sidebar__nav">
        <a href="/profile" class="<%= url === '/profile' ? 'active' : '' %>">
          <i class="fas fa-user"></i> Profile
        </a>
        <a href="/my-orders" class="<%= url === '/my-orders' ? 'active' : '' %>">
          <i class="fas fa-box"></i> Orders
        </a>
        <a href="/manage-address" class="<%= url === '/manage-address' ? 'active' : '' %>">
          <i class="fas fa-map-marker-alt"></i> Addresses
        </a>
        <a href="/wallet" class="<%= url === '/wallet' ? 'active' : '' %>">
          <i class="fas fa-wallet"></i> Wallet
        </a>
        <a href="/wishlist" class="<%= url === '/wishlist' ? 'active' : '' %>">
          <i class="fas fa-heart"></i> Wishlist
        </a>
        <a href="/login" class="<%= url === '/login' ? 'active' : '' %>">
          <i class="fas fa-sign-in-alt"></i> Add Account
        </a>
      </nav>

      <div class="profile-sidebar__logout">
        <form action="/logout" method="POST">
          <button type="submit" class="btn-glora-logout">
            <i class="fas fa-sign-out-alt" style="margin-right:6px;"></i>Log Out
          </button>
        </form>
      </div>

    </aside>

      <!-- ══ WALLET PANEL ════════════════════════════════ -->
      <div class="wallet-panel">
        <div class="glora-account__heading">
      <span class="glora-account__eyebrow">Your account</span>
      <h1 class="glora-account__title">My Wallet</h1>
    </div>

        <!-- Balance + Add Money -->
        <div class="wallet-balance">
          <div class="wallet-balance__left">
            <p class="wallet-balance__eyebrow">Available Balance</p>
            <p class="wallet-balance__amount">₹ <%= wallet.balance.toLocaleString('en-IN') %></p>
            <p class="wallet-balance__sub">GLORA Wallet · <%= userName %></p>
          </div>

          <form id="addMoneyForm" class="wallet-balance__add">
            <input
              type="number"
              id="amount"
              name="amount"
              class="wallet-balance__input"
              placeholder="Enter amount ₹"
              min="1"
              required
            >
            <button type="submit" class="wallet-balance__btn">
              <i class="fas fa-plus" style="margin-right:6px;"></i>Add Money
            </button>
          </form>
        </div>

        <!-- Transaction History -->
        <div class="wallet-transactions">
          <div class="wallet-transactions__header">
            <span class="wallet-transactions__title">Transaction History</span>
            <span class="wallet-transactions__count">
              <%= wallet.transactions.length %> transaction<%= wallet.transactions.length !== 1 ? 's' : '' %>
            </span>
          </div>

          <% if (wallet.transactions.length === 0) { %>
            <div class="wallet-empty">
              <i class="fas fa-receipt"></i>
              <p class="wallet-empty__title">No Transactions Yet</p>
              <p class="wallet-empty__text">Add money to your wallet to get started.</p>
            </div>
          <% } else { %>
            <table class="wallet-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Type</th>
                  <th>Amount</th>
                  <th>Description</th>
                </tr>
              </thead>
              <tbody>
                <% wallet.transactions.slice().reverse().forEach(function(t) { %>
                <tr>
                  <td class="tx-date">
                    <%= t.date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                  </td>
                  <td>
                    <% if (t.type === 'credit') { %>
                      <span class="tx-badge tx-badge--credit"><i class="fas fa-arrow-down" style="font-size:8px;"></i> Credit</span>
                    <% } else { %>
                      <span class="tx-badge tx-badge--debit"><i class="fas fa-arrow-up" style="font-size:8px;"></i> Debit</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (t.type === 'credit') { %>
                      <span class="tx-amount--credit">+₹ <%= t.amount.toLocaleString('en-IN') %></span>
                    <% } else { %>
                      <span class="tx-amount--debit">−₹ <%= t.amount.toLocaleString('en-IN') %></span>
                    <% } %>
                  </td>
                  <td class="tx-desc"><%= t.description %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>

      </div>
    </div>
  </div>
</div>

<%- include('../partials/user/footer') %>

<script>
document.getElementById('addMoneyForm').addEventListener('submit', async function (e) {
  e.preventDefault();

  const amount = document.getElementById('amount').value;
  if (!amount || amount <= 0) return alert('Please enter a valid amount');

  const res  = await fetch('/wallet/create-order', {
    method:  'POST',
    headers: { 'Content-Type': 'application/json' },
    body:    JSON.stringify({ amount })
  });

  const data = await res.json();
  if (!data.success) return alert('Failed to create payment. Try again.');

  const options = {
    key:         data.key_id,
    amount:      data.order.amount,
    currency:    'INR',
    name:        'GLORA Wallet',
    description: 'Add money to wallet',
    order_id:    data.order.id,
    handler: async function (response) {
      const verifyRes = await fetch('/wallet/verify-payment', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          razorpay_order_id:   response.razorpay_order_id,
          razorpay_payment_id: response.razorpay_payment_id,
          razorpay_signature:  response.razorpay_signature,
          amount
        })
      });
      const result = await verifyRes.json();
      window.location.href = result.redirectUrl;
    },
    theme: { color: '#8B1A1A' }
  };

  const rzp = new Razorpay(options);
  rzp.open();
});
</script>
