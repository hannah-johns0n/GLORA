<%- include('../partials/user/header', { userName: userName, url: '/manage-address' }) %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
  /* ── BASE ───────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --glora-dark:   #1A1A1A;
    --glora-cream:  #FAF7F4;
    --glora-red:    #8B1A1A;
    --glora-gold:   #D4A96A;
    --glora-blush:  #F0EBE3;
    --glora-muted:  #6B6B6B;
    --glora-border: #E0D8D0;
  }

  body {
    background: var(--glora-cream);
    font-family: 'Poppins', sans-serif;
    color: var(--glora-dark);
  }

  /* ── PAGE WRAPPER ───────────────────────────────────── */
  .glora-account {
    min-height: calc(100vh - 72px);
    padding: 40px 0 100px;
    margin-top: 72px;
  }

  .glora-account__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .glora-account__heading {
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--glora-border);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .glora-account__eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  .glora-account__title {
    font-family: 'Cormorant Garant', serif;
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .glora-account__layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 32px;
    align-items: start;
  }

  /* ════════════════════════════════════════════════════
     SHARED SIDEBAR
  ════════════════════════════════════════════════════ */
  .profile-sidebar {
    background: #fff;
    border: 1px solid var(--glora-border);
    position: sticky;
    top: 96px;
  }

  .profile-sidebar__user {
    padding: 28px 24px 24px;
    border-bottom: 1px solid var(--glora-border);
    text-align: center;
  }

  .profile-sidebar__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--glora-blush);
    border: 2px solid var(--glora-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 14px;
  }

  .profile-sidebar__avatar i {
    font-size: 26px;
    color: var(--glora-muted);
  }

  .profile-sidebar__name {
    font-family: 'Cormorant Garant', serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: 0.3px;
    margin-bottom: 4px;
  }

  .profile-sidebar__label {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  /* Nav links */
  .profile-sidebar__nav {
    padding: 12px 0;
  }

  .profile-sidebar__nav a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--glora-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .profile-sidebar__nav a i {
    font-size: 13px;
    width: 16px;
    text-align: center;
  }

  .profile-sidebar__nav a:hover {
    color: var(--glora-dark);
    background: var(--glora-blush);
    border-left-color: var(--glora-border);
  }

  .profile-sidebar__nav a.active {
    color: var(--glora-red);
    border-left-color: var(--glora-red);
    background: #fdf5f5;
  }

  /* Logout */
  .profile-sidebar__logout {
    padding: 16px 24px;
    border-top: 1px solid var(--glora-border);
  }

  .profile-sidebar__logout form { margin: 0; }

  .btn-glora-logout {
    display: block;
    width: 100%;
    padding: 11px;
    background: transparent;
    border: 1.5px solid var(--glora-dark);
    color: var(--glora-dark);
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
  }

  .btn-glora-logout:hover {
    background: var(--glora-dark);
    color: #fff;
  }

  /* ════════════════════════════════════════════════════
     ADDRESS PANEL
  ════════════════════════════════════════════════════ */
  .address-panel { display: flex; flex-direction: column; gap: 0; }

  /* Panel header row */
  .address-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .address-panel__count {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-muted);
  }

  /* Add address button */
  .btn-add-address {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 24px;
    background: var(--glora-dark);
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .btn-add-address:hover {
    background: var(--glora-red);
    color: #fff;
    text-decoration: none;
  }

  /* ── ADDRESS GRID ───────────────────────────────────── */
  .address-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  /* ── ADDRESS CARD ───────────────────────────────────── */
  .address-card {
    background: #fff;
    border: 1px solid var(--glora-border);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s ease;
  }

  .address-card:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,0.07);
  }

  .address-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    background: var(--glora-cream);
    border-bottom: 1px solid var(--glora-border);
  }

  .address-card__type {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--glora-dark);
  }

  .address-card__type i {
    font-size: 11px;
    color: var(--glora-gold);
  }

  .address-card__body {
    padding: 18px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .address-card__row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 12px;
    color: var(--glora-dark);
    line-height: 1.5;
  }

  .address-card__row i {
    font-size: 11px;
    color: var(--glora-muted);
    width: 14px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ── ADDRESS ACTIONS ────────────────────────────────── */
  .address-card__footer {
    display: flex;
    gap: 10px;
    padding: 14px 20px;
    border-top: 1px solid var(--glora-border);
  }

  .addr-btn {
    flex: 1;
    padding: 9px 12px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border: none;
    text-align: center;
  }

  .addr-btn--edit {
    background: transparent;
    color: var(--glora-dark);
    border: 1px solid var(--glora-border);
  }

  .addr-btn--edit:hover {
    background: var(--glora-dark);
    color: #fff;
    border-color: var(--glora-dark);
    text-decoration: none;
  }

  .addr-btn--delete {
    background: transparent;
    color: var(--glora-red);
    border: 1px solid var(--glora-red);
  }

  .addr-btn--delete:hover {
    background: var(--glora-red);
    color: #fff;
  }

  /* ── EMPTY STATE ────────────────────────────────────── */
  .address-empty {
    background: #fff;
    border: 1px solid var(--glora-border);
    padding: 80px 40px;
    text-align: center;
  }

  .address-empty__icon {
    font-size: 2.5rem;
    color: var(--glora-gold);
    margin-bottom: 20px;
    display: block;
  }

  .address-empty__title {
    font-family: 'Cormorant Garant', serif;
    font-size: 28px;
    font-weight: 600;
    color: var(--glora-dark);
    margin-bottom: 10px;
  }

  .address-empty__text {
    font-size: 13px;
    color: var(--glora-muted);
    margin-bottom: 28px;
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .glora-account__layout { grid-template-columns: 1fr; }
    .glora-sidebar { position: static; }
    .glora-sidebar__nav { display: grid; grid-template-columns: 1fr 1fr; }
    .address-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .glora-account__container { padding: 0 16px; }
    .glora-sidebar__nav { grid-template-columns: 1fr; }
    .address-grid { grid-template-columns: 1fr; }
  }
</style>

<div class="glora-account">
  <div class="glora-account__container">
    <div class="glora-account__layout">

      <!-- ══ SHARED SIDEBAR ══════════════════════════════ -->
      <aside class="profile-sidebar">

      <div class="profile-sidebar__user">
        <div class="profile-sidebar__avatar">
          <i class="fas fa-user"></i>
        </div>
        <p class="profile-sidebar__name"><%= userName || 'User' %></p>
        <span class="profile-sidebar__label">My Account</span>
      </div>

      <nav class="profile-sidebar__nav">
        <a href="/profile" class="<%= url === '/profile' ? 'active' : '' %>">
          <i class="fas fa-user"></i> Profile
        </a>
        <a href="/my-orders" class="<%= url === '/my-orders' ? 'active' : '' %>">
          <i class="fas fa-box"></i> Orders
        </a>
        <a href="/manage-address" class="<%= url === '/manage-address' ? 'active' : '' %>">
          <i class="fas fa-map-marker-alt"></i> Addresses
        </a>
        <a href="/wallet" class="<%= url === '/wallet' ? 'active' : '' %>">
          <i class="fas fa-wallet"></i> Wallet
        </a>
        <a href="/wishlist" class="<%= url === '/wishlist' ? 'active' : '' %>">
          <i class="fas fa-heart"></i> Wishlist
        </a>
        <a href="/add-account" class="<%= url === '/login' ? 'active' : '' %>">
          <i class="fas fa-sign-in-alt"></i> Add Account
        </a>
      </nav>

      <div class="profile-sidebar__logout">
        <form action="/logout" method="POST">
          <button type="submit" class="btn-glora-logout">
            <i class="fas fa-sign-out-alt" style="margin-right:6px;"></i>Log Out
          </button>
        </form>
      </div>

    </aside>

      <!-- ══ ADDRESS PANEL ═══════════════════════════════ -->
      <div class="address-panel">
        <div class="glora-account__heading">
      <span class="glora-account__eyebrow">Your account</span>
      <h1 class="glora-account__title">Manage Addresses</h1>
    </div>

        <% if (addresses.length === 0) { %>

          <!-- Empty state -->
          <div class="address-empty">
            <i class="fas fa-map-marker-alt address-empty__icon"></i>
            <h3 class="address-empty__title">No Addresses Saved</h3>
            <p class="address-empty__text">Add a delivery address to make checkout faster.</p>
            <a href="/add-address" class="btn-add-address">
              <i class="fas fa-plus"></i> Add New Address
            </a>
          </div>

        <% } else { %>

          <div class="address-panel__header">
            <span class="address-panel__count">
              <%= addresses.length %> address<%= addresses.length !== 1 ? 'es' : '' %> saved
            </span>
            <a href="/add-address" class="btn-add-address">
              <i class="fas fa-plus"></i> Add New Address
            </a>
          </div>

          <div class="address-grid">
            <% addresses.forEach(function(address) {
              let typeIcon = 'fas fa-home';
              if (address.addressType && address.addressType.toLowerCase() === 'work') typeIcon = 'fas fa-briefcase';
              else if (address.addressType && address.addressType.toLowerCase() === 'other') typeIcon = 'fas fa-map-pin';
            %>
            <div class="address-card">

              <div class="address-card__header">
                <span class="address-card__type">
                  <i class="<%= typeIcon %>"></i>
                  <%= address.addressType || 'Address' %>
                </span>
              </div>

              <div class="address-card__body">
                <div class="address-card__row">
                  <i class="fas fa-city"></i>
                  <span><%= address.city %>, <%= address.state %> — <%= address.pincode %></span>
                </div>
                <% if (address.landmark) { %>
                <div class="address-card__row">
                  <i class="fas fa-landmark"></i>
                  <span>Near <%= address.landmark %></span>
                </div>
                <% } %>
                <div class="address-card__row">
                  <i class="fas fa-phone"></i>
                  <span><%= address.phoneNumber %></span>
                </div>
              </div>

              <div class="address-card__footer">
                <a href="/edit-address/<%= address._id %>" class="addr-btn addr-btn--edit">
                  <i class="fas fa-pen"></i> Edit
                </a>
                <form action="/delete-address/<%= address._id %>" method="POST" style="flex:1; display:contents;" class="delete-address-form">
                  <button type="submit" class="addr-btn addr-btn--delete">
                    <i class="fas fa-trash-alt"></i> Delete
                  </button>
                </form>
              </div>

            </div>
            <% }); %>
          </div>

        <% } %>

      </div>
    </div>
  </div>
</div>

<%- include('../partials/user/footer') %>

<script>
  <% if (typeof flash !== 'undefined' && flash) { %>
    Swal.fire({
      icon: '<%= flash.type === "error" ? "error" : "success" %>',
      title: '<%= flash.type === "error" ? "Error" : "Success" %>',
      text: '<%= flash.message %>',
      timer: 2000,
      timerProgressBar: true,
      showConfirmButton: false,
      confirmButtonColor: '#8B1A1A'
    });
  <% } %>
</script>
