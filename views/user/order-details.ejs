<%- include('../partials/user/header', { userName: userName }) %>

    <div class="container py-4 mt-3">

        <% if (success_msg && success_msg.length> 0) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= success_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

                <% if (error_msg && error_msg.length> 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <%= error_msg %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <% } %>

                        <div class="order-container">

                            <!-- Order Header -->
                            <div class="order-summary-card mb-4">
                                <div class="order-header">
                                    <h2 class="order-title">OrderId: #<%= order.orderId %>
                                    </h2>
                                    <div class="order-status-badge <%= order.status.toLowerCase() %>">
                                        <%= order.status %>
                                    </div>
                                </div>
                                <div class="order-meta">
                                    <div class="meta-item">
                                        <i class="far fa-calendar-alt me-2"></i>
                                        <span>Placed on <%= new Date(order.createdAt).toLocaleDateString('en-IN', {
                                                day: 'numeric' , month: 'long' , year: 'numeric' }) %></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Order Items -->
                            <div class="order-section">
                                <h3 class="section-title">Order Items</h3>
                                <div class="order-items">
                                    <% order.orderItems.forEach(function(item) { %>
                                        <div class="order-item">

                                            <div class="item-image">
                                                <!-- ✅ Use item.image stored in order — no productId needed -->
                                                <img src="<%= item.image || '/images/placeholder-product.jpg' %>"
                                                    alt="<%= item.name || 'Product' %>">
                                            </div>

                                            <div class="item-details">
                                                <!-- ✅ Use item.name stored in order -->
                                                <h4 class="item-name">
                                                    <%= item.name || 'Product' %>
                                                </h4>

                                                <!-- ✅ Use item.price stored in order -->
                                                <div class="item-price">₹<%= item.price ? item.price.toFixed(2) : '0.00'
                                                        %>
                                                </div>

                                                <div class="item-quantity">Qty: <%= item.quantity %>
                                                </div>

                                                <!-- ✅ Removed duplicate status display -->
                                                <h4>Status: <%= order.status==='Return-Rejected' ? 'Return Rejected' :
                                                        (item.status || order.status) %>
                                                </h4>
                                            </div>

                                            <% if ( order.status !=='Cancelled' && order.status !=='Delivered' &&
                                                item.status !=='Cancelled' && item.status !=='Delivered' && item.status
                                                !=='Returned' && item.status !=='Return-Requested' ) { %>
                                                <button type="button" class="btn btn-outline-primary ms-2"
                                                    onclick="returnOrder('<%= order.orderId %>')">
                                                    <i class="fas fa-undo me-2"></i>Return Order
                                                </button>
                                                <% } %>

                                        </div>
                                        <% }); %>
                                </div>
                            </div>

                            <!-- Shipping Address -->
                            <div class="shipping-address">
                                <p class="address-type">Address Type: <%= order.addressId?.addressType || 'N/A' %>
                                </p>
                                <h5>Shipped To:</h5>
                                <p class="address-city">
                                    <%= order.addressId?.city || 'N/A' %>,
                                        <%= order.addressId?.state || 'N/A' %> -
                                            <%= order.addressId?.pincode || 'N/A' %>
                                </p>
                                <p class="address-landmark">
                                    <%= order.addressId?.landmark || 'N/A' %>
                                </p>
                                <p class="address-phone">
                                    <i class="fas fa-phone-alt me-2"></i>+91 <%= order.addressId?.phoneNumber || 'N/A'
                                        %>
                                </p>
                            </div>

                            <!-- Payment Info -->
                            <% if (order.paymentMethod) { %>
                                <div class="meta-item">
                                    <i class="fas fa-credit-card me-2"></i>
                                    <span>Payment Method: <strong>
                                            <%= order.paymentMethod %>
                                        </strong></span>
                                </div>
                                <% } %>

                                    <% if (order.paymentStatus) { %>
                                        <div class="meta-item">
                                            <i class="fas fa-check-circle me-2"></i>
                                            <span>Payment Status:
                                                <strong class="payment-status <%= order.paymentStatus.toLowerCase() %>">
                                                    <%= order.paymentStatus %>
                                                </strong>
                                            </span>
                                        </div>
                                        <% } else { %>
                                            <div class="meta-item">
                                                <i class="fas fa-exclamation-circle me-2"></i>
                                                <span>Payment Status: <strong class="text-muted">N/A</strong></span>
                                            </div>
                                            <% } %>

                        </div>

                        <!-- Order Summary -->
                        <div class="order-summary">
                            <h3 class="section-title">Order Summary</h3>

                            <div class="summary-row">
                                <span>Subtotal (<%= order.orderItems.reduce(function(t, i) { return t + i.quantity; },
                                        0) %> items)</span>
                                <!-- ✅ Use item.price stored in order -->
                                <span>₹<%= order.orderItems.reduce(function(total, item) { return total + (item.price ||
                                        0) * item.quantity; }, 0).toFixed(2) %></span>
                            </div>

                            <div class="summary-row">
                                <span>Shipping</span>
                                <span>₹<%= (order.shipping || 50).toFixed(2) %></span>
                            </div>

                            <% if (order.discount && order.discount> 0) { %>
                                <div class="summary-row discount">
                                    <span>Discount</span>
                                    <span>-₹<%= order.discount.toFixed(2) %></span>
                                </div>
                                <% } %>

                                    <div class="summary-total">
                                        <span>Total</span>
                                        <span>₹<%= order.totalPrice.toFixed(2) %></span>
                                    </div>
                        </div>

                        <!-- Actions -->
                        <div class="order-actions mt-4 mb-4">
                            <a href="/my-orders" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to Orders
                            </a>
                            <% if (order.status==='Delivered' && !order.returnRequest) { %>
                                <button class="btn btn-outline-primary ms-2 btn-return"
                                    data-order-id="<%= order.orderId %>">
                                    <i class="fas fa-undo me-2"></i>Return Order
                                </button>
                                <% } %>
                        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/user/orders.js"></script>
    <script>
        async function cancelItem(productId) {
            const { value: reason } = await Swal.fire({
                title: 'Cancel Item?',
                input: 'text',
                inputPlaceholder: 'Enter reason for cancellation',
                showCancelButton: true,
                confirmButtonText: 'Yes, Cancel',
                cancelButtonText: 'No',
                inputValidator: function (value) {
                    if (!value) return 'Reason is required!';
                }
            });

            if (!reason) return;

            try {
                const response = await fetch(
                    '/my-orders/<%= order.orderId %>/cancel-product/' + productId,
                    {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ reason })
                    }
                );

                const data = await response.json();

                if (response.ok && data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Cancelled!',
                        text: 'The item has been cancelled successfully.',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(function () {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error', data.message || 'Failed to cancel item', 'error');
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Error', 'Something went wrong!', 'error');
            }
        }
    </script>
    <script>
        // ── RETURN ORDER ─────────────────────────────────────────────────
        var returnBtn = document.querySelector('.btn-return');
        if (returnBtn) {
            returnBtn.addEventListener('click', async function () {
                const orderId = this.dataset.orderId;

                const { value: reason } = await Swal.fire({
                    title: 'Return Order',
                    input: 'text',
                    inputPlaceholder: 'Enter reason for return',
                    showCancelButton: true,
                    confirmButtonText: 'Submit Return',
                    cancelButtonText: 'Cancel',
                    inputValidator: function (value) {
                        if (!value) return 'Please provide a reason for return.';
                    }
                });

                if (!reason) return;

                try {
                    const res = await fetch('/my-orders/' + orderId + '/return', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ reason })
                    });
                    const data = await res.json();

                    if (res.ok && data.success) {
                        await Swal.fire({
                            icon: 'success',
                            title: 'Return Requested!',
                            text: 'Your return request has been submitted. Our team will review it shortly.',
                            confirmButtonText: 'View My Orders'
                        });
                        window.location.href = '/my-orders';
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: data.message || 'Failed to submit return request.'
                        });
                    }
                } catch (err) {
                    console.error(err);
                    Swal.fire('Error', 'Something went wrong. Please try again.', 'error');
                }
            });
        }
    </script>


    <style>
        .order-container {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
            padding: 16px;
            max-width: 800px;
            margin: 0 auto;
            padding-top: 50px;
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .order-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin: 0;
            color: #333;
        }

        .order-status-badge {
            padding: 6px 12px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 500;
            text-transform: capitalize;
        }

        .order-status-badge.pending {
            background-color: #fff3cd;
            color: #856404;
        }

        .order-status-badge.processing {
            background-color: #cce5ff;
            color: #004085;
        }

        .order-status-badge.shipped {
            background-color: #e2e3e5;
            color: #383d41;
        }

        .order-status-badge.delivered {
            background-color: #d4edda;
            color: #155724;
        }

        .order-status-badge.cancelled,
        .order-status-badge.returned {
            background-color: #f8d7da;
            color: #721c24;
        }

        .order-meta {
            display: flex;
            gap: 20px;
            color: #666;
            font-size: 14px;
        }

        .meta-item {
            display: flex;
            align-items: center;
        }

        .order-items-section {
            margin-top: 16px;
        }

        .section-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 15px;
            color: #333;
            padding-bottom: 10px;
            border-bottom: 1px solid #f0f0f0;
        }

        .order-items {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .order-item {
            display: flex;
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
            align-items: center;
        }

        .order-item:last-child {
            border-bottom: none;
        }

        .item-image {
            width: 60px;
            height: 60px;
            border-radius: 4px;
            overflow: hidden;
            margin-right: 15px;
            background: #f8f9fa;
            flex-shrink: 0;
        }

        .item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .item-details {
            flex: 1;
        }

        .item-name {
            font-weight: 500;
            margin-bottom: 5px;
            color: #333;
        }

        .item-price,
        .item-quantity,
        .item-subtotal {
            font-size: 14px;
            color: #666;
            margin-bottom: 3px;
        }

        .item-subtotal {
            font-weight: 500;
            color: #333;
        }

        .item-actions {
            margin-left: 15px;
            display: flex;
            align-items: center;
        }

        .btn-cancel-item {
            background: none;
            border: 1px solid #dc3545;
            color: #dc3545;
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-cancel-item:hover {
            background-color: #f8d7da;
        }

        .shipping-section {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid #f0f0f0;
        }

        .address-name {
            font-weight: 500;
            margin-bottom: 5px;
            color: #333;
        }

        .address-street,
        .address-city {
            color: #666;
            margin-bottom: 3px;
        }

        .address-phone {
            color: #666;
            margin-top: 8px;
            display: flex;
            align-items: center;
        }

        .order-summary {
            margin: 16px 0;
            padding: 16px 0;
            border-top: 1px solid #f0f0f0;
            border-bottom: 1px solid #f0f0f0;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            padding-bottom: 10px;
            border-bottom: 1px solid #f0f0f0;
        }

        .summary-row:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .summary-total {
            display: flex;
            justify-content: space-between;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #e9ecef;
            font-size: 1.1rem;
            font-weight: 600;
            color: #333;
        }

        .discount {
            color: #28a745;
        }

        .payment-status {
            text-transform: capitalize;
            font-weight: 500;
            margin-left: 2px;
        }

        .payment-status.paid,
        .payment-status.completed,
        .payment-status.successful {
            color: #28a745;
        }

        .payment-status.pending,
        .payment-status.processing {
            color: #ffc107;
        }

        .payment-status.failed,
        .payment-status.cancelled,
        .payment-status.refunded {
            color: #dc3545;
        }

        @media (max-width: 768px) {
            .order-meta {
                flex-direction: column;
                gap: 8px;
            }

            .order-item {
                flex-direction: column;
            }

            .item-actions {
                margin: 10px 0 0 0;
                width: 100%;
            }

            .btn-cancel-item {
                width: 100%;
                text-align: center;
            }
        }
    </style>

    <%- include('../partials/user/footer') %>