<%- include('../partials/user/header', { userName: user?.name || 'User', url: '/profile' }) %>

<style>
  /* ── BASE ───────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --glora-dark:   #1A1A1A;
    --glora-cream:  #FAF7F4;
    --glora-red:    #8B1A1A;
    --glora-gold:   #D4A96A;
    --glora-blush:  #F0EBE3;
    --glora-muted:  #6B6B6B;
    --glora-border: #E0D8D0;
  }

  body {
    background: var(--glora-cream);
    font-family: 'Poppins', sans-serif;
    color: var(--glora-dark);
  }

  /* ── PAGE WRAPPER ───────────────────────────────────── */
  .profile-page {
    min-height: 100vh;
    padding: 40px 0 80px;
    margin-top: 72px;
  }

  .profile-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 32px;
    align-items: start;
  }

  /* ── SIDEBAR ────────────────────────────────────────── */
  .profile-sidebar {
    background: #fff;
    border: 1px solid var(--glora-border);
    position: sticky;
    top: 96px;
  }

  .profile-sidebar__user {
    padding: 28px 24px 24px;
    border-bottom: 1px solid var(--glora-border);
    text-align: center;
  }

  .profile-sidebar__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--glora-blush);
    border: 2px solid var(--glora-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 14px;
  }

  .profile-sidebar__avatar i {
    font-size: 26px;
    color: var(--glora-muted);
  }

  .profile-sidebar__name {
    font-family: 'Cormorant Garant', serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: 0.3px;
    margin-bottom: 4px;
  }

  .profile-sidebar__label {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  /* Nav links */
  .profile-sidebar__nav {
    padding: 12px 0;
  }

  .profile-sidebar__nav a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--glora-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .profile-sidebar__nav a i {
    font-size: 13px;
    width: 16px;
    text-align: center;
  }

  .profile-sidebar__nav a:hover {
    color: var(--glora-dark);
    background: var(--glora-blush);
    border-left-color: var(--glora-border);
  }

  .profile-sidebar__nav a.active {
    color: var(--glora-red);
    border-left-color: var(--glora-red);
    background: #fdf5f5;
  }

  /* Logout */
  .profile-sidebar__logout {
    padding: 16px 24px;
    border-top: 1px solid var(--glora-border);
  }

  .profile-sidebar__logout form { margin: 0; }

  .btn-glora-logout {
    display: block;
    width: 100%;
    padding: 11px;
    background: transparent;
    border: 1.5px solid var(--glora-dark);
    color: var(--glora-dark);
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
  }

  .btn-glora-logout:hover {
    background: var(--glora-dark);
    color: #fff;
  }

  /* ── MAIN CONTENT ───────────────────────────────────── */
  .profile-main {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Page eyebrow */
  .profile-eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--glora-gold);
    margin-bottom: 6px;
  }

  .profile-title {
    font-family: 'Cormorant Garant', serif;
    font-size: clamp(28px, 3vw, 38px);
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: -0.3px;
  }

  /* ── CARD ───────────────────────────────────────────── */
  .profile-card {
    background: #fff;
    border: 1px solid var(--glora-border);
    padding: 32px 36px;
  }

  .profile-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--glora-border);
  }

  .profile-card__header-title {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--glora-muted);
  }

  /* Edit button */
  .btn-glora-edit {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 22px;
    background: var(--glora-dark);
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .btn-glora-edit:hover {
    background: var(--glora-red);
    color: #fff;
    text-decoration: none;
  }

  .btn-glora-edit i { font-size: 11px; }

  /* ── INFO FIELDS ────────────────────────────────────── */
  .profile-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 32px;
  }

  .profile-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .profile-field--full {
    grid-column: 1 / -1;
  }

  .profile-field__label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  .profile-field__value {
    font-size: 13px;
    font-weight: 400;
    color: var(--glora-dark);
    padding: 12px 16px;
    background: var(--glora-cream);
    border: 1px solid var(--glora-border);
    letter-spacing: 0.2px;
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .profile-field__value--muted {
    color: var(--glora-muted);
    font-style: italic;
  }

  /* Password dots */
  .profile-field__value--password {
    letter-spacing: 4px;
    font-size: 16px;
    color: var(--glora-muted);
  }

  /* Inline link */
  .profile-field__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--glora-red);
    text-decoration: none;
    margin-top: 4px;
    transition: opacity 0.2s ease;
  }

  .profile-field__link:hover {
    opacity: 0.75;
    text-decoration: none;
    color: var(--glora-red);
  }

  .profile-field__link i { font-size: 9px; }

  /* ── REFERRAL CARD ──────────────────────────────────── */
  .referral-card {
    background: var(--glora-dark);
    padding: 28px 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .referral-card__left { flex: 1; }

  .referral-card__eyebrow {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-gold);
    margin-bottom: 6px;
  }

  .referral-card__title {
    font-family: 'Cormorant Garant', serif;
    font-size: 20px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 10px;
  }

  .referral-card__desc {
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.3px;
    line-height: 1.6;
  }

  .referral-card__code-wrap {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  .referral-card__code {
    padding: 13px 22px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    font-family: 'Courier New', monospace;
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 3px;
  }

  .referral-card__copy {
    padding: 13px 18px;
    background: var(--glora-gold);
    border: none;
    cursor: pointer;
    color: var(--glora-dark);
    font-size: 13px;
    transition: opacity 0.2s ease;
  }

  .referral-card__copy:hover { opacity: 0.85; }

  /* ── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .profile-container {
      grid-template-columns: 1fr;
      padding: 0 24px;
    }
    .profile-sidebar { position: static; }
    .profile-sidebar__nav { display: grid; grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .profile-container { padding: 0 16px; }
    .profile-card { padding: 24px 20px; }
    .profile-fields { grid-template-columns: 1fr; }
    .referral-card { flex-direction: column; align-items: flex-start; }
    .profile-sidebar__nav { grid-template-columns: 1fr; }
  }
</style>

<div class="profile-page">
  <div class="profile-container">

    <!-- ── SIDEBAR ───────────────────────────────────── -->
    <aside class="profile-sidebar">

      <div class="profile-sidebar__user">
        <div class="profile-sidebar__avatar">
          <i class="fas fa-user"></i>
        </div>
        <p class="profile-sidebar__name"><%= user?.name || 'User' %></p>
        <span class="profile-sidebar__label">My Account</span>
      </div>

      <nav class="profile-sidebar__nav">
        <a href="/profile" class="active">
          <i class="fas fa-user"></i> Profile
        </a>
        <a href="/my-orders" class="<%= url === '/my-orders' ? 'active' : '' %>">
          <i class="fas fa-box"></i> Orders
        </a>
        <a href="/manage-address">
          <i class="fas fa-map-marker-alt"></i> Addresses
        </a>
        <a href="/wallet" class="<%= url === '/wallet' ? 'active' : '' %>">
          <i class="fas fa-wallet"></i> Wallet
        </a>
        <a href="/wishlist" class="<%= url === '/wishlist' ? 'active' : '' %>">
          <i class="fas fa-heart"></i> Wishlist
        </a>
        <a href="/add-account" class="<%= url === '/login' ? 'active' : '' %>">
          <i class="fas fa-sign-in-alt"></i> Add Account
        </a>
      </nav>

      <div class="profile-sidebar__logout">
        <form action="/logout" method="POST">
          <button type="submit" class="btn-glora-logout">
            <i class="fas fa-sign-out-alt" style="margin-right:6px;"></i>Log Out
          </button>
        </form>
      </div>

    </aside>

    <!-- ── MAIN ──────────────────────────────────────── -->
    <main class="profile-main">

      <% if (!user) { %>
        <div class="profile-card" style="text-align:center; padding: 60px 36px;">
          <i class="fas fa-lock" style="font-size:2rem; color: var(--glora-gold); margin-bottom:16px; display:block;"></i>
          <p class="profile-title" style="margin-bottom:12px;">Please sign in</p>
          <p style="font-size:13px; color:var(--glora-muted); margin-bottom:24px;">You need to be logged in to view this page.</p>
          <a href="/login" class="btn-glora-edit">Sign In</a>
        </div>

      <% } else { %>

        <!-- Page heading -->
        <div>
          <p class="profile-eyebrow">Your account</p>
          <h1 class="profile-title">Personal Information</h1>
        </div>

        <!-- Referral card -->
        <%
          let referralCode = user.referralCode;
          if (!referralCode) {
            let letters = (user.name ? user.name.substring(0, 3) : "USR").toUpperCase();
            let numbers = Math.floor(1000 + Math.random() * 9000);
            referralCode = letters + numbers;
          }
        %>
        <div class="referral-card">
          <div class="referral-card__left">
            <p class="referral-card__eyebrow">Refer & Earn</p>
            <p class="referral-card__title">Your Referral Code</p>
            <p class="referral-card__desc">Share this code with friends and earn rewards when they shop.</p>
          </div>
          <div class="referral-card__code-wrap">
            <span class="referral-card__code" id="referralCode"><%= referralCode %></span>
            <button class="referral-card__copy" id="copyBtn" title="Copy code">
              <i class="fas fa-copy"></i>
            </button>
          </div>
        </div>

        <!-- Info card -->
        <div class="profile-card">
          <div class="profile-card__header">
            <span class="profile-card__header-title">Account Details</span>
            <a href="/profile/edit" class="btn-glora-edit">
              <i class="fas fa-pen"></i> Edit Profile
            </a>
          </div>

          <div class="profile-fields">

            <div class="profile-field">
              <span class="profile-field__label">Full Name</span>
              <div class="profile-field__value">
                <%= user.name || '' %>
              </div>
            </div>

            <div class="profile-field">
              <span class="profile-field__label">Mobile Number</span>
              <div class="profile-field__value <%= !user.phoneNumber ? 'profile-field__value--muted' : '' %>">
                <%= user.phoneNumber || 'Not added yet' %>
              </div>
            </div>

            <div class="profile-field">
              <span class="profile-field__label">Email Address</span>
              <div class="profile-field__value"><%= user.email || '' %></div>
              <% if (user.password) { %>
                <a href="/change-email" class="profile-field__link">
                  <i class="fas fa-arrow-right"></i> Change Email
                </a>
              <% } %>
            </div>

            <div class="profile-field">
              <span class="profile-field__label">Password</span>
              <div class="profile-field__value profile-field__value--password">••••••••</div>
              <% if (user.password) { %>
                <a href="/reset-password" class="profile-field__link">
                  <i class="fas fa-arrow-right"></i> Change Password
                </a>
              <% } %>
            </div>

          </div>
        </div>

      <% } %>
    </main>

  </div>
</div>

<%- include('../partials/user/footer') %>

<script>
  // Copy referral code
  const copyBtn = document.getElementById('copyBtn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function () {
      const code = document.getElementById('referralCode').textContent.trim();
      navigator.clipboard.writeText(code).then(() => {
        this.innerHTML = '<i class="fas fa-check"></i>';
        this.style.background = '#4CAF50';
        setTimeout(() => {
          this.innerHTML = '<i class="fas fa-copy"></i>';
          this.style.background = '';
        }, 1800);
      });
    });
  }
</script>

    <% if (typeof flash !== 'undefined' && flash) { %>
    <script>
      Swal.fire({
        icon: '<%= flash.type === "error" ? "error" : "success" %>',
        title: '<%= flash.type === "error" ? "Error" : "Success" %>',
        text: '<%= flash.message %>',
        confirmButtonColor: '#D4A96A'
      });
    </script>
    <% } %>