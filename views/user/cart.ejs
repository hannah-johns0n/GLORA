<%- include('../partials/user/header', { userName: userName, url: url }) %>

  <style>
    /* ── CART PAGE ──────────────────────────────────────── */
    .glora-cart {
      min-height: calc(100vh - 72px);
      background: var(--glora-cream);
      padding: 60px 0 100px;
    }

    .glora-cart__container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 40px;
    }

    /* ── PAGE HEADING ───────────────────────────────────── */
    .glora-cart__heading {
      margin-bottom: 40px;
      padding-bottom: 20px;
      border-bottom: 1px solid rgba(26, 26, 26, 0.10);
      display: flex;
      align-items: baseline;
      gap: 14px;
    }

    .glora-cart__eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--glora-gold);
    }

    .glora-cart__title {
      font-family: 'Cormorant Garant', serif;
      font-size: 38px;
      font-weight: 600;
      color: var(--glora-dark);
      letter-spacing: -0.5px;
      line-height: 1;
    }

    /* ── EMPTY STATE ────────────────────────────────────── */
    .glora-cart__empty {
      text-align: center;
      padding: 100px 40px;
    }

    .glora-cart__empty-icon {
      width: 72px;
      height: 72px;
      border: 1.5px solid rgba(26, 26, 26, 0.12);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 28px;
    }

    .glora-cart__empty-icon i {
      font-size: 26px;
      color: var(--glora-muted);
    }

    .glora-cart__empty-title {
      font-family: 'Cormorant Garant', serif;
      font-size: 30px;
      font-weight: 600;
      color: var(--glora-dark);
      margin-bottom: 10px;
    }

    .glora-cart__empty-sub {
      font-size: 12px;
      color: var(--glora-muted);
      letter-spacing: 0.5px;
      margin-bottom: 32px;
    }

    .glora-cart__empty-cta {
      display: inline-block;
      padding: 13px 36px;
      background: var(--glora-dark);
      color: #fff;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      text-decoration: none;
      transition: background 0.3s ease;
    }

    .glora-cart__empty-cta:hover {
      background: var(--glora-red);
      color: #fff;
      text-decoration: none;
    }

    /* ── LAYOUT ─────────────────────────────────────────── */
    .glora-cart__layout {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 28px;
      align-items: start;
    }

    /* ── ITEMS PANEL ────────────────────────────────────── */
    .glora-cart__items {
      background: #fff;
      border: 1px solid rgba(26, 26, 26, 0.07);
    }

    /* Table head */
    .glora-cart__table-head {
      display: grid;
      grid-template-columns: 3fr 1fr 1fr 1fr 1fr 36px;
      padding: 13px 24px;
      background: var(--glora-blush);
      border-bottom: 1px solid rgba(26, 26, 26, 0.08);
      gap: 12px;
    }

    .glora-cart__table-head span {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--glora-muted);
    }

    .glora-cart__table-head span:not(:first-child) {
      text-align: center;
    }

    /* ── ROW ────────────────────────────────────────────── */
    .glora-cart__row {
      display: grid;
      grid-template-columns: 3fr 1fr 1fr 1fr 1fr 36px;
      padding: 20px 24px;
      align-items: center;
      gap: 12px;
      border-bottom: 1px solid rgba(26, 26, 26, 0.06);
      transition: background 0.2s ease;
      position: relative;
    }

    .glora-cart__row:hover {
      background: #fdfcfb;
    }

    .glora-cart__row:last-child {
      border-bottom: none;
    }

    /* Out-of-stock / unavailable row */
    .glora-cart__row--unavailable {
      background: #f7f5f3;
    }

    .glora-cart__row--unavailable .glora-cart__product-name,
    .glora-cart__row--unavailable .glora-cart__product-meta,
    .glora-cart__row--unavailable .glora-cart__price,
    .glora-cart__row--unavailable .glora-cart__total,
    .glora-cart__row--unavailable .glora-cart__qty-num {
      opacity: 0.4;
    }

    .glora-cart__row--unavailable .glora-cart__img-wrap {
      filter: grayscale(60%);
      opacity: 0.5;
    }

    /* ── PRODUCT CELL ───────────────────────────────────── */
    .glora-cart__product {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      min-width: 0;
    }

    .glora-cart__img-wrap {
      width: 80px;
      height: 80px;
      background: var(--glora-blush);
      flex-shrink: 0;
      overflow: hidden;
      border: 1px solid rgba(26, 26, 26, 0.06);
      transition: filter 0.3s ease, opacity 0.3s ease;
    }

    .glora-cart__img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }

    .glora-cart__row:not(.glora-cart__row--unavailable):hover .glora-cart__img-wrap img {
      transform: scale(1.05);
    }

    .glora-cart__img-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--glora-blush);
    }

    .glora-cart__img-placeholder i {
      font-size: 20px;
      color: rgba(26, 26, 26, 0.15);
    }

    .glora-cart__product-info {
      min-width: 0;
      flex: 1;
      padding-top: 2px;
    }

    /* Product name — wraps, no truncation */
    .glora-cart__product-name {
      font-size: 13px;
      font-weight: 500;
      color: var(--glora-dark);
      margin-bottom: 5px;
      line-height: 1.45;
      white-space: normal;
      /* ← wraps */
      word-break: break-word;
    }

    /* Variant row */
    .glora-cart__product-meta {
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin-bottom: 6px;
    }

    .glora-cart__variant {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 10px;
      font-weight: 500;
      color: var(--glora-muted);
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .glora-cart__variant i {
      font-size: 9px;
      color: var(--glora-gold);
      opacity: 0.8;
    }

    /* ── VARIANT CHIP ───────────────────────────────────── */
    .glora-cart__variant-chip {
      display: inline-flex;
      align-items: center;
      gap: 0;
      border: 1px solid var(--glora-border);
      overflow: hidden;
      width: fit-content;
      margin-bottom: 2px;
    }

    .glora-cart__variant-key {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #fff;
      background: var(--glora-dark);
      padding: 4px 9px;
      line-height: 1;
    }

    .glora-cart__variant-val {
      font-size: 10px;
      font-weight: 500;
      color: var(--glora-dark);
      background: var(--glora-blush);
      padding: 4px 10px;
      line-height: 1;
      letter-spacing: 0.5px;
    }

    /* Offer badge */
    .glora-cart__offer-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 3px 10px;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      color: var(--glora-gold);
      background: rgba(212, 169, 106, 0.10);
      border: 1px solid rgba(212, 169, 106, 0.25);
      width: fit-content;
    }

    .glora-cart__offer-badge i {
      font-size: 9px;
    }

    /* Out-of-stock badge */
    .glora-cart__oos-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 10px;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--glora-red);
      background: rgba(139, 26, 26, 0.06);
      border: 1px solid rgba(139, 26, 26, 0.20);
      width: fit-content;
      margin-top: 2px;
    }

    .glora-cart__oos-badge i {
      font-size: 9px;
    }

    /* ── PRICE / TOTAL CELLS ────────────────────────────── */
    .glora-cart__cell {
      text-align: center;
    }

    .glora-cart__price {
      font-size: 13px;
      font-weight: 400;
      color: var(--glora-dark);
    }

    .glora-cart__total {
      font-size: 13px;
      font-weight: 600;
      color: var(--glora-red);
    }

    /* ── QUANTITY STEPPER ───────────────────────────────── */
    .glora-cart__qty {
      display: inline-flex;
      align-items: center;
      border: 1px solid rgba(26, 26, 26, 0.14);
      overflow: hidden;
    }

    .glora-cart__qty-btn {
      width: 28px;
      height: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 15px;
      line-height: 1;
      color: var(--glora-dark);
      font-family: 'Poppins', sans-serif;
      transition: background 0.2s ease, color 0.2s ease;
      flex-shrink: 0;
    }

    .glora-cart__qty-btn:hover:not(:disabled) {
      background: var(--glora-dark);
      color: #fff;
    }

    .glora-cart__qty-btn:disabled {
      cursor: not-allowed;
      color: #ccc;
      background: #f5f5f5;
    }

    .glora-cart__qty-num {
      min-width: 34px;
      text-align: center;
      font-size: 13px;
      font-weight: 500;
      color: var(--glora-dark);
      border-left: 1px solid rgba(26, 26, 26, 0.12);
      border-right: 1px solid rgba(26, 26, 26, 0.12);
      padding: 0 4px;
      line-height: 30px;
      display: block;
    }

    /* Qty cell wrapper for centering */
    .glora-cart__qty-wrap {
      display: flex;
      justify-content: center;
    }

    /* ── REMOVE ─────────────────────────────────────────── */
    .glora-cart__remove {
      background: none;
      border: none;
      cursor: pointer;
      color: rgba(26, 26, 26, 0.22);
      font-size: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      margin: 0 auto;
      transition: color 0.2s ease, background 0.2s ease;
      border-radius: 50%;
    }

    .glora-cart__remove:hover {
      color: var(--glora-red);
      background: rgba(139, 26, 26, 0.06);
    }

    /* ── ORDER SUMMARY ──────────────────────────────────── */
    .glora-cart__summary {
      background: #fff;
      border: 1px solid rgba(26, 26, 26, 0.07);
      padding: 28px;
      position: sticky;
      top: 92px;
    }

    .glora-cart__summary-title {
      font-family: 'Cormorant Garant', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--glora-dark);
      margin-bottom: 22px;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(26, 26, 26, 0.08);
    }

    .glora-cart__summary-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    .glora-cart__summary-label {
      font-size: 11px;
      color: var(--glora-muted);
      letter-spacing: 0.5px;
    }

    .glora-cart__summary-value {
      font-size: 13px;
      font-weight: 500;
      color: var(--glora-dark);
    }

    .glora-cart__summary-free {
      font-size: 12px;
      font-weight: 600;
      color: #2d7a3a;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .glora-cart__summary-divider {
      height: 1px;
      background: rgba(26, 26, 26, 0.08);
      margin: 16px 0;
    }

    .glora-cart__summary-total-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--glora-dark);
    }

    .glora-cart__summary-total-value {
      font-family: 'Cormorant Garant', serif;
      font-size: 26px;
      font-weight: 600;
      color: var(--glora-dark);
    }

    /* Shipping progress bar */
    .glora-cart__shipping-bar-wrap {
      margin: 16px 0 4px;
    }

    .glora-cart__shipping-bar-label {
      font-size: 10px;
      color: var(--glora-muted);
      margin-bottom: 7px;
      letter-spacing: 0.3px;
    }

    .glora-cart__shipping-bar-label strong {
      color: var(--glora-dark);
    }

    .glora-cart__shipping-bar-track {
      width: 100%;
      height: 3px;
      background: rgba(26, 26, 26, 0.10);
      border-radius: 99px;
      overflow: hidden;
    }

    .glora-cart__shipping-bar-fill {
      height: 100%;
      background: var(--glora-gold);
      border-radius: 99px;
      transition: width 0.4s ease;
    }

    .glora-cart__checkout-btn {
      display: block;
      width: 100%;
      padding: 15px;
      background: var(--glora-dark);
      color: #fff;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
      transition: background 0.3s ease;
      margin-top: 22px;
    }

    .glora-cart__checkout-btn:hover {
      background: var(--glora-red);
    }

    .glora-cart__continue-link {
      display: block;
      text-align: center;
      margin-top: 14px;
      font-size: 10px;
      color: var(--glora-muted);
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .glora-cart__continue-link:hover {
      color: var(--glora-dark);
      text-decoration: none;
    }

    .glora-cart__summary-note {
      margin-top: 18px;
      padding: 12px 14px;
      background: var(--glora-blush);
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }

    .glora-cart__summary-note i {
      font-size: 12px;
      color: var(--glora-gold);
      margin-top: 1px;
      flex-shrink: 0;
    }

    .glora-cart__summary-note span {
      font-size: 10px;
      color: var(--glora-muted);
      line-height: 1.6;
      letter-spacing: 0.3px;
    }

    /* ── RESPONSIVE ─────────────────────────────────────── */
    @media (max-width: 1024px) {
      .glora-cart__layout {
        grid-template-columns: 1fr 280px;
      }
    }

    @media (max-width: 860px) {
      .glora-cart__layout {
        grid-template-columns: 1fr;
      }

      .glora-cart__summary {
        position: static;
      }
    }

    @media (max-width: 640px) {
      .glora-cart__container {
        padding: 0 16px;
      }

      .glora-cart {
        padding: 36px 0 80px;
      }

      .glora-cart__table-head {
        grid-template-columns: 1fr 80px 36px;
        padding: 10px 14px;
      }

      .glora-cart__table-head .col-price-head,
      .glora-cart__table-head .col-total-head,
      .glora-cart__table-head .col-variant-head {
        display: none;
      }

      .glora-cart__row {
        grid-template-columns: 1fr 80px 36px;
        padding: 14px;
        gap: 8px;
      }

      .glora-cart__cell.col-price,
      .glora-cart__cell.col-total,
      .glora-cart__cell.col-variant {
        display: none;
      }

      .glora-cart__img-wrap {
        width: 60px;
        height: 60px;
      }

      .glora-cart__product {
        gap: 10px;
      }
    }
  </style>

<div class="glora-cart">
  <div class="glora-cart__container">

    <!-- Heading -->
    <div class="glora-cart__heading">
      <span class="glora-cart__eyebrow">Review your selection</span>
      <h1 class="glora-cart__title">Your Bag</h1>
    </div>

    <% if (!cart || cart.length===0) { %>

      <!-- Empty state -->
      <div class="glora-cart__empty">
        <div class="glora-cart__empty-icon">
          <i class="fas fa-shopping-bag"></i>
        </div>
        <h2 class="glora-cart__empty-title">Your bag is empty</h2>
        <p class="glora-cart__empty-sub">Discover something you'll love in our collection</p>
        <a href="/shop" class="glora-cart__empty-cta">Explore the Collection</a>
      </div>

      <% } else { %>

        <% var subtotal=0; cart.forEach(function(item) { subtotal +=item.itemTotal; }); var shippingFree=subtotal>=
          999;
          var shippingProgress = Math.min((subtotal / 999) * 100, 100);
          var remaining = Math.max(999 - subtotal, 0).toFixed(2);
          %>

          <div class="glora-cart__layout">

            <!-- ── ITEMS PANEL ──────────────────────────────── -->
            <div class="glora-cart__items">

              <!-- Table head -->
              <div class="glora-cart__table-head">
                <span>Product</span>
                <span class="col-variant-head">Variant</span>
                <span class="col-price-head">Price</span>
                <span>Quantity</span>
                <span class="col-total-head">Total</span>
                <span></span>
              </div>

              <!-- Rows -->
              <% cart.forEach(function(item) { var unavailable=item.isUnavailable; %>
                <div class="glora-cart__row <%= unavailable ? 'glora-cart__row--unavailable' : '' %>">

                  <!-- Product -->
                  <div class="glora-cart__product">
                    <a href="/product/<%= item.productId._id %>" class="glora-cart__img-wrap"
                      style="text-decoration:none; display:block;">
                      <% if (item.productId.images && item.productId.images.length> 0) { %>
                        <img src="<%= item.productId.images[0] %>" alt="<%= item.productId.productName %>">
                        <% } else { %>
                          <div class="glora-cart__img-placeholder"><i class="fas fa-image"></i></div>
                          <% } %>
                    </a>

                    <div class="glora-cart__product-info">
                      <a href="/product/<%= item.productId._id %>" style="text-decoration:none; color:inherit;">
                        <p class="glora-cart__product-name">
                          <%= item.productId.productName %>
                        </p>
                      </a>

                      <div class="glora-cart__product-meta">
                        <% if (item.appliedOffer) { %>
                          <span class="glora-cart__offer-badge">
                            <i class="fas fa-bolt"></i>
                            <%= item.appliedOffer.title %>
                          </span>
                          <% } %>

                            <% if (unavailable) { %>
                              <span class="glora-cart__oos-badge">
                                <i class="fas fa-ban"></i>
                                Out of Stock
                              </span>
                              <% } %>
                      </div>
                    </div>
                  </div>

                  <!-- Variant -->
                  <div class="glora-cart__cell col-variant">
                    <% if (item.unit) { %>
                      <span class="glora-cart__variant-val">
                        <%= item.unit %>
                      </span>
                      <% } else { %>
                        <% var matchedVariant=item.productId.variants && item.variantIndex !==null &&
                          item.variantIndex !==undefined ? item.productId.variants[item.variantIndex] : null; %>
                          <% if (matchedVariant) { %>
                            <span class="glora-cart__variant-val">
                              <%= matchedVariant.unit %>
                            </span>
                            <% } else { %>
                              <span class="glora-cart__variant-val">—</span>
                              <% } %>
                                <% } %>
                  </div>

                  <!-- Price -->
                  <div class="glora-cart__cell col-price">
                    <span class="glora-cart__price">₹<%= item.price.toFixed(2) %></span>
                  </div>

                  <!-- Quantity -->
                  <div class="glora-cart__cell">
                    <div class="glora-cart__qty-wrap">
                      <div class="glora-cart__qty">
                        <button class="glora-cart__qty-btn dec-btn" data-id="<%= item.productId._id %>"
                          data-price="<%= item.price %>" <%=unavailable ? 'disabled' : '' %>>−</button>
                        <span class="glora-cart__qty-num">
                          <%= item.quantity %>
                        </span>
                        <button class="glora-cart__qty-btn inc-btn" data-id="<%= item.productId._id %>"
                          data-price="<%= item.price %>" <%=unavailable ? 'disabled' : '' %>>+</button>
                      </div>
                    </div>
                  </div>

                  <!-- Total -->
                  <div class="glora-cart__cell col-total">
                    <span class="glora-cart__total">
                      ₹<span class="item-total">
                        <%= item.itemTotal.toFixed(2) %>
                      </span>
                    </span>
                  </div>

                  <!-- Remove -->
                  <button class="glora-cart__remove remove-btn" data-id="<%= item.productId._id %>" title="Remove item">
                    <i class="fas fa-times"></i>
                  </button>

                </div>
                <% }); %>

            </div>

            <!-- ── ORDER SUMMARY ───────────────────────────── -->
            <div class="glora-cart__summary">
              <h2 class="glora-cart__summary-title">Order Summary</h2>

              <div class="glora-cart__summary-row">
                <span class="glora-cart__summary-label">Subtotal</span>
                <span class="glora-cart__summary-value">₹<span id="summary-subtotal">
                    <%= subtotal.toFixed(2) %>
                  </span></span>
              </div>

              <div class="glora-cart__summary-row">
                <span class="glora-cart__summary-label">Shipping</span>
                <% if (shippingFree) { %>
                  <span class="glora-cart__summary-free"><i class="fas fa-check-circle"></i> Free</span>
                  <% } else { %>
                    <span class="glora-cart__summary-value" style="font-size:11px; color:var(--glora-muted);">At
                      checkout</span>
                    <% } %>
              </div>

              <!-- Shipping progress bar -->
              <% if (!shippingFree) { %>
                <div class="glora-cart__shipping-bar-wrap">
                  <p class="glora-cart__shipping-bar-label">
                    Add <strong>₹<%= remaining %></strong> more for free shipping
                  </p>
                  <div class="glora-cart__shipping-bar-track">
                    <div class="glora-cart__shipping-bar-fill" style="width:<%= shippingProgress %>%"></div>
                  </div>
                </div>
                <% } %>

                  <div class="glora-cart__summary-divider"></div>

                  <div class="glora-cart__summary-row">
                    <span class="glora-cart__summary-total-label">Total</span>
                    <span class="glora-cart__summary-total-value">₹<span id="summary-total">
                        <%= subtotal.toFixed(2) %>
                      </span></span>
                  </div>

                  <button id="checkout-btn" class="glora-cart__checkout-btn">
                    <i class="fas fa-lock" style="margin-right:8px; font-size:9px;"></i>Proceed to Checkout
                  </button>

                  <a href="/shop" class="glora-cart__continue-link">← Continue Shopping</a>

                  <div class="glora-cart__summary-note">
                    <i class="fas fa-shield-alt"></i>
                    <span>Free shipping on orders above ₹999. Authentic products, easy returns.</span>
                  </div>
            </div>

          </div>
          <% } %>

  </div>
</div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      /* ── helpers ──────────────────────────────────────── */
      function recalcTotals() {
        var subtotal = 0;
        document.querySelectorAll('.glora-cart__row:not(.glora-cart__row--unavailable)').forEach(function (row) {
          var price = parseFloat(row.querySelector('.inc-btn').dataset.price);
          var qty = parseInt(row.querySelector('.glora-cart__qty-num').textContent);
          var line = price * qty;
          row.querySelector('.item-total').textContent = line.toFixed(2);
          subtotal += line;
        });
        document.getElementById('summary-subtotal').textContent = subtotal.toFixed(2);
        document.getElementById('summary-total').textContent = subtotal.toFixed(2);
      }

      function showErr(msg) {
        Swal.fire({ icon: 'error', title: 'Oops', text: msg, confirmButtonColor: '#1A1A1A' });
      }

      /* ── events ───────────────────────────────────────── */
      document.addEventListener('DOMContentLoaded', function () {

        /* Increment */
        document.querySelectorAll('.inc-btn').forEach(function (btn) {
          btn.addEventListener('click', async function () {
            try {
              var res = await fetch('/cart/increment/' + this.dataset.id, { method: 'POST' });
              var result = await res.json();
              if (result.success) {
                var numEl = this.previousElementSibling;
                numEl.textContent = parseInt(numEl.textContent) + 1;
                recalcTotals();
              } else {
                showErr(result.message || 'Failed to increase quantity');
              }
            } catch { showErr('Failed to update quantity.'); }
          });
        });

        /* Decrement */
        document.querySelectorAll('.dec-btn').forEach(function (btn) {
          btn.addEventListener('click', async function () {
            try {
              var res = await fetch('/cart/decrement/' + this.dataset.id, { method: 'POST' });
              var result = await res.json();
              if (result.success) {
                var numEl = this.nextElementSibling;
                var current = parseInt(numEl.textContent);
                if (current > 1) {
                  numEl.textContent = current - 1;
                  recalcTotals();
                }
              } else {
                Swal.fire({
                  toast: true, position: 'top-end', icon: 'warning',
                  title: result.message, showConfirmButton: false,
                  timer: 2500, timerProgressBar: true
                });
              }
            } catch { showErr('Failed to update quantity.'); }
          });
        });

        /* Remove */
        document.querySelectorAll('.remove-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var id = this.dataset.id;
            Swal.fire({
              title: 'Remove item?',
              text: 'This item will be removed from your bag.',
              icon: 'warning',
              showCancelButton: true,
              confirmButtonColor: '#1A1A1A',
              cancelButtonColor: '#aaa',
              confirmButtonText: 'Remove',
              cancelButtonText: 'Keep it'
            }).then(function (result) {
              if (result.isConfirmed) {
                fetch('/cart/remove/' + id, { method: 'POST' })
                  .then(function () { location.reload(); });
              }
            });
          });
        });

        /* Checkout */
        var checkoutBtn = document.getElementById('checkout-btn');
        if (checkoutBtn) {
          checkoutBtn.addEventListener('click', function () {
            fetch('/cart/validate-checkout', { method: 'POST' })
              .then(function (r) { return r.json(); })
              .then(function (data) {
                if (data.success) {
                  window.location.href = '/checkout';
                } else {
                  showErr(data.message);
                }
              });
          });
        }

      });
    </script>

    <%- include('../partials/user/footer') %>