

<%- include('../partials/user/header', { userName: userName, url: url }) %>

<style>
  /* ── CART PAGE ──────────────────────────────────────── */
  .glora-cart {
    min-height: calc(100vh - 72px);
    background: var(--glora-cream);
    padding: 60px 0 100px;
  }

  .glora-cart__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ── PAGE HEADING ───────────────────────────────────── */
  .glora-cart__heading {
    margin-bottom: 48px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(26,26,26,0.10);
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .glora-cart__eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--glora-gold);
  }

  .glora-cart__title {
    font-family: 'Cormorant Garant', serif;
    font-size: 38px;
    font-weight: 600;
    color: var(--glora-dark);
    letter-spacing: -0.5px;
    line-height: 1;
  }

  /* ── EMPTY STATE ────────────────────────────────────── */
  .glora-cart__empty {
    text-align: center;
    padding: 100px 40px;
  }

  .glora-cart__empty-icon {
    width: 72px; height: 72px;
    border: 1.5px solid rgba(26,26,26,0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 28px;
  }

  .glora-cart__empty-icon i {
    font-size: 26px;
    color: var(--glora-muted);
  }

  .glora-cart__empty-title {
    font-family: 'Cormorant Garant', serif;
    font-size: 30px;
    font-weight: 600;
    color: var(--glora-dark);
    margin-bottom: 10px;
  }

  .glora-cart__empty-sub {
    font-size: 12px;
    color: var(--glora-muted);
    letter-spacing: 0.5px;
    margin-bottom: 32px;
  }

  .glora-cart__empty-cta {
    display: inline-block;
    padding: 13px 36px;
    background: var(--glora-dark);
    color: #fff;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s ease;
  }

  .glora-cart__empty-cta:hover {
    background: var(--glora-red);
    color: #fff;
    text-decoration: none;
  }

  /* ── LAYOUT: items left, summary right ─────────────── */
  .glora-cart__layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 32px;
    align-items: start;
  }

  /* ── ITEMS TABLE ────────────────────────────────────── */
  .glora-cart__items {
    background: #fff;
  }

  /* Table header */
  .glora-cart__table-head {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1.2fr 1fr 40px;
    padding: 12px 24px;
    border-bottom: 1px solid rgba(26,26,26,0.08);
  }

  .glora-cart__table-head span {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--glora-muted);
  }

  .glora-cart__table-head span:not(:first-child) {
    text-align: center;
  }

  /* Row */
  .glora-cart__row {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1.2fr 1fr 40px;
    padding: 20px 24px;
    align-items: center;
    border-bottom: 1px solid rgba(26,26,26,0.06);
    transition: background 0.2s ease;
  }

  .glora-cart__row:hover {
    background: var(--glora-cream);
  }

  .glora-cart__row:last-child {
    border-bottom: none;
  }

  .glora-cart__row--unavailable {
    opacity: 0.45;
    background: #f9f9f9;
  }

  /* Product cell */
  .glora-cart__product {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .glora-cart__img-wrap {
    width: 72px; height: 72px;
    background: var(--glora-blush);
    flex-shrink: 0;
    overflow: hidden;
  }

  .glora-cart__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .glora-cart__row:hover .glora-cart__img-wrap img {
    transform: scale(1.05);
  }

  .glora-cart__img-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: var(--glora-blush);
  }

  .glora-cart__img-placeholder i {
    font-size: 20px;
    color: rgba(26,26,26,0.20);
  }

  .glora-cart__product-info {
    min-width: 0;
  }

  .glora-cart__product-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--glora-dark);
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .glora-cart__product-variant {
    font-size: 11px;
    color: var(--glora-muted);
    letter-spacing: 0.3px;
  }

  .glora-cart__offer-badge {
    display: inline-block;
    margin-top: 8px;
    padding: 5px 12px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--glora-gold);
    background: rgba(217, 179, 102, 0.12);
    border-radius: 999px;
  }

  .glora-cart__unavailable-badge {
    display: inline-block;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--glora-muted);
    border: 1px solid rgba(26,26,26,0.20);
    padding: 2px 8px;
    margin-top: 5px;
  }

  /* Price / Total cells */
  .glora-cart__cell {
    text-align: center;
  }

  .glora-cart__price {
    font-size: 13px;
    font-weight: 500;
    color: var(--glora-dark);
  }

  .glora-cart__total {
    font-size: 13px;
    font-weight: 600;
    color: var(--glora-red);
  }

  /* Quantity control */
  .glora-cart__qty {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    border: 1px solid rgba(26,26,26,0.14);
    width: fit-content;
    margin: 0 auto;
  }

  .glora-cart__qty-btn {
    width: 30px; height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    color: var(--glora-dark);
    transition: background 0.2s ease, color 0.2s ease;
    font-family: 'Poppins', sans-serif;
  }

  .glora-cart__qty-btn:hover:not(:disabled) {
    background: var(--glora-dark);
    color: #fff;
  }

  .glora-cart__qty-btn:disabled {
    cursor: not-allowed;
    color: #ccc;
  }

  .glora-cart__qty-num {
    min-width: 32px;
    text-align: center;
    font-size: 13px;
    font-weight: 500;
    color: var(--glora-dark);
    border-left: 1px solid rgba(26,26,26,0.14);
    border-right: 1px solid rgba(26,26,26,0.14);
    padding: 0 4px;
    line-height: 30px;
    display: block;
  }

  /* Remove btn */
  .glora-cart__remove {
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(26,26,26,0.25);
    font-size: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px; height: 32px;
    transition: color 0.2s ease;
    margin: 0 auto;
  }

  .glora-cart__remove:hover {
    color: var(--glora-red);
  }

  /* ── ORDER SUMMARY ──────────────────────────────────── */
  .glora-cart__summary {
    background: #fff;
    padding: 32px;
    position: sticky;
    top: 92px;
  }

  .glora-cart__summary-title {
    font-family: 'Cormorant Garant', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--glora-dark);
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(26,26,26,0.08);
  }

  .glora-cart__summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .glora-cart__summary-label {
    font-size: 11px;
    color: var(--glora-muted);
    letter-spacing: 0.5px;
  }

  .glora-cart__summary-value {
    font-size: 13px;
    font-weight: 500;
    color: var(--glora-dark);
  }

  .glora-cart__summary-free {
    font-size: 12px;
    font-weight: 500;
    color: #2d7a3a;
  }

  .glora-cart__summary-divider {
    height: 1px;
    background: rgba(26,26,26,0.08);
    margin: 18px 0;
  }

  .glora-cart__summary-total-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--glora-dark);
  }

  .glora-cart__summary-total-value {
    font-family: 'Cormorant Garant', serif;
    font-size: 26px;
    font-weight: 600;
    color: var(--glora-dark);
  }

  .glora-cart__checkout-btn {
    display: block;
    width: 100%;
    padding: 15px;
    background: var(--glora-dark);
    color: #fff;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    font-family: 'Poppins', sans-serif;
    transition: background 0.3s ease;
    margin-top: 24px;
  }

  .glora-cart__checkout-btn:hover {
    background: var(--glora-red);
  }

  .glora-cart__continue-link {
    display: block;
    text-align: center;
    margin-top: 14px;
    font-size: 10px;
    color: var(--glora-muted);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .glora-cart__continue-link:hover {
    color: var(--glora-dark);
    text-decoration: none;
  }

  .glora-cart__summary-note {
    margin-top: 20px;
    padding: 12px 14px;
    background: var(--glora-blush);
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .glora-cart__summary-note i {
    font-size: 12px;
    color: var(--glora-gold);
    margin-top: 1px;
    flex-shrink: 0;
  }

  .glora-cart__summary-note span {
    font-size: 10px;
    color: var(--glora-muted);
    line-height: 1.6;
    letter-spacing: 0.3px;
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 960px) {
    .glora-cart__layout {
      grid-template-columns: 1fr;
    }
    .glora-cart__summary {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .glora-cart__container { padding: 0 20px; }
    .glora-cart { padding: 40px 0 80px; }

    .glora-cart__table-head {
      grid-template-columns: 1fr 80px 90px 40px;
      padding: 10px 16px;
    }

    /* hide Price col header on mobile */
    .glora-cart__table-head .col-price-head { display: none; }

    .glora-cart__row {
      grid-template-columns: 1fr 80px 90px 40px;
      padding: 16px;
      gap: 8px;
    }

    .glora-cart__cell.col-price { display: none; }

    .glora-cart__img-wrap { width: 56px; height: 56px; }
    .glora-cart__product { gap: 10px; }
  }
</style>

<div class="glora-cart">
  <div class="glora-cart__container">

    <!-- Heading -->
    <div class="glora-cart__heading">
      <span class="glora-cart__eyebrow">Review your selection</span>
      <h1 class="glora-cart__title">Your Bag</h1>
    </div>

    <% if (!cart || cart.length === 0) { %>
      <!-- Empty state -->
      <div class="glora-cart__empty">
        <div class="glora-cart__empty-icon">
          <i class="fas fa-shopping-bag"></i>
        </div>
        <h2 class="glora-cart__empty-title">Your bag is empty</h2>
        <p class="glora-cart__empty-sub">Discover something you'll love in our collection</p>
        <a href="/shop" class="glora-cart__empty-cta">Explore the Collection</a>
      </div>

    <% } else { %>

      <%
        var subtotal = 0;
        cart.forEach(function(item) { subtotal += item.itemTotal; });
        var shippingFree = subtotal >= 999;
      %>

      <div class="glora-cart__layout">

        <!-- Items panel -->
        <div class="glora-cart__items">

          <!-- Table head -->
          <div class="glora-cart__table-head">
            <span>Product</span>
            <span class="col-price-head">Price</span>
            <span>Quantity</span>
            <span>Total</span>
            <span></span>
          </div>

          <!-- Rows -->
          <% cart.forEach(function(item) { %>
          <div class="glora-cart__row <%= item.isUnavailable ? 'glora-cart__row--unavailable' : '' %>">

            <!-- Product -->
            <div class="glora-cart__product">
              <div class="glora-cart__img-wrap">
                <% if (item.productId.images && item.productId.images.length > 0) { %>
                  <img src="<%= item.productId.images[0] %>" alt="<%= item.productId.productName %>">
                <% } else { %>
                  <div class="glora-cart__img-placeholder">
                    <i class="fas fa-image"></i>
                  </div>
                <% } %>
              </div>
              <div class="glora-cart__product-info">
                <p class="glora-cart__product-name"><%= item.productId.productName %></p>
                <% if (item.unit) { %>
                  <p class="glora-cart__product-variant"><%= item.unit %></p>
                <% } %>
                <% if (item.appliedOffer) { %>
                  <span class="glora-cart__offer-badge">Offer: <%= item.appliedOffer.title %></span>
                <% } %>
                <% if (item.isUnavailable) { %>
                  <span class="glora-cart__unavailable-badge">Unavailable</span>
                <% } %>
              </div>
            </div>

            <!-- Price -->
            <div class="glora-cart__cell col-price">
              <span class="glora-cart__price">₹<%= item.price.toFixed(2) %></span>
            </div>

            <!-- Quantity -->
            <div class="glora-cart__cell">
              <div class="glora-cart__qty">
                <button class="glora-cart__qty-btn dec-btn"
                  data-id="<%= item.productId._id %>"
                  data-price="<%= item.price %>"
                  <%= item.isUnavailable ? 'disabled' : '' %>>−</button>
                <span class="glora-cart__qty-num"><%= item.quantity %></span>
                <button class="glora-cart__qty-btn inc-btn"
                  data-id="<%= item.productId._id %>"
                  data-price="<%= item.price %>"
                  <%= item.isUnavailable ? 'disabled' : '' %>>+</button>
              </div>
            </div>

            <!-- Total -->
            <div class="glora-cart__cell">
              <span class="glora-cart__total">₹<span class="item-total"><%= item.itemTotal.toFixed(2) %></span></span>
            </div>

            <!-- Remove -->
            <button class="glora-cart__remove remove-btn" data-id="<%= item.productId._id %>" title="Remove">
              <i class="fas fa-times"></i>
            </button>

          </div>
          <% }); %>

        </div>

        <!-- Order Summary -->
        <div class="glora-cart__summary">
          <h2 class="glora-cart__summary-title">Order Summary</h2>

          <div class="glora-cart__summary-row">
            <span class="glora-cart__summary-label">Subtotal</span>
            <span class="glora-cart__summary-value">₹<span id="summary-subtotal"><%= subtotal.toFixed(2) %></span></span>
          </div>

          <div class="glora-cart__summary-row">
            <span class="glora-cart__summary-label">Shipping</span>
            <% if (shippingFree) { %>
              <span class="glora-cart__summary-free">Free</span>
            <% } else { %>
              <span class="glora-cart__summary-value">Calculated at checkout</span>
            <% } %>
          </div>

          <div class="glora-cart__summary-divider"></div>

          <div class="glora-cart__summary-row">
            <span class="glora-cart__summary-total-label">Total</span>
            <span class="glora-cart__summary-total-value">₹<span id="summary-total"><%= subtotal.toFixed(2) %></span></span>
          </div>

          <button id="checkout-btn" class="glora-cart__checkout-btn">
            Proceed to Checkout
          </button>

          <a href="/shop" class="glora-cart__continue-link">← Continue Shopping</a>

          <div class="glora-cart__summary-note">
            <i class="fas fa-shield-alt"></i>
            <span>Free shipping on orders above ₹999. Authentic products, easy returns.</span>
          </div>
        </div>

      </div>
    <% } %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  /* ── helpers ──────────────────────────────────────── */
  function recalcTotals() {
    var subtotal = 0;
    document.querySelectorAll('.glora-cart__row:not(.glora-cart__row--unavailable)').forEach(function(row) {
      var price = parseFloat(row.querySelector('.glora-cart__qty-btn.inc-btn').dataset.price);
      var qty   = parseInt(row.querySelector('.glora-cart__qty-num').textContent);
      var lineTotal = price * qty;
      row.querySelector('.item-total').textContent = lineTotal.toFixed(2);
      subtotal += lineTotal;
    });
    document.getElementById('summary-subtotal').textContent = subtotal.toFixed(2);
    document.getElementById('summary-total').textContent    = subtotal.toFixed(2);
  }

  function showErr(msg) {
    Swal.fire({ icon: 'error', title: 'Oops', text: msg, confirmButtonColor: '#1A1A1A' });
  }

  /* ── events ───────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function() {

    /* Increment */
    document.querySelectorAll('.inc-btn').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        try {
          var res    = await fetch('/cart/increment/' + this.dataset.id, { method: 'POST' });
          var result = await res.json();
          if (result.success) {
            var numEl = this.previousElementSibling;
            numEl.textContent = parseInt(numEl.textContent) + 1;
            recalcTotals();
          } else {
            showErr(result.message || 'Failed to increase quantity');
          }
        } catch { showErr('Failed to update quantity.'); }
      });
    });

    /* Decrement */
    document.querySelectorAll('.dec-btn').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        try {
          var res    = await fetch('/cart/decrement/' + this.dataset.id, { method: 'POST' });
          var result = await res.json();
          if (result.success) {
            var numEl = this.nextElementSibling;
            var current = parseInt(numEl.textContent);
            if (current > 1) {
              numEl.textContent = current - 1;
              recalcTotals();
            }
          } else {
            Swal.fire({
              toast: true, position: 'top-end', icon: 'warning',
              title: result.message, showConfirmButton: false,
              timer: 2500, timerProgressBar: true
            });
          }
        } catch { showErr('Failed to update quantity.'); }
      });
    });

    /* Remove */
    document.querySelectorAll('.remove-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = this.dataset.id;
        Swal.fire({
          title: 'Remove item?',
          text:  'This item will be removed from your bag.',
          icon:  'warning',
          showCancelButton:   true,
          confirmButtonColor: '#1A1A1A',
          cancelButtonColor:  '#aaa',
          confirmButtonText:  'Remove',
          cancelButtonText:   'Keep it'
        }).then(function(result) {
          if (result.isConfirmed) {
            fetch('/cart/remove/' + id, { method: 'POST' })
              .then(function() { location.reload(); });
          }
        });
      });
    });

    /* Checkout */
    var checkoutBtn = document.getElementById('checkout-btn');
    if (checkoutBtn) {
      checkoutBtn.addEventListener('click', function() {
        fetch('/cart/validate-checkout', { method: 'POST' })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.success) {
              window.location.href = '/checkout';
            } else {
              showErr(data.message);
            }
          });
      });
    }

  });
</script>

<%- include('../partials/user/footer') %>
