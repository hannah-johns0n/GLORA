<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>GLORA Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.5/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:wght@400;600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --glora-dark:    #1A1A1A;
      --glora-cream:   #FAF7F4;
      --glora-burgundy:#8B1A1A;
      --glora-gold:    #D4A96A;
      --glora-border:  #E8E2DA;
      --glora-muted:   #888;
      --sidebar-w:     220px;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: #F4F1EC;
      color: var(--glora-dark);
      margin-top: 64px;
    }

    .ga-navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 64px;
      background: var(--glora-dark);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 28px;
      z-index: 1040;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }

    .ga-navbar__left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .ga-navbar__brand {
      font-family: 'Cormorant Garant', serif;
      font-size: 26px;
      font-weight: 600;
      color: var(--glora-cream);
      letter-spacing: 1px;
      text-decoration: none;
    }

    .ga-navbar__brand span {
      color: var(--glora-gold);
      font-size: 10px;
      font-family: 'Poppins', sans-serif;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      display: block;
      line-height: 1;
      margin-top: -2px;
    }

    .ga-navbar__toggle {
      background: none;
      border: none;
      color: var(--glora-cream);
      font-size: 20px;
      cursor: pointer;
      padding: 4px;
      display: none;
    }

    .ga-navbar__right {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .ga-navbar__admin {
      font-size: 12px;
      font-weight: 500;
      color: rgba(255,255,255,0.6);
      letter-spacing: 0.5px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .ga-navbar__admin i {
      font-size: 16px;
      color: var(--glora-gold);
    }

    .ga-logout-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 16px;
      border: 1px solid rgba(255,255,255,0.18);
      background: transparent;
      color: rgba(255,255,255,0.75);
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .ga-logout-btn:hover {
      background: var(--glora-burgundy);
      border-color: var(--glora-burgundy);
      color: #fff;
    }

    .ga-layout {
      display: flex;
      min-height: calc(100vh - 64px);
    }

    .ga-sidebar {
      width: var(--sidebar-w);
      background: #fff;
      border-right: 1px solid var(--glora-border);
      position: fixed;
      top: 64px;
      left: 0;
      bottom: 0;
      overflow-y: auto;
      z-index: 1030;
      transition: transform 0.3s ease;
    }

    .ga-sidebar__inner {
      padding: 24px 0 40px;
    }

    .ga-sidebar__label {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--glora-gold);
      padding: 0 20px;
      margin-bottom: 10px;
      margin-top: 8px;
    }

    .ga-nav {
      list-style: none;
    }

    .ga-nav__link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 20px;
      font-size: 12px;
      font-weight: 500;
      color: #777;
      text-decoration: none;
      letter-spacing: 0.3px;
      border-left: 2px solid transparent;
      transition: all 0.2s ease;
      position: relative;
    }

    .ga-nav__link i {
      font-size: 15px;
      width: 18px;
      text-align: center;
      color: #bbb;
      transition: color 0.2s ease;
    }

    .ga-nav__link:hover {
      color: var(--glora-dark);
      border-left-color: var(--glora-gold);
      background: #FAF7F4;
      padding-left: 24px;
    }

    .ga-nav__link:hover i { color: var(--glora-burgundy); }

    .ga-nav__link.active {
      color: var(--glora-dark);
      border-left-color: var(--glora-burgundy);
      background: #FAF7F4;
      font-weight: 600;
      padding-left: 24px;
    }

    .ga-nav__link.active i { color: var(--glora-burgundy); }

    .ga-sidebar__divider {
      height: 1px;
      background: var(--glora-border);
      margin: 12px 20px;
    }

    .ga-main {
      margin-left: var(--sidebar-w);
      flex: 1;
      min-width: 0;
    }

    @media (max-width: 768px) {
      .ga-navbar__toggle { display: block; }
      .ga-sidebar {
        transform: translateX(-100%);
      }
      .ga-sidebar.open {
        transform: translateX(0);
      }
      .ga-main { margin-left: 0; }
    }
  </style>
</head>

<body>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <nav class="ga-navbar">
    <div class="ga-navbar__left">
      <button class="ga-navbar__toggle" id="sidebarToggle">
        <i class="bi bi-list"></i>
      </button>
      <a class="ga-navbar__brand" href="/admin/dashboard">
        GLORA
        <span>Admin Panel</span>
      </a>
    </div>
    <div class="ga-navbar__right">
      <div class="ga-navbar__admin">
        <i class="bi bi-person-circle"></i>
        Admin
      </div>
      <form action="/admin/Logout" method="POST">
        <button type="submit" class="ga-logout-btn">
          <i class="bi bi-box-arrow-right"></i>
          Logout
        </button>
      </form>
    </div>
  </nav>

  <div class="ga-layout">
    <aside class="ga-sidebar" id="sidebar">
      <div class="ga-sidebar__inner">
        <p class="ga-sidebar__label">Main</p>
        <ul class="ga-nav">
          <li>
            <a class="ga-nav__link <%= (typeof path !== 'undefined' && path === '/admin/dashboard') ? 'active' : '' %>" href="/admin/dashboard">
              <i class="bi bi-speedometer2"></i> Dashboard
            </a>
          </li>
          <li>
            <a class="ga-nav__link <%= (typeof path !== 'undefined' && path === '/admin/user') ? 'active' : '' %>" href="/admin/user">
              <i class="bi bi-people"></i> Customers
            </a>
          </li>
        </ul>

        <div class="ga-sidebar__divider"></div>
        <p class="ga-sidebar__label">Catalogue</p>
        <ul class="ga-nav">
          <li>
            <a class="ga-nav__link <%= (typeof path !== 'undefined' && path === '/admin/category') ? 'active' : '' %>" href="/admin/category">
              <i class="bi bi-grid"></i> Categories
            </a>
          </li>
          <li>
            <a class="ga-nav__link <%= (typeof path !== 'undefined' && path === '/admin/products') ? 'active' : '' %>" href="/admin/products">
              <i class="bi bi-box"></i> Products
            </a>
          </li>
        </ul>

        <div class="ga-sidebar__divider"></div>
        <p class="ga-sidebar__label">Commerce</p>
        <ul class="ga-nav">
          <li>
            <a class="ga-nav__link <%= (typeof path !== 'undefined' && path === '/admin/order-list') ? 'active' : '' %>" href="/admin/order-list">
              <i class="bi bi-cart"></i> Orders
            </a>
          </li>
          <li>
            <a class="ga-nav__link <%= (typeof path !== 'undefined' && path === '/admin/coupons') ? 'active' : '' %>" href="/admin/coupons">
              <i class="bi bi-ticket-perforated"></i> Coupons
            </a>
          </li>
          <li>
            <a class="ga-nav__link <%= (typeof path !== 'undefined' && path === '/admin/offers') ? 'active' : '' %>" href="/admin/offers">
              <i class="bi bi-gift"></i> Offers
            </a>
          </li>
        </ul>

        <div class="ga-sidebar__divider"></div>
        <p class="ga-sidebar__label">Reports</p>
        <ul class="ga-nav">
          <li>
            <a class="ga-nav__link <%= (typeof path !== 'undefined' && path === '/admin/sales-report') ? 'active' : '' %>" href="/admin/sales-report">
              <i class="bi bi-graph-up"></i> Sales Report
            </a>
          </li>
        </ul>
      </div>
    </aside>
