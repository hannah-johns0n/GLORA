<aside class="glora-sidebar">
  <div class="glora-sidebar__user">
    <div class="glora-sidebar__avatar">
      <i class="fas fa-user"></i>
    </div>
    <p class="glora-sidebar__name"><%= typeof user !== 'undefined' && user ? user.name : 'User' %></p>
    <span class="glora-sidebar__label">Member</span>
  </div>

  <nav class="glora-sidebar__nav">
    <a href="/profile" class="glora-sidebar__nav-item <%= activePage === 'profile' ? 'active' : '' %>">
      <i class="fas fa-user"></i> My Account
    </a>
    <a href="/my-orders" class="glora-sidebar__nav-item <%= activePage === 'orders' ? 'active' : '' %>">
      <i class="fas fa-box"></i> My Orders
    </a>
    <a href="/manage-address" class="glora-sidebar__nav-item <%= activePage === 'addresses' ? 'active' : '' %>">
      <i class="fas fa-map-marker-alt"></i> Addresses
    </a>
    <a href="/wallet" class="glora-sidebar__nav-item <%= activePage === 'wallet' ? 'active' : '' %>">
      <i class="fas fa-wallet"></i> Wallet
    </a>
    <a href="/wishlist" class="glora-sidebar__nav-item <%= activePage === 'wishlist' ? 'active' : '' %>">
      <i class="fas fa-heart"></i> Wishlist
    </a>
    <a href="/add-account" class="glora-sidebar__nav-item <%= activePage === 'linked' ? 'active' : '' %>">
      <i class="fas fa-link"></i> Linked Accounts
    </a>
  </nav>

  <div class="glora-sidebar__footer">
    <form action="/logout" method="POST">
      <button type="submit" class="glora-sidebar__logout">
        <i class="fas fa-sign-out-alt" style="margin-right:6px;"></i>Log Out
      </button>
    </form>
  </div>
</aside>

<style>
  /* ── SIDEBAR ── lives here so every page that includes this gets it automatically */
  .glora-sidebar { background: #fff; position: sticky; top: 92px; }

  .glora-sidebar__user {
    padding: 28px 24px 20px;
    border-bottom: 1px solid rgba(26,26,26,0.07);
  }

  .glora-sidebar__avatar {
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--glora-blush);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 12px;
  }
  .glora-sidebar__avatar i { font-size: 20px; color: var(--glora-muted); }

  .glora-sidebar__name {
    font-size: 13px; font-weight: 600; color: var(--glora-dark);
    margin-bottom: 2px; white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis;
  }

  .glora-sidebar__label {
    font-size: 9px; font-weight: 500;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--glora-gold);
  }

  .glora-sidebar__nav { padding: 12px 0; }

  .glora-sidebar__nav-item {
    display: flex; align-items: center; gap: 12px;
    padding: 11px 24px;
    font-size: 11px; font-weight: 500; letter-spacing: 1px;
    color: var(--glora-muted); text-decoration: none;
    transition: background 0.2s, color 0.2s;
    position: relative;
  }
  .glora-sidebar__nav-item::before {
    content: ''; position: absolute;
    left: 0; top: 0; bottom: 0; width: 2px;
    background: var(--glora-red); opacity: 0; transition: opacity 0.2s;
  }
  .glora-sidebar__nav-item:hover {
    background: var(--glora-cream); color: var(--glora-dark); text-decoration: none;
  }
  .glora-sidebar__nav-item.active {
    background: var(--glora-cream); color: var(--glora-dark); font-weight: 600;
  }
  .glora-sidebar__nav-item.active::before { opacity: 1; }

  .glora-sidebar__nav-item i {
    font-size: 13px; width: 16px; text-align: center;
    flex-shrink: 0; color: var(--glora-muted); transition: color 0.2s;
  }
  .glora-sidebar__nav-item:hover i,
  .glora-sidebar__nav-item.active i { color: var(--glora-red); }

  .glora-sidebar__footer {
    padding: 12px 16px 20px;
    border-top: 1px solid rgba(26,26,26,0.07); margin-top: 4px;
  }

  .glora-sidebar__logout {
    display: block; width: 100%; padding: 10px;
    background: none; border: 1px solid rgba(26,26,26,0.15);
    font-size: 9px; font-weight: 600;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--glora-muted); cursor: pointer;
    font-family: 'Poppins', sans-serif;
    transition: all 0.2s; text-align: center;
  }
  .glora-sidebar__logout:hover {
    background: var(--glora-dark); border-color: var(--glora-dark); color: #fff;
  }
</style>
