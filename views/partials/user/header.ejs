<!DOCTYPE html>
<html lang="en">
<head>
  <title>GLORA</title>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,400;0,600;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" type="text/css" href="/styles/bootstrap4/bootstrap.min.css" />

  <style>
    /* ── RESET & BASE ───────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --glora-dark:   #1A1A1A;
      --glora-cream:  #FAF7F4;
      --glora-red:    #8B1A1A;
      --glora-gold:   #D4A96A;
      --glora-blush:  #F0EBE3;
      --glora-muted:  #6B6B6B;
    }

    body {
      background: var(--glora-cream);
      font-family: 'Poppins', sans-serif;
      color: var(--glora-dark);
      margin-top: 72px;
    }

    /* ── HEADER ─────────────────────────────────────── */
    .glora-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1030;
      background: var(--glora-cream);
      border-bottom: 1px solid rgba(26,26,26,0.10);
      height: 72px;
      display: flex;
      align-items: center;
    }

    .glora-header__inner {
      width: 100%;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    /* Logo */
    .glora-header__logo a {
      font-family: 'Cormorant Garant', serif;
      font-size: 26px;
      font-weight: 600;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--glora-dark);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .glora-header__logo a:hover {
      color: var(--glora-red);
    }

    /* Nav */
    .glora-header__nav ul {
      display: flex;
      gap: 36px;
      list-style: none;
      margin: 0; padding: 0;
    }

    .glora-header__nav ul li a {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--glora-muted);
      text-decoration: none;
      position: relative;
      padding-bottom: 3px;
      transition: color 0.2s ease;
    }

    .glora-header__nav ul li a::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 0; height: 1px;
      background: var(--glora-red);
      transition: width 0.3s ease;
    }

    .glora-header__nav ul li a:hover,
    .glora-header__nav ul li a.active {
      color: var(--glora-dark);
    }

    .glora-header__nav ul li a:hover::after,
    .glora-header__nav ul li a.active::after {
      width: 100%;
    }

    .glora-header__nav ul li a.active {
      color: var(--glora-red);
    }

    /* Actions */
    .glora-header__actions {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .glora-header__icon-btn {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--glora-dark);
      text-decoration: none;
      transition: color 0.2s ease;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }

    .glora-header__icon-btn:hover {
      color: var(--glora-red);
    }

    .glora-header__icon-btn i {
      font-size: 16px;
    }

    .glora-header__badge {
      position: absolute;
      top: -6px; right: -6px;
      background: var(--glora-red);
      color: #fff;
      font-size: 9px;
      font-weight: 600;
      width: 16px; height: 16px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Poppins', sans-serif;
    }

    /* Divider */
    .glora-header__divider {
      width: 1px;
      height: 20px;
      background: rgba(26,26,26,0.15);
    }

    /* User area */
    .glora-header__user {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .glora-header__username {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 1px;
      color: var(--glora-dark);
      text-decoration: none;
    }

    .glora-header__username:hover {
      color: var(--glora-red);
      text-decoration: none;
    }

    .glora-header__logout {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--glora-muted);
      background: none;
      border: 1px solid rgba(26,26,26,0.20);
      padding: 5px 14px;
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: 'Poppins', sans-serif;
    }

    .glora-header__logout:hover {
      background: var(--glora-dark);
      color: #fff;
      border-color: var(--glora-dark);
    }

    .glora-header__login {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #fff;
      background: var(--glora-dark);
      border: 1px solid var(--glora-dark);
      padding: 7px 18px;
      text-decoration: none;
      transition: all 0.2s ease;
      display: inline-block;
    }

    .glora-header__login:hover {
      background: var(--glora-red);
      border-color: var(--glora-red);
      color: #fff;
      text-decoration: none;
    }

    .glora-header__guest {
      font-size: 11px;
      color: var(--glora-muted);
      letter-spacing: 0.5px;
    }

    /* ── RESPONSIVE ─────────────────────────────────── */
    @media (max-width: 768px) {
      .glora-header__inner { padding: 0 20px; }
      .glora-header__nav { display: none; }
      .glora-header__logo a { font-size: 22px; letter-spacing: 3px; }
    }
  </style>
</head>

<body>
  <header class="glora-header">
    <div class="glora-header__inner">

      <!-- Logo -->
      <div class="glora-header__logo">
        <a href="/">GLORA</a>
      </div>

      <!-- Nav -->
      <nav class="glora-header__nav">
        <ul>
          <li><a href="/" class="<%= (url === '/' || url === '/home') ? 'active' : '' %>">Home</a></li>
          <li><a href="/shop" class="<%= url && url.startsWith('/shop') ? 'active' : '' %>">Shop</a></li>
          <li><a href="/aboutUs" class="<%= url && url.startsWith('/aboutUs') ? 'active' : '' %>">About</a></li>
        </ul>
      </nav>

      <!-- Actions -->
      <div class="glora-header__actions">
        <!-- Cart -->
        <a href="/cart" class="glora-header__icon-btn" title="Cart">
          <i class="fas fa-shopping-bag"></i>
          <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
            <span class="glora-header__badge"><%= cartCount %></span>
          <% } %>
        </a>

        <!-- Wishlist -->
        <a href="/wishlist" class="glora-header__icon-btn" title="Wishlist">
          <i class="fas fa-heart"></i>
        </a>

        <div class="glora-header__divider"></div>

        <!-- User -->
        <div class="glora-header__user">
          <% if (typeof userName !== 'undefined' && userName) { %>
            <a href="/profile" class="glora-header__username">
              <i class="fas fa-user" style="font-size:13px; margin-right:6px; color: var(--glora-muted);"></i><%= userName %>
            </a>
            <form action="/logout" method="POST" style="margin:0;">
              <button type="submit" class="glora-header__logout">Logout</button>
            </form>
          <% } else { %>
            <span class="glora-header__guest">Guest</span>
            <a href="/login" class="glora-header__login">Sign In</a>
          <% } %>
        </div>
      </div>

    </div>
  </header>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
